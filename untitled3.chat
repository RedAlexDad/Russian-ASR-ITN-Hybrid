              "output": "<path>/home/redalexdad/GitHub/Russian-ASR-ITN-Hybrid/draft.ipynb</path>\n<type>file</type>\n<content>\n1001:     \"            for j in range(start, i):\\n\",\n1002:     \"                tj = tokens[j]; lk2, io2 = lookup_word(tj), is_ordinal_word(tj)\\n\",\n1003:     \"                if io2: gd.append((int(ordinal_value(tj)),0,False,True))\\n\",\n1004:     \"                elif lk2:\\n\",\n1005:     \"                    if tj in _FUSED_COMPOUNDS: gd.extend(_FUSED_COMPOUNDS[tj])\\n\",\n1006:     \"                    else: gd.append((lk2[0],lk2[1],lk2[2],False))\\n\",\n1007:     \"            result_tokens.extend(parse_number_group(gd))\\n\",\n1008:     \"        else:\\n\",\n1009:     \"            result_tokens.append(t); i += 1\\n\",\n1010:     \"    return \\\" \\\".join(result_tokens)\"\n1011:    ]\n1012:   },\n1013:   {\n1014:    \"cell_type\": \"code\",\n1015:    \"execution_count\": null,\n1016:    \"id\": \"2309a956\",\n1017:    \"metadata\": {},\n1018:    \"outputs\": [],\n1019:    \"source\": [\n1020:     \"def normalize_text_sequence(text):\\n\",\n1021:     \"    if not isinstance(text, str) or not text.strip(): return text\\n\",\n1022:     \"    text = _asr_preprocess(text)\\n\",\n1023:     \"    tokens = text.split()\\n\",\n1024:     \"    result_tokens, i = [], 0\\n\",\n1025:     \"    while i < len(tokens):\\n\",\n1026:     \"        cs = classify(tokens[i], tokens[:i])\\n\",\n1027:     \"        if cs and not all(c.subtype == \\\"vague\\\" for c in cs):\\n\",\n1028:     \"            group = []\\n\",\n1029:     \"            while i < len(tokens):\\n\",\n1030:     \"                c2 = classify(tokens[i], tokens[:i])\\n\",\n1031:     \"                if c2 and not all(c.subtype == \\\"vague\\\" for c in c2):\\n\",\n1032:     \"                    group.extend(c2); i += 1\\n\",\n1033:     \"                else: break\\n\",\n1034:     \"            result_tokens.extend(parse_sequence(group))\\n\",\n1035:     \"        else:\\n\",\n1036:     \"            result_tokens.append(tokens[i]); i += 1\\n\",\n1037:     \"    return \\\" \\\".join(result_tokens)\\n\",\n1038:     \"\\n\",\n1039:     \"print(\\\"\\\\n--- Examples ---\\\")\\n\",\n1040:     \"for ex in [\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\",\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 \u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\",\\\"\u0434\u0432\u0430\u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439\\\",\\n\",\n1041:     \"           \\\"\u0441\u043a\u0438\u0434\u043a\u0430 \u0434\u0432\u0435 \u0442\u0441\u044b\u044f\u0447\u0438 \u0447\u0442\u044b\u0440\u0435\u0441\u0442\u0430 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432\\\"]:\\n\",\n1042:     \"    print(f\\\"  IN:  {ex}\\\")\\n\",\n1043:     \"    print(f\\\"  OUT: {normalize_text(ex)}\\\")\\n\",\n1044:     \"    print()\"\n1045:    ]\n1046:   },\n1047:   {\n1048:    \"cell_type\": \"markdown\",\n1049:    \"id\": \"39883731\",\n1050:    \"metadata\": {},\n1051:    \"source\": [\n1052:     \"**\u0410\u043d\u0430\u043b\u0438\u0437 \u043f\u0440\u0438\u043c\u0435\u0440\u043e\u0432:**\\n\",\n1053:     \"\\n\",\n1054:     \"| \u0412\u0445\u043e\u0434 | \u0412\u044b\u0445\u043e\u0434 | \u041e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u044c |\\n\",\n1055:     \"|---|---|---|\\n\",\n1056:     \"| `\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439` | 250 \u0440\u0443\u0431\u043b\u0435\u0439 | \u0411\u0430\u0437\u043e\u0432\u0430\u044f \u0441\u0443\u043c\u043c\u0430 |\\n\",\n1057:     \"| `\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 \u043f\u044f\u0442\u044c\u0441\u043e\u0442` | 2500 | Fused compound |\\n\",\n1058:     \"| `\u0434\u0432\u0430\u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439` | 200 \u0440\u0443\u0431\u043b\u0435\u0439 | ASR-\u043e\u0448\u0438\u0431\u043a\u0430 |\\n\",\n1059:     \"| `\u0441\u043a\u0438\u0434\u043a\u0430 \u0434\u0432\u0435 \u0442\u0441\u044b\u044f\u0447\u0438 \u0447\u0442\u044b\u0440\u0435\u0441\u0442\u0430 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432` | \u0441\u043a\u0438\u0434\u043a\u0430 2 \u0442\u0441\u044b\u044f\u0447\u0438 \u0447\u0442\u044b\u0440\u0435\u0441\u0442\u0430 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432 | ASR-\u0448\u0443\u043c \u043d\u0435 \u0440\u0430\u0441\u043f\u043e\u0437\u043d\u0430\u043d |\\n\",\n1060:     \"\\n\",\n1061:     \"\u0427\u0438\u0441\u0442\u044b\u0435 \u0447\u0438\u0441\u043b\u0430 \u0438 ASR-\u043e\u0448\u0438\u0431\u043a\u0438 \u0438\u0437 \u0441\u043b\u043e\u0432\u0430\u0440\u044f \u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u044e\u0442\u0441\u044f \u043a\u043e\u0440\u0440\u0435\u043a\u0442\u043d\u043e. \\n\",\n1062:     \"\u0417\u0430\u0448\u0443\u043c\u043b\u0451\u043d\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u044b (\u0442\u0441\u044b\u044f\u0447\u0438, \u0447\u0442\u044b\u0440\u0435\u0441\u0442\u0430) \u2014 \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u0438\u0430\u043b\u044c\u043d\u043e\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 rule-based.\"\n1063:    ]\n1064:   },\n1065:   {\n1066:    \"cell_type\": \"markdown\",\n1067:    \"id\": \"80a5fde0\",\n1068:    \"metadata\": {},\n1069:    \"source\": [\n1070:     \"---\\n\",\n1071:     \"## 7. \u041e\u0446\u0435\u043d\u043a\u0430 \u043d\u0430 \u0432\u0441\u0435\u0445 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\u0430\u0445\\n\",\n1072:     \"\\n\",\n1073:     \"\u0421\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435 \u0434\u0432\u0443\u0445 \u043f\u0430\u0440\u0441\u0435\u0440\u043e\u0432: legacy (current) \u0438 sequence.\\n\",\n1074:     \"\\n\",\n1075:     \"| \u0414\u0430\u0442\u0430\u0441\u0435\u0442 | Legacy | Sequence |\\n\",\n1076:     \"|---|---|---|\\n\",\n1077:     \"| calibration.f | 99.80% (499/500) | 99.80% (499/500) |\\n\",\n1078:     \"| synthetic clean | 95.87% (4688/4890) | 95.87% (4688/4890) |\\n\",\n1079:     \"| synthetic noisy | 2.93% (344/11728) | 4.26% (500/11728) |\\n\",\n1080:     \"| real.f | 55.23% (95/172) | 55.23% (95/172) |\"\n1081:    ]\n1082:   },\n1083:   {\n1084:    \"cell_type\": \"code\",\n1085:    \"execution_count\": null,\n1086:    \"id\": \"aa935892\",\n1087:    \"metadata\": {},\n1088:    \"outputs\": [],\n1089:    \"source\": [\n1090:     \"def report(fn, df, name=\\\"\\\"):\\n\",\n1091:     \"    correct = sum(1 for _,r in df.iterrows() if fn(r[\\\"task_text\\\"])==r[\\\"ground_truth\\\"])\\n\",\n1092:     \"    pct = correct/len(df)*100\\n\",\n1093:     \"    print(f\\\"  {name}: {correct}/{len(df)} = {pct:.2f}%\\\")\\n\",\n1094:     \"    if \\\"noise_level\\\" in df.columns:\\n\",\n1095:     \"        for g in [\\\"clean\\\",\\\"noisy\\\"]:\\n\",\n1096:     \"            sub = df[df[\\\"noise_level\\\"]==g]\\n\",\n1097:     \"            if len(sub)==0: continue\\n\",\n1098:     \"            gc = sum(1 for _,r in sub.iterrows() if fn(r[\\\"task_text\\\"])==r[\\\"ground_truth\\\"])\\n\",\n1099:     \"            print(f\\\"         {g}: {gc}/{len(sub)} = {100*gc/len(sub):.2f}%\\\")\\n\",\n1100:     \"    return pct\\n\",\n1101:     \"\\n\",\n1102:     \"print(\\\"=\\\"*50)\\n\",\n1103:     \"print(\\\"=== calibration.f ===\\\")\\n\",\n1104:     \"report(normalize_text, cal, \\\"Current\\\")\\n\",\n1105:     \"report(normalize_text_sequence, cal, \\\"Sequence\\\")\\n\",\n1106:     \"\\n\",\n1107:     \"print(\\\"\\\\n=== synthetic.f ===\\\")\\n\",\n1108:     \"report(normalize_text, syn, \\\"Current\\\")\\n\",\n1109:     \"report(normalize_text_sequence, syn, \\\"Sequence\\\")\\n\",\n1110:     \"\\n\",\n1111:     \"print(\\\"\\\\n=== real.f ===\\\")\\n\",\n1112:     \"report(normalize_text, real, \\\"Current\\\")\\n\",\n1113:     \"report(normalize_text_sequence, real, \\\"Sequence\\\")\"\n1114:    ]\n1115:   },\n1116:   {\n1117:    \"cell_type\": \"markdown\",\n1118:    \"id\": \"588b60a7\",\n1119:    \"metadata\": {},\n1120:    \"source\": [\n1121:     \"**\u0410\u043d\u0430\u043b\u0438\u0437 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432 \u043e\u0446\u0435\u043d\u043a\u0438:**\\n\",\n1122:     \"\\n\",\n1123:     \"**calibration.f:** Current 99.60%, Sequence 99.20%\\n\",\n1124:     \"\u041d\u0438\u0436\u0435 \u044d\u0442\u0430\u043b\u043e\u043d\u043d\u044b\u0445 99.80% \u2014 \u0432 inline-\u0441\u043b\u043e\u0432\u0430\u0440\u0435 \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u043b\u043e \u0451-\u0444\u043e\u0440\u043c ordinal.\\n\",\n1125:     \"\u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043e \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435\u043c 11 \u0444\u043e\u0440\u043c \u0441 \u0451.\\n\",\n1126:     \"\\n\",\n1127:     \"**synthetic.f:** Current 29.48%, Sequence 31.03%\\n\",\n1128:     \"| \u041f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e | Current | Sequence | Delta |\\n\",\n1129:     \"|---|---|---|---|\\n\",\n1130:     \"| clean | 95.87% | 95.87% | 0% |\\n\",\n1131:     \"| noisy | 1.80% | 3.99% | **+2.19%** |\\n\",\n1132:     \"\\n\",\n1133:     \"**real.f:** 55.81% (\u043e\u0431\u0430 \u043f\u0430\u0440\u0441\u0435\u0440\u0430)\\n\",\n1134:     \"\u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043b\u0438\u043f\u0430\u0435\u0442 \u043a \u0442\u043e\u043a\u0435\u043d\u0430\u043c. \u041f\u043e\u0442\u043e\u043b\u043e\u043a \u043f\u043e\u0441\u043b\u0435 \u0444\u0438\u043a\u0441\u043e\u0432: ~85-90%.\"\n1135:    ]\n1136:   },\n1137:   {\n1138:    \"cell_type\": \"markdown\",\n1139:    \"id\": \"cd3b176a\",\n1140:    \"metadata\": {},\n1141:    \"source\": [\n1142:     \"---\\n\",\n1143:     \"## 8. \u0410\u043d\u0430\u043b\u0438\u0437 \u043e\u0448\u0438\u0431\u043e\u043a\\n\",\n1144:     \"\\n\",\n1145:     \"### 8.1 calibration.f \u2014 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u043e\u0448\u0438\u0431\u043a\u0430\\n\",\n1146:     \"\\n\",\n1147:     \"```\\n\",\n1148:     \"TASK: \u0434\u0432\u0430\u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439 \u0441\u043a\u0438\u0434\u043a\u0430 \u043d\u0430 \u0442\u043e\u0432\u0430\u0440 \u0435\u0441\u043b\u0438 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0437\u0430\u043a\u0430\u0437 \u0434\u043e \u0442\u0440\u0451\u0445 \u0447\u0430\u0441\u043e\u0432 \u0434\u043d\u044f\\n\",\n1149:     \"GT:   \u0434\u0432\u0430\u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439 \u0441\u043a\u0438\u0434\u043a\u0430 \u043d\u0430 \u0442\u043e\u0432\u0430\u0440 \u0435\u0441\u043b\u0438 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0437\u0430\u043a\u0430\u0437 \u0434\u043e 3 \u0447\u0430\u0441\u043e\u0432 \u0434\u043d\u044f\\n\",\n1150:     \"PRED: 200 \u0440\u0443\u0431\u043b\u0435\u0439 \u0441\u043a\u0438\u0434\u043a\u0430 \u043d\u0430 \u0442\u043e\u0432\u0430\u0440 \u0435\u0441\u043b\u0438 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0437\u0430\u043a\u0430\u0437 \u0434\u043e 3 \u0447\u0430\u0441\u043e\u0432 \u0434\u043d\u044f\\n\",\n1151:     \"```\\n\",\n1152:     \"\\n\",\n1153:     \"GT \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u0442 ASR-\u043e\u0448\u0438\u0431\u043a\u0443 \\\"\u0434\u0432\u0430\u0441\u0442\u0430\\\" (\u043d\u0435 \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d\u043e). \u041f\u0430\u0440\u0441\u0435\u0440 \u043f\u0440\u0430\u0432 \u2014 ITN.\\n\",\n1154:     \"\\n\",\n1155:     \"### 8.2 real.f \u2014 55.23% (95/172)\\n\",\n1156:     \"\\n\",\n1157:     \"| \u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f | \u041a\u043e\u043b-\u0432\u043e | % | \u041f\u0440\u0438\u043c\u0435\u0440 |\\n\",\n1158:     \"|---|---|---|---|\\n\",\n1159:     \"| \u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043b\u0438\u043f\u043b\u0430 \u043a \u0442\u043e\u043a\u0435\u043d\u0443 | 17 | 22% | `\u0434\u0435\u0432\u044f\u0442\u044c)`, `\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442%` |\\n\",\n1160:     \"| \u0414\u0435\u0441\u044f\u0442\u043a\u0438+\u0435\u0434\u0438\u043d\u0438\u0446\u044b \u0440\u0430\u0437\u0431\u0438\u0442\u044b | 11 | 14% | `\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c \u0434\u0435\u0432\u044f\u0442\u044c)` |\\n\",\n1161:     \"| \u0414\u0435\u0444\u0438\u0441\u043d\u044b\u0435 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438 | 9 | 12% | `\u0444\u0430\u0431-\u043f\u044f\u0442\u044c\u0441\u043e\u0442`, `\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c-\u0445` |\\n\",\n1162:     \"| Decimal comma | 7 | 9% | `\u043e\u0434\u0438\u043d,5`, `\u043f\u044f\u0442\u044c,4` |\\n\",\n1163:     \"| Time-\u0444\u043e\u0440\u043c\u0430\u0442 | 5 | 6% | `\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c:19` |\\n\",\n1164:     \"| \u041a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0435 false positives | ~10 | 13% | `\u043f\u0435\u0440\u0432\u044b\u043c`->1, `\u0434\u0432\u0443\u0445`->2 |\\n\",\n1165:     \"| \u041f\u0440\u043e\u0447\u0435\u0435 | ~18 | 23% | \u0441\u043b\u043e\u0432\u043e\u0444\u043e\u0440\u043c\u044b, 41\u0430-\u0441\u0435\u043c\u044c |\\n\",\n1166:     \"\\n\",\n1167:     \"**\u041f\u043e\u0442\u043e\u043b\u043e\u043a \u043f\u043e\u0441\u043b\u0435 \u0444\u0438\u043a\u0441\u043e\u0432:** ~85-90%\\n\",\n1168:     \"\\n\",\n1169:     \"### 8.3 synthetic.f \u2014 \u0432\u0437\u0432\u0435\u0448\u0435\u043d\u043d\u043e\u0435 \u0441\u0440\u0435\u0434\u043d\u0435\u0435 29.48%\\n\",\n1170:     \"\\n\",\n1171:     \"| \u041f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e | \u0421\u0442\u0440\u043e\u043a | \u0414\u043e\u043b\u044f | Accuracy |\\n\",\n1172:     \"|---|---|---|---|\\n\",\n1173:     \"| clean | 4,890 | 29.4% | **95.87%** |\\n\",\n1174:     \"| noisy | 11,728 | 70.6% | **1.80%** |\\n\",\n1175:     \"\\n\",\n1176:     \"Rule-based \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0442\u043e\u0447\u043d\u043e\u0433\u043e \u0441\u043e\u0432\u043f\u0430\u0434\u0435\u043d\u0438\u044f \u2014 **\u043f\u0440\u0438\u043d\u0446\u0438\u043f\u0438\u0430\u043b\u044c\u043d\u043e\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435**.\\n\",\n1177:     \"ASR-\u0448\u0443\u043c \u043b\u043e\u043c\u0430\u0435\u0442 \u0441\u043b\u043e\u0432\u0430: `\u0442\u0441\u044b\u044f\u0447\u0438`, `\u0447\u0442\u044b\u0440\u0435\u0441\u0442\u0430`, `\u0442\u0440\u0441\u0442\u0430`, `\u0448\u0438\u0441\u0434\u044c\u0441\u0430\u0442`. \u0418\u0441\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e T5.\"\n1178:    ]\n1179:   },\n1180:   {\n1181:    \"cell_type\": \"code\",\n1182:    \"execution_count\": null,\n1183:    \"id\": \"cc278377\",\n1184:    \"metadata\": {},\n1185:    \"outputs\": [],\n1186:    \"source\": [\n1187:     \"def show_errors(fn, df, n=5):\\n\",\n1188:     \"    errors = []\\n\",\n1189:     \"    for i,r in df.iterrows():\\n\",\n1190:     \"        p = fn(r[\\\"task_text\\\"])\\n\",\n1191:     \"        if p != r[\\\"ground_truth\\\"]:\\n\",\n1192:     \"            errors.append((i,r[\\\"task_text\\\"][:80],r[\\\"ground_truth\\\"][:80],p[:80]))\\n\",\n1193:     \"            if len(errors) >= n: break\\n\",\n1194:     \"    for idx,(ri,t,g,p) in enumerate(errors):\\n\",\n1195:     \"        print(f\\\"\\\\n--- {idx+1}. Row {ri} ---\\\\nTASK: {t}\\\\nGT:   {g}\\\\nPRED: {p}\\\")\\n\",\n1196:     \"\\n\",\n1197:     \"print(\\\"=== calibration.f errors ===\\\")\\n\",\n1198:     \"show_errors(normalize_text, cal)\\n\",\n1199:     \"print(\\\"\\\\n=== real.f first 5 errors ===\\\")\\n\",\n1200:     \"show_errors(normalize_text, real)\"\n1201:    ]\n1202:   },\n1203:   {\n1204:    \"cell_type\": \"markdown\",\n1205:    \"id\": \"ac8e856e\",\n1206:    \"metadata\": {},\n1207:    \"source\": [\n1208:     \"**\u0410\u043d\u0430\u043b\u0438\u0437 \u043e\u0448\u0438\u0431\u043e\u043a:**\\n\",\n1209:     \"\\n\",\n1210:     \"### calibration.f (2 \u043e\u0448\u0438\u0431\u043a\u0438 \u0438\u0437 500):\\n\",\n1211:     \"1. Row 136: `\u0434\u0432\u0430\u0441\u0442\u0430` \u2014 GT \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 ASR-\u043e\u0448\u0438\u0431\u043a\u0443, \u043f\u0430\u0440\u0441\u0435\u0440 \u0434\u0430\u0451\u0442 200 (ITN-\u043a\u043e\u0440\u0440\u0435\u043a\u0442\u0435\u043d)\\n\",\n1212:     \"2. Row 242: `\u0434\u0432\u0435\u0441\u0442\u0438 \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u044b\u0439` -> 280 \u2014 \u0451-\u0444\u043e\u0440\u043c\u0430 \u043d\u0435 \u0432 \u0441\u043b\u043e\u0432\u0430\u0440\u0435 (\u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043e)\\n\",\n1213:     \"\\n\",\n1214:     \"### real.f (\u043f\u0435\u0440\u0432\u044b\u0435 5):\\n\",\n1215:     \"1. `\u0434\u0432\u0435 \u0442\u044b\u0441\u044f\u0447\u0438 \u0434\u0432\u0430` -> `\u0434\u0432\u0435 1000 \u0434\u0432\u0430` \u2014 \\\"\u0434\u0432\u0435\\\" \u043d\u0435 \u043e\u043f\u043e\u0437\u043d\u0430\u043d\u043e (\u0436\u0435\u043d\u0441\u043a\u0438\u0439 \u0440\u043e\u0434)\\n\",\n1216:     \"2. `\u043e\u0434\u0438\u043d,5 \u043a\u043c` -> \u043d\u0435 \u0440\u0430\u0441\u043f\u043e\u0437\u043d\u0430\u043d \u043a\u0430\u043a \u0434\u0435\u0441\u044f\u0442\u0438\u0447\u043d\u0430\u044f \u0434\u0440\u043e\u0431\u044c\\n\",\n1217:     \"3. `\u043e\u0434\u043d\u0430 \u0442\u044b\u0441\u044f\u0447\u0430...` -> \\\"\u043e\u0434\u043d\u0430\\\" \u043d\u0435 \u043e\u043f\u043e\u0437\u043d\u0430\u043d\u0430 (\u0436\u0435\u043d\u0441\u043a\u0438\u0439 \u0440\u043e\u0434)\\n\",\n1218:     \"4. `\u043e\u0434\u043d\u0430 \u0442\u044b\u0441\u044f\u0447\u0430 \u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442...` -> \u0442\u0430 \u0436\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430\\n\",\n1219:     \"5. `\u043f\u044f\u0442\u044c-\u0439` -> \u0434\u0435\u0444\u0438\u0441 \u043d\u0435 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u0430\u043d\\n\",\n1220:     \"\\n\",\n1221:     \"\u041f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442 7 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0439 \u0438\u0437 docs/full_report.md:\\n\",\n1222:     \"\u043f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f 22%, \u0434\u0435\u0441\u044f\u0442\u043a\u0438+\u0435\u0434\u0438\u043d\u0438\u0446\u044b 14%, \u0434\u0435\u0444\u0438\u0441\u044b 12%,\\n\",\n1223:     \"decimal comma 9%, time 6%, false positives 13%, \u043f\u0440\u043e\u0447\u0435\u0435 23%\"\n1224:    ]\n1225:   },\n1226:   {\n1227:    \"cell_type\": \"markdown\",\n1228:    \"id\": \"57cfb46c\",\n1229:    \"metadata\": {},\n1230:    \"source\": [\n1231:     \"---\\n\",\n1232:     \"## 9. \u0413\u0438\u0431\u0440\u0438\u0434\u043d\u044b\u0439 \u043f\u043e\u0434\u0445\u043e\u0434 (\u043f\u0430\u0440\u0441\u0435\u0440 + ruT5)\\n\",\n1233:     \"\\n\",\n1234:     \"**\u0410\u0440\u0445\u0438\u0442\u0435\u043a\u0442\u0443\u0440\u0430:**\\n\",\n1235:     \"```\\n\",\n1236:     \"\u0412\u0445\u043e\u0434 -> \u041f\u0430\u0440\u0441\u0435\u0440 -> confidence >= 0.75 -> \u043e\u0442\u0432\u0435\u0442\\n\",\n1237:     \"                -> confidence < 0.75 -> ruT5 fallback\\n\",\n1238:     \"```\\n\",\n1239:     \"\\n\",\n1240:     \"**Confidence rules:**\\n\",\n1241:     \"\\n\",\n1242:     \"| \u041f\u0440\u0438\u0437\u043d\u0430\u043a | \u0412\u0435\u0441 |\\n\",\n1243:     \"|---|---|\\n\",\n1244:     \"| has_asr_error (\\\"\u0434\u0432\u0435\u0441\u0438\\\", \\\"\u0442\u044b\u0449\\\") | -0.3 |\\n\",\n1245:     \"| has_merged_tokens (\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\") | -0.2 |\\n\",\n1246:     \"| has_unknown_words | -0.2 |\\n\",\n1247:     \"| numeral_density > 3 | -0.1 |\\n\",\n1248:     \"\\n\",\n1249:     \"**\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442:** \u0433\u0438\u0431\u0440\u0438\u0434 94.4% vs \u043f\u0430\u0440\u0441\u0435\u0440 97.6% \u2014 **\u043d\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f**.\\n\",\n1250:     \"T5 \u043d\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0430 \u043d\u0430 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0445 ASR-\u043f\u0430\u0442\u0442\u0435\u0440\u043d\u0430\u0445 \u0438 \u0443\u0441\u0442\u0443\u043f\u0430\u0435\u0442 \u043f\u0430\u0440\u0441\u0435\u0440\u0443.\"\n1251:    ]\n1252:   },\n1253:   {\n1254:    \"cell_type\": \"code\",\n1255:    \"execution_count\": null,\n1256:    \"id\": \"fdf22799\",\n1257:    \"metadata\": {},\n1258:    \"outputs\": [],\n1259:    \"source\": [\n1260:     \"def _parser_confidence(text, pred):\\n\",\n1261:     \"    score = 1.0\\n\",\n1262:     \"    tokens = text.lower().split()\\n\",\n1263:     \"    if \\\"\u0434\u0432\u0435\u0441\u0438\\\" in tokens: score -= 0.3\\n\",\n1264:     \"    if any(\\\"\u0442\u044b\u0441\u044f\u0447\\\" in w or \\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\\\" in w for w in tokens): score -= 0.2\\n\",\n1265:     \"    nc = sum(1 for t in tokens if lookup_word(t) is not None)\\n\",\n1266:     \"    if nc > 3: score -= 0.1\\n\",\n1267:     \"    if nc == 0: score -= 0.1\\n\",\n1268:     \"    return max(0.1, min(1.0, score))\\n\",\n1269:     \"\\n\",\n1270:     \"def hybrid_normalize(text):\\n\",\n1271:     \"    pred = normalize_text(text)\\n\",\n1272:     \"    if _parser_confidence(text, pred) >= 0.75: return pred\\n\",\n1273:     \"    mp = \\\"models/ruT5-itn\\\"\\n\",\n1274:     \"    if not os.path.exists(mp): return pred\\n\",\n1275:     \"    try:\\n\",\n1276:     \"        import torch as _torch\\n\",\n1277:     \"        from peft import PeftModel\\n\",\n1278:     \"        from transformers import AutoModelForSeq2SeqLM, AutoTokenizer\\n\",\n1279:     \"        tok = AutoTokenizer.from_pretrained(\\\"cointegrated/ruT5-small\\\", use_fast=False)\\n\",\n1280:     \"        base = AutoModelForSeq2SeqLM.from_pretrained(\\\"cointegrated/ruT5-small\\\")\\n\",\n1281:     \"        model = PeftModel.from_pretrained(base, mp)\\n\",\n1282:     \"        model.eval()\\n\",\n1283:     \"        inp = tok(text, return_tensors=\\\"pt\\\", truncation=True, max_length=64)\\n\",\n1284:     \"        with _torch.no_grad():\\n\",\n1285:     \"            out = model.generate(**inp, max_length=64, num_beams=2, early_stopping=True, no_repeat_ngram_size=2)\\n\",\n1286:     \"        t5 = tok.decode(out[0], skip_special_tokens=True)\\n\",\n1287:     \"        return t5 if t5 and t5 != text else pred\\n\",\n1288:     \"    except Exception:\\n\",\n1289:     \"        return pred\\n\",\n1290:     \"\\n\",\n1291:     \"print(\\\"Hybrid examples (model required at models/ruT5-itn):\\\")\\n\",\n1292:     \"for ex in [\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\",\\\"\u0434\u0432\u0435 \u0442\u044b\u0441\u044f\u0447\u0438 \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044c \u0442\u0440\u0438\\\"]:\\n\",\n1293:     \"    print(f\\\"\\\\nIN:  {ex}\\\\nOUT: {hybrid_normalize(ex)}\\\")\"\n1294:    ]\n1295:   },\n1296:   {\n1297:    \"cell_type\": \"markdown\",\n1298:    \"id\": \"dd743ff8\",\n1299:    \"metadata\": {},\n1300:    \"source\": [\n1301:     \"---\\n\",\n1302:     \"## 10. ML \u043f\u043e\u0434\u0445\u043e\u0434 \u2014 ruT5-small + LoRA\\n\",\n1303:     \"\\n\",\n1304:     \"### \u041f\u0440\u043e\u0431\u043b\u0435\u043c\u0430\\n\",\n1305:     \"\\n\",\n1306:     \"\u041f\u043e\u043b\u043d\u043e\u0435 fine-tuning ruT5-small (65M) \u043d\u0430 <500 samples -> 100% \u043f\u0435\u0440\u0435\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435.\\n\",\n1307:     \"eval_loss=0.2, accuracy=0%, \u043c\u0443\u0441\u043e\u0440\u043d\u044b\u0435 \u0442\u043e\u043a\u0435\u043d\u044b (`<0x57>`).\\n\",\n1308:     \"\\n\",\n1309:     \"**\u041f\u0440\u0438\u0447\u0438\u043d\u0430 `<0x57>`:** \u043c\u0435\u0442\u043a\u0438 \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043b\u0438 `<pad>` (id=0) \u0432\u043c\u0435\u0441\u0442\u043e `-100`.\\n\",\n1310:     \"\u041c\u043e\u0434\u0435\u043b\u044c \u0443\u0447\u0438\u043b\u0430\u0441\u044c \u043f\u0440\u0435\u0434\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u043f\u0430\u0434\u0434\u0438\u043d\u0433 \u043a\u0430\u043a \u0432\u0430\u043b\u0438\u0434\u043d\u044b\u0439 \u0442\u043e\u043a\u0435\u043d.\\n\",\n1311:     \"**\u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435:** `labels[labels == 0] = -100`\\n\",\n1312:     \"\\n\",\n1313:     \"### LoRA \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f\\n\",\n1314:     \"\\n\",\n1315:     \"```python\\n\",\n1316:     \"LoraConfig(r=8, lora_alpha=16,\\n\",\n1317:     \"    target_modules=['q','v','k','o','wi','wo'],\\n\",\n1318:     \"    lora_dropout=0.1)\\n\",\n1319:     \"```\\n\",\n1320:     \"\\n\",\n1321:     \"\u041e\u0431\u0443\u0447\u0430\u0435\u0442\u0441\u044f 0.9M/66M = 1.36% \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432.\\n\",\n1322:     \"\\n\",\n1323:     \"### \u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f\\n\",\n1324:     \"\\n\",\n1325:     \"| \u0417\u0430\u043f\u0443\u0441\u043a | \u042d\u043f\u043e\u0445\u0438 | \u0421\u044d\u043c\u043f\u043b\u044b | Accuracy | Num_acc | CER | \u0412\u0440\u0435\u043c\u044f |\\n\",\n1326:     \"|---|---|---|---|---|---|---|\\n\",\n1327:     \"| ep3_s1000 | 3 | 1000 | 0.00% | 0.00% | 0.819 | ~12 \u043c\u0438\u043d |\\n\",\n1328:     \"| ep3_s2000 | 3 | 2000 | 2.00% | 1.80% | 0.704 | ~12 \u043c\u0438\u043d |\\n\",\n1329:     \"| ep5 | 5 | 4890 | 27.40% | 26.70% | 0.334 | 15.5 \u043c\u0438\u043d |\\n\",\n1330:     \"| ep10 | 10 | 4890 | 42.33% | 46.52% | 0.237 | 31 \u043c\u0438\u043d |\\n\",\n1331:     \"| ep10_r16 | 10 | 4890 | 43.56% | \u2014 | \u2014 | 31.3 \u043c\u0438\u043d |\\n\",\n1332:     \"| **ep20** | **20** | **4890** | **57.26%** | **60.07%** | **0.152** | **61.6 \u043c\u0438\u043d** |\\n\",\n1333:     \"\\n\",\n1334:     \"**\u0414\u0438\u043d\u0430\u043c\u0438\u043a\u0430:**\\n\",\n1335:     \"\\n\",\n1336:     \"| \u042d\u043f\u043e\u0445\u0430 | eval_loss | Accuracy |\\n\",\n1337:     \"|---|---|---|\\n\",\n1338:     \"| 1 | 1.3336 | 7.57% |\\n\",\n1339:     \"| 5 | 0.7762 | 27.40% |\\n\",\n1340:     \"| 10 | 0.5716 | 42.33% |\\n\",\n1341:     \"| 15 | 0.4968 | 57.67% |\\n\",\n1342:     \"| 20 | 0.4848 | 57.26% |\\n\",\n1343:     \"\\n\",\n1344:     \"### \u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f\\n\",\n1345:     \"\\n\",\n1346:     \"- \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u044b \u0442\u043e\u043b\u044c\u043a\u043e clean-\u0434\u0430\u043d\u043d\u044b\u0435 (29% \u043e\u0442 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u044b\u0445)\\n\",\n1347:     \"- LoRA rank=8 (0.9M/66M)\\n\",\n1348:     \"- ruT5-small (65M), \u043d\u0435 base (250M)\\n\",\n1349:     \"- \u0422\u043e\u043b\u044c\u043a\u043e cardinal + ordinal\\n\",\n1350:     \"- \u041f\u043b\u0430\u0442\u043e \u043f\u043e\u0441\u043b\u0435 15 \u044d\u043f\u043e\u0445\"\n1351:    ]\n1352:   },\n1353:   {\n1354:    \"cell_type\": \"markdown\",\n1355:    \"id\": \"280d36ae\",\n1356:    \"metadata\": {},\n1357:    \"source\": [\n1358:     \"### 10.1 \u0417\u0430\u043f\u0443\u0441\u043a \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f\\n\",\n1359:     \"\\n\",\n1360:     \"\u042f\u0447\u0435\u0439\u043a\u0430 \u043d\u0438\u0436\u0435 \u0437\u0430\u043f\u0443\u0441\u043a\u0430\u0435\u0442 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435 ruT5-small \u0441 LoRA. \u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\\n\",\n1361:     \"\\n\",\n1362:     \"- `EPOCHS`: \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u044d\u043f\u043e\u0445 (10-20)\\n\",\n1363:     \"- `BATCH_SIZE`: batch size\\n\",\n1364:     \"- `LORA_R`: LoRA rank (8 \u0438\u043b\u0438 16)\\n\",\n1365:     \"- `MODEL_PATH`: \u043f\u0443\u0442\u044c \u0434\u043b\u044f \u0441\u043e\u0445\u0440\u0430\u043d\u0435\u043d\u0438\u044f (\u043e\u043f\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e, \u0434\u043b\u044f resume)\\n\",\n1366:     \"- `NOISE_LEVEL`: clean / noisy / all\"\n1367:    ]\n1368:   },\n1369:   {\n1370:    \"cell_type\": \"code\",\n1371:    \"execution_count\": null,\n1372:    \"id\": \"8b7ebdd9\",\n1373:    \"metadata\": {},\n1374:    \"outputs\": [],\n1375:    \"source\": [\n1376:     \"# T5 LoRA Training\\n\",\n1377:     \"# Uncomment to run. Requires: torch, transformers, peft, datasets, mlflow\\n\",\n1378:     \"import torch\\n\",\n1379:     \"from transformers import (\\n\",\n1380:     \"    AutoTokenizer, AutoModelForSeq2SeqLM,\\n\",\n1381:     \"    Seq2SeqTrainer, Seq2SeqTrainingArguments,\\n\",\n1382:     \"    DataCollatorForSeq2Seq, EarlyStoppingCallback\\n\",\n1383:     \")\\n\",\n1384:     \"from peft import LoraConfig, get_peft_model, TaskType\\n\",\n1385:     \"from datasets import Dataset\\n\",\n1386:     \"\\n\",\n1387:     \"EPOCHS = 5\\n\",\n1388:     \"BATCH_SIZE = 16\\n\",\n1389:     \"LORA_R = 8\\n\",\n1390:     \"LORA_ALPHA = 16\\n\",\n1391:     \"MAX_LENGTH = 128\\n\",\n1392:     \"OUTPUT_DIR = \\\"models/ruT5-itn\\\"\\n\",\n1393:     \"USE_CLEAN = True\\n\",\n1394:     \"TEST_SIZE = 0.1\\n\",\n1395:     \"\\n\",\n1396:     \"print(\\\"=== T5 LoRA Training ===\\\")\\n\",\n1397:     \"print(f\\\"  Epochs: {EPOCHS}, Batch: {BATCH_SIZE}, LoRA r={LORA_R}\\\")\\n\",\n1398:     \"print(f\\\"  Data: {'clean only' if USE_CLEAN else 'all'}\\\")\\n\",\n1399:     \"\\n\",\n1400:     \"train_df = syn[syn[\\\"ground_truth\\\"].notna() & (syn[\\\"task_text\\\"] != \\\"\\\")]\\n\",\n1401:     \"if USE_CLEAN: train_df = train_df[train_df[\\\"noise_level\\\"] == \\\"clean\\\"]\\n\",\n1402:     \"train_df = train_df[[\\\"task_text\\\", \\\"ground_truth\\\"]].rename(\\n\",\n1403:     \"    columns={\\\"task_text\\\": \\\"input\\\", \\\"ground_truth\\\": \\\"output\\\"})\\n\",\n1404:     \"print(f\\\"  Train samples: {len(train_df)}\\\")\\n\",\n1405:     \"\\n\",\n1406:     \"data = Dataset.from_pandas(train_df.sample(frac=1, random_state=42))\\n\",\n1407:     \"split = data.train_test_split(test_size=TEST_SIZE, seed=42)\\n\",\n1408:     \"print(f\\\"  Train: {len(split['train'])}, Test: {len(split['test'])}\\\")\\n\",\n1409:     \"\\n\",\n1410:     \"tokenizer = AutoTokenizer.from_pretrained(\\\"cointegrated/ruT5-small\\\", use_fast=False)\\n\",\n1411:     \"\\n\",\n1412:     \"def preprocess(batch):\\n\",\n1413:     \"    inp = tokenizer(batch[\\\"input\\\"], truncation=True, max_length=MAX_LENGTH, padding=\\\"max_length\\\")\\n\",\n1414:     \"    tgt = tokenizer(batch[\\\"output\\\"], truncation=True, max_length=MAX_LENGTH, padding=\\\"max_length\\\")\\n\",\n1415:     \"    labels = []\\n\",\n1416:     \"    for seq in tgt[\\\"input_ids\\\"]:\\n\",\n1417:     \"        labels.append([-100 if t == 0 else t for t in seq])\\n\",\n1418:     \"    inp[\\\"labels\\\"] = labels\\n\",\n1419:     \"    return inp\\n\",\n1420:     \"\\n\",\n1421:     \"train_tok = split[\\\"train\\\"].map(preprocess, batched=True, remove_columns=[\\\"input\\\",\\\"output\\\"])\\n\",\n1422:     \"test_tok = split[\\\"test\\\"].map(preprocess, batched=True, remove_columns=[\\\"input\\\",\\\"output\\\"])\\n\",\n1423:     \"\\n\",\n1424:     \"base = AutoModelForSeq2SeqLM.from_pretrained(\\\"cointegrated/ruT5-small\\\")\\n\",\n1425:     \"lora_config = LoraConfig(\\n\",\n1426:     \"    r=LORA_R, lora_alpha=LORA_ALPHA,\\n\",\n1427:     \"    target_modules=[\\\"q\\\",\\\"v\\\",\\\"k\\\",\\\"o\\\",\\\"wi\\\",\\\"wo\\\"],\\n\",\n1428:     \"    lora_dropout=0.1, task_type=TaskType.SEQ_2_SEQ_LM)\\n\",\n1429:     \"model = get_peft_model(base, lora_config)\\n\",\n1430:     \"model.train()\\n\",\n1431:     \"print(f\\\"  Params: {model.num_parameters(only_trainable=True):,} / {model.num_parameters():,}\\\")\\n\",\n1432:     \"\\n\",\n1433:     \"args = Seq2SeqTrainingArguments(\\n\",\n1434:     \"    output_dir=OUTPUT_DIR, num_train_epochs=EPOCHS,\\n\",\n1435:     \"    per_device_train_batch_size=BATCH_SIZE, per_device_eval_batch_size=BATCH_SIZE,\\n\",\n1436:     \"    eval_strategy=\\\"epoch\\\", save_strategy=\\\"epoch\\\",\\n\",\n1437:     \"    load_best_model_at_end=True, metric_for_best_model=\\\"eval_loss\\\",\\n\",\n1438:     \"    greater_is_better=False, save_total_limit=1,\\n\",\n1439:     \"    predict_with_generate=True, fp16=False,\\n\",\n1440:     \"    logging_steps=10, report_to=\\\"none\\\",\\n\",\n1441:     \")\\n\",\n1442:     \"trainer = Seq2SeqTrainer(\\n\",\n1443:     \"    model=model, args=args,\\n\",\n1444:     \"    train_dataset=train_tok, eval_dataset=test_tok,\\n\",\n1445:     \"    data_collator=DataCollatorForSeq2Seq(tokenizer, model=model),\\n\",\n1446:     \"    tokenizer=tokenizer,\\n\",\n1447:     \"    callbacks=[EarlyStoppingCallback(early_stopping_patience=5)],\\n\",\n1448:     \")\\n\",\n1449:     \"\\n\",\n1450:     \"print(f\\\"\\\\nReady to train ({EPOCHS} epochs, ~{3 * EPOCHS} min on GPU)\\\")\\n\",\n1451:     \"# trainer.train()\\n\",\n1452:     \"# model.save_pretrained(OUTPUT_DIR)\\n\",\n1453:     \"print(\\\"Uncomment trainer.train() to run.\\\")\\n\"\n1454:    ]\n1455:   },\n1456:   {\n1457:    \"cell_type\": \"markdown\",\n1458:    \"id\": \"5d30dda4\",\n1459:    \"metadata\": {},\n1460:    \"source\": [\n1461:     \"---\\n\",\n1462:     \"## 11. \u0413\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f \u0441\u0438\u043d\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0434\u0430\u043d\u043d\u044b\u0445\\n\",\n1463:     \"\\n\",\n1464:     \"`scripts/generate_synthetic.py` \u0441\u043e\u0437\u0434\u0430\u0451\u0442 \u043f\u0430\u0440\u044b (task_text, ground_truth) \u0447\u0435\u0440\u0435\u0437:\\n\",\n1465:     \"\\n\",\n1466:     \"1. **number_to_words()** \u2014 \u0447\u0438\u0441\u043b\u043e -> \u0441\u043b\u043e\u0432\u0435\u0441\u043d\u0430\u044f \u0444\u043e\u0440\u043c\u0430 (\u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f)\\n\",\n1467:     \"2. **ASR noise** \u2014 \u0437\u0430\u043c\u0435\u043d\u0430 \u043f\u043e \u0441\u043b\u043e\u0432\u0430\u0440\u044e, \u0441\u043a\u043b\u0435\u0439\u043a\u0430, \u0444\u043e\u043d\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0437\u0430\u043c\u0435\u043d\u044b, \u043f\u0440\u043e\u043f\u0443\u0441\u043a \u0431\u0443\u043a\u0432\\n\",\n1468:     \"3. **\u0428\u0430\u0431\u043b\u043e\u043d\u044b** \u2014 30 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0445 \u0444\u0440\u0430\u0437\\n\",\n1469:     \"4. **\u0413\u0440\u0443\u043f\u043f\u0438\u0440\u043e\u0432\u043a\u0430** \u2014 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0438\u0440\u0443\u0435\u043c\u0430\u044f \u0441\u0443\u043c\u043c\u0430/\u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435\\n\",\n1470:     \"5. **\u041f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435** \u2014 8 \u0448\u0430\u0431\u043b\u043e\u043d\u043e\u0432 x \u0447\u0438\u0441\u043b\u0430 1-31\\n\",\n1471:     \"6. **\u041d\u043e\u0432\u043e\u0441\u0442\u0438** \u2014 RSS-\u043b\u0435\u043d\u0442\u044b + Wikipedia\\n\",\n1472:     \"\\n\",\n1473:     \"**\u0424\u043e\u0440\u043c\u0430\u0442:** Feather \u0441 \u043a\u043e\u043b\u043e\u043d\u043a\u0430\u043c\u0438 task_text, ground_truth, source, num_type, noise_level\"\n1474:    ]\n1475:   },\n1476:   {\n1477:    \"cell_type\": \"code\",\n1478:    \"execution_count\": null,\n1479:    \"id\": \"5cba7969\",\n1480:    \"metadata\": {},\n1481:    \"outputs\": [],\n1482:    \"source\": [\n1483:     \"# \u2550\u2550\u2550 Quick data generation demo \u2550\u2550\u2550\\n\",\n1484:     \"# \u041f\u043e\u043b\u043d\u044b\u0439 \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u043e\u0440: make synthetic (scripts/generate_synthetic.py)\\n\",\n1485:     \"\\n\",\n1486:     \"def number_to_words_demo(n):\\n\",\n1487:     \"    units = [\\\"\\\",\\\"\u043e\u0434\u0438\u043d\\\",\\\"\u0434\u0432\u0430\\\",\\\"\u0442\u0440\u0438\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\\\",\\\"\u043f\u044f\u0442\u044c\\\",\\\"\u0448\u0435\u0441\u0442\u044c\\\",\\\"\u0441\u0435\u043c\u044c\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\\\",\\\"\u0434\u0435\u0432\u044f\u0442\u044c\\\"]\\n\",\n1488:     \"    teens = [\\\"\u0434\u0435\u0441\u044f\u0442\u044c\\\",\\\"\u043e\u0434\u0438\u043d\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0442\u0440\u0438\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\n\",\n1489:     \"             \\\"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0434\u0435\u0432\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\"]\\n\",\n1490:     \"    tens = [\\\"\\\",\\\"\\\",\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0441\u043e\u0440\u043e\u043a\\\",\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\n\",\n1491:     \"            \\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\"]\\n\",\n1492:     \"    hundreds = [\\\"\\\",\\\"\u0441\u0442\u043e\\\",\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\",\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\",\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\",\\n\",\n1493:     \"                \\\"\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442\\\",\\\"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\",\\\"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\\\"]\\n\",\n1494:     \"    if n == 0: return \\\"\u043d\u043e\u043b\u044c\\\"\\n\",\n1495:     \"    if n < 10: return units[n]\\n\",\n1496:     \"    if n < 20: return teens[n-10]\\n\",\n1497:     \"    if n < 100:\\n\",\n1498:     \"        t, u = divmod(n, 10)\\n\",\n1499:     \"        return tens[t] + (\\\" \\\" + units[u] if u else \\\"\\\")\\n\",\n1500:     \"    if n < 1000:\\n\",\n1501:     \"        h, rest = divmod(n, 100)\\n\",\n1502:     \"        return hundreds[h] + (\\\" \\\" + number_to_words_demo(rest) if rest else \\\"\\\")\\n\",\n1503:     \"    if n < 1000000:\\n\",\n1504:     \"        th, rest = divmod(n, 1000)\\n\",\n1505:     \"        base = number_to_words_demo(th)\\n\",\n1506:     \"        th_word = \\\"\u0442\u044b\u0441\u044f\u0447\u0430\\\" if th == 1 else (\\\"\u0442\u044b\u0441\u044f\u0447\u0438\\\" if th < 5 else \\\"\u0442\u044b\u0441\u044f\u0447\\\")\\n\",\n1507:     \"        return base + \\\" \\\" + th_word + (\\\" \\\" + number_to_words_demo(rest) if rest else \\\"\\\")\\n\",\n1508:     \"    return str(n)\\n\",\n1509:     \"\\n\",\n1510:     \"for n in [0, 5, 14, 42, 137, 999, 2024, 54321]:\\n\",\n1511:     \"    print(f\\\"  {n:7d} -> {number_to_words_demo(n)}\\\")\"\n1512:    ]\n1513:   },\n1514:   {\n1515:    \"cell_type\": \"markdown\",\n1516:    \"id\": \"8a946cd6\",\n1517:    \"metadata\": {},\n1518:    \"source\": [\n1519:     \"---\\n\",\n1520:     \"## 12. \u0421\u0432\u043e\u0434\u043a\u0430 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432\\n\",\n1521:     \"\\n\",\n1522:     \"### Rule-based \u043f\u0430\u0440\u0441\u0435\u0440\\n\",\n1523:     \"\\n\",\n1524:     \"| \u0414\u0430\u0442\u0430\u0441\u0435\u0442 | Legacy | Sequence |\\n\",\n1525:     \"|---|---|---|\\n\",\n1526:     \"| calibration.f | **99.80%** (499/500) | **99.80%** (499/500) |\\n\",\n1527:     \"| synthetic clean | **95.87%** (4688/4890) | **95.87%** (4688/4890) |\\n\",\n1528:     \"| synthetic noisy | **2.93%** (344/11728) | **4.26%** (500/11728) |\\n\",\n1529:     \"| real.f | **55.23%** (95/172) | **55.23%** (95/172) |\\n\",\n1530:     \"\\n\",\n1531:     \"### T5 + LoRA\\n\",\n1532:     \"\\n\",\n1533:     \"| \u0417\u0430\u043f\u0443\u0441\u043a | Accuracy |\\n\",\n1534:     \"|---|---|\\n\",\n1535:     \"| ep3, 2000 samples | 2.00% |\\n\",\n1536:     \"| ep5, 4890 clean | 27.40% |\\n\",\n1537:     \"| ep10, 4890 clean | 42.33% |\\n\",\n1538:     \"| ep20, 4890 clean | **57.26%** |\\n\",\n1539:     \"\\n\",\n1540:     \"### \u041a\u043e\u043c\u043c\u0438\u0442\u044b\\n\",\n1541:     \"\\n\",\n1542:     \"| \u041a\u043e\u043c\u043c\u0438\u0442 | \u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 |\\n\",\n1543:     \"|---|---|\\n\",\n1544:     \"| `d73c805` | feat: 99.6% \u0447\u0435\u0440\u0435\u0437 \u0441\u043b\u043e\u0432\u0430\u0440\u043d\u044b\u0435 + \u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0444\u0438\u043a\u0441\u044b |\\n\",\n1545:     \"| `5265561` | feat: regex ASR-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433 (99.8%) |\\n\",\n1546:     \"| `53cd417` | feat: root-based \u0434\u0438\u043d\u0430\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0441\u043b\u043e\u0432\u0430\u0440\u0438 |\\n\",\n1547:     \"| `e6ecd36` | feat: pymorphy2-\u0434\u0438\u0441\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f |\\n\",\n1548:     \"| `cae5e4b` | feat: sequence-based token classifier \u0438 \u043f\u0430\u0440\u0441\u0435\u0440 |\\n\",\n1549:     \"| `0bfcf4b` | feat: clean/noisy split \u0432 evaluate |\\n\",\n1550:     \"| `0922847` | docs: \u043f\u043e\u043b\u043d\u044b\u0439 \u043e\u0442\u0447\u0451\u0442 |\\n\",\n1551:     \"\\n\",\n1552:     \"### \u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f\\n\",\n1553:     \"\\n\",\n1554:     \"1. Rule-based \u043d\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0430 ASR-\u0448\u0443\u043c\u043d\u044b\u0445 \u0434\u0430\u043d\u043d\u044b\u0445 (1.8%) \u2014 \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u0438\u0430\u043b\u044c\u043d\u043e\\n\",\n1555:     \"2. T5 \u043d\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0430 \u043d\u0430 noisy \u2014 clean-only 57%\\n\",\n1556:     \"3. real.f 55% \u2014 \u043f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043b\u0438\u043f\u0430\u0435\u0442 \u043a \u0442\u043e\u043a\u0435\u043d\u0430\u043c\\n\",\n1557:     \"4. Noisy training \u043f\u0440\u0435\u0440\u0432\u0430\u043d \u043d\u0430 epoch 2\\n\",\n1558:     \"5. \u0422\u043e\u043b\u044c\u043a\u043e cardinal + ordinal \u2014 \u043d\u0435\u0442 \u0434\u0440\u043e\u0431\u0435\u0439, \u0434\u0430\u0442, \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432\\n\",\n1559:     \"6. LoRA rank=8 \u2014 \u0443\u0437\u043a\u043e\u0435 \u0433\u043e\u0440\u043b\u044b\u0448\u043a\u043e (0.9M/66M)\"\n1560:    ]\n1561:   }\n1562:  ],\n1563:  \"metadata\": {\n1564:   \"kernelspec\": {\n1565:    \"display_name\": \"Python 3 (ipykernel)\",\n1566:    \"language\": \"python\",\n1567:    \"name\": \"python3\"\n1568:   },\n1569:   \"language_info\": {\n1570:    \"codemirror_mode\": {\n1571:     \"name\": \"ipython\",\n1572:     \"version\": 3\n1573:    },\n1574:    \"file_extension\": \".py\",\n1575:    \"mimetype\": \"text/x-python\",\n1576:    \"name\": \"python\",\n1577:    \"nbconvert_exporter\": \"python\",\n1578:    \"pygments_lexer\": \"ipython3\",\n1579:    \"version\": \"3.12.3\"\n1580:   }\n1581:  },\n1582:  \"nbformat\": 4,\n1583:  \"nbformat_minor\": 5\n1584: }\n\n(End of file - total 1584 lines)\n</content>",
