              "output": "[\n  {\n    \"content\": \"\u0418\u0437\u0443\u0447\u0438\u0442\u044c \u043a\u043b\u044e\u0447\u0435\u0432\u044b\u0435 \u0438\u0441\u0445\u043e\u0434\u043d\u044b\u0435 \u0444\u0430\u0439\u043b\u044b \u043f\u0440\u043e\u0435\u043a\u0442\u0430 (normalizer, parser, hybrid, token_classifier, sequence_parser, lexicon, disambiguate, dicts)\",\n    \"status\": \"in_progress\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"\u0418\u0437\u0443\u0447\u0438\u0442\u044c main.py, cli.py, EDA, \u0442\u0435\u0441\u0442\u044b\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"\u0421\u043e\u0437\u0434\u0430\u0442\u044c comprehensive .ipynb \u043d\u043e\u0443\u0442\u0431\u0443\u043a \u0441 \u043f\u043e\u043b\u043d\u044b\u043c \u0430\u043d\u0430\u043b\u0438\u0437\u043e\u043c \u043f\u0440\u043e\u0435\u043a\u0442\u0430\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  }\n]",
