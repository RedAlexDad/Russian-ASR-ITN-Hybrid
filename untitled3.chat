  \\\"\u2502   \u251c\u2500\u2500 calibration.f     # 500 \u0441\u0442\u0440\u043e\u043a, \u044d\u0442\u0430\u043b\u043e\u043d\\\\n\\\",\\n    \\\"\u2502   \u251c\u2500\u2500 synthetic.f       # ~16.6K \u0441\u0442\u0440\u043e\u043a, \u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f\\\\n\\\",\\n    \\\"\u2502   \u251c\u2500\u2500 real.f            # 172 \u0441\u0442\u0440\u043e\u043a\u0438, \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0435\\\\n\\\",\\n    \\\"\u2502   \u2514\u2500\u2500 test.f            # \u0422\u0435\u0441\u0442\u043e\u0432\u044b\u0439\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 tests/                # \u0422\u0435\u0441\u0442\u044b\\\\n\\\",\\n    \\\"\u2502   \u251c\u2500\u2500 test_parser.py\\\\n\\\",\\n    \\\"\u2502   \u2514\u2500\u2500 test_sequence_parser.py\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 models/               # T5 \u043c\u043e\u0434\u0435\u043b\u0438\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 reports/              # \u041e\u0442\u0447\u0451\u0442\u044b \u0438 \u043f\u043b\u0430\u043d\u044b\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 scripts/              # \u0413\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f \u0434\u0430\u043d\u043d\u044b\u0445\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 makefiles/            # Makefile-\u043c\u043e\u0434\u0443\u043b\u0438\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 Dockerfile\\\\n\\\",\\n    \\\"\u251c\u2500\u2500 docker-compose.yml\\\\n\\\",\\n    \\\"\u2514\u2500\u2500 main.py               # \u0422\u043e\u0447\u043a\u0430 \u0432\u0445\u043e\u0434\u0430\\\\n\\\",\\n    \\\"```\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 2. \u0414\u0430\u0442\u0430\u0441\u0435\u0442\u044b\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0422\u0440\u0438 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\u0430 \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 Feather \u0441 \u043a\u043e\u043b\u043e\u043d\u043a\u0430\u043c\u0438 `task_text`, `ground_truth`, \u0438 \u043c\u0435\u0442\u0430-\u043a\u043e\u043b\u043e\u043d\u043a\u0430\u043c\u0438.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"import sys, os, re, inspect, json, random, math, pickle\\\\n\\\",\\n    \\\"from pathlib import Path\\\\n\\\",\\n    \\\"from dataclasses import dataclass\\\\n\\\",\\n    \\\"from collections import Counter\\\\n\\\",\\n    \\\"import pandas as pd\\\\n\\\",\\n    \\\"import pyarrow.feather as feather\\\\n\\\",\\n    \\\"import numpy as np\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"cal = feather.read_table(\\\\\\\"data/calibration.f\\\\\\\").to_pandas()\\\\n\\\",\\n    \\\"syn = feather.read_table(\\\\\\\"data/synthetic.f\\\\\\\").to_pandas()\\\\n\\\",\\n    \\\"real = feather.read_table(\\\\\\\"data/real.f\\\\\\\").to_pandas()\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'\u0414\u0430\u0442\u0430\u0441\u0435\u0442':<20} {'\u0421\u0442\u0440\u043e\u043a':<8} {'\u0421\u0440\u0435\u0434\u043d\u044f\u044f \u0434\u043b\u0438\u043d\u0430':<15} {'\u041a\u043e\u043b\u043e\u043d\u043a\u0438'}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'calibration.f':<20} {len(cal):<8} {cal['task_text'].str.len().mean():.1f} \u0447\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'synthetic.f':<20} {len(syn):<8} {syn['task_text'].str.len().mean():.1f} \u0447\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'real.f':<20} {len(real):<8} {real['task_text'].str.len().mean():.1f} \u0447\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n\u041f\u043e\u043b\u043d\u044b\u0435 \u043c\u0435\u0442\u0430-\u043a\u043e\u043b\u043e\u043d\u043a\u0438:\\\\\\\")\\\\n\\\",\\n    \\\"for d, label in [(syn, 'synthetic'), (real, 'real'), (cal, 'calibration')]:\\\\n\\\",\\n    \\\"    meta = [c for c in d.columns if c not in ['task_text','ground_truth','__index_level_0__']]\\\\n\\\",\\n    \\\"    if meta:\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  {label}: {meta}\\\\\\\")\\\\n\\\",\\n    \\\"        for m in meta:\\\\n\\\",\\n    \\\"            if d[m].dtype == 'object':\\\\n\\\",\\n    \\\"                vals = d[m].value_counts()\\\\n\\\",\\n    \\\"                print(f\\\\\\\"    {m}: {dict(vals)}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 2.1 calibration.f \u2014 \u044d\u0442\u0430\u043b\u043e\u043d\u043d\u044b\u0439 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"- **500 \u0441\u0442\u0440\u043e\u043a**, \u043a\u043e\u0440\u043e\u0442\u043a\u0438\u0435 ASR-\u0444\u0440\u0430\u0437\u044b (\u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0434\u043b\u0438\u043d\u0430 ~30 \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432)\\\\n\\\",\\n    \\\"- \u0427\u0438\u0441\u043b\u043e\u0432\u044b\u0435 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u044b: \u0446\u0435\u043d\u044b, \u0431\u044e\u0434\u0436\u0435\u0442\u044b, \u0441\u0440\u043e\u043a\u0438, \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u044b\\\\n\\\",\\n    \\\"- \u041c\u0438\u043d\u0438\u043c\u0443\u043c \u043f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u0438, \u0447\u0438\u0441\u0442\u044b\u0439 \u0440\u0443\u0441\u0441\u043a\u0438\u0439 \u044f\u0437\u044b\u043a\\\\n\\\",\\n    \\\"- **\u0411\u0435\u0437 ASR-\u0448\u0443\u043c\u0430** \u2014 \u044d\u0442\u0430\u043b\u043e\u043d \u0434\u043b\u044f \u043e\u0446\u0435\u043d\u043a\u0438 rule-based \u043f\u0430\u0440\u0441\u0435\u0440\u0430\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"### 2.2 synthetic.f \u2014 \u0441\u0438\u043d\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"- **16 618 \u0441\u0442\u0440\u043e\u043a**, \u0441\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u043d \u0447\u0435\u0440\u0435\u0437 `scripts/generate_synthetic.py`\\\\n\\\",\\n    \\\"- \u0414\u0432\u0430 \u043f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u0430: clean (29.4%) \u0438 noisy ASR-\u0448\u0443\u043c (70.6%)\\\\n\\\",\\n    \\\"- 4 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430 \u0448\u0430\u0431\u043b\u043e\u043d\u043e\u0432: template (45.1%), grouping (36.1%), ordinal (18.1%), news (0.7%)\\\\n\\\",\\n    \\\"- 2 \u0442\u0438\u043f\u0430 \u0447\u0438\u0441\u0435\u043b: cardinal (82%) \u0438 ordinal (18%)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u041f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e | \u0421\u0442\u0440\u043e\u043a | \u0414\u043e\u043b\u044f | \u0421\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u044f |\\\\n\\\",\\n    \\\"|---|---|---|---|\\\\n\\\",\\n    \\\"| clean | 4 890 | 29.4% | \u0418\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0439 ASR |\\\\n\\\",\\n    \\\"| noisy | 11 728 | 70.6% | \u0420\u0435\u0430\u043b\u044c\u043d\u044b\u0439 ASR \u0441 \u0448\u0443\u043c\u043e\u043c |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"### 2.3 real.f \u2014 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0434\u0430\u043d\u043d\u044b\u0435\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"- **172 \u0441\u0442\u0440\u043e\u043a\u0438** \u0438\u0437 Wikipedia API \u0438 \u043d\u043e\u0432\u043e\u0441\u0442\u043d\u044b\u0445 RSS\\\\n\\\",\\n    \\\"- \u0414\u043b\u0438\u043d\u043d\u044b\u0435 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u044b (\u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0434\u043b\u0438\u043d\u0430 ~123 \u0441\u0438\u043c\u0432\u043e\u043b\u0430)\\\\n\\\",\\n    \\\"- \u0421\u043c\u0435\u0448\u0430\u043d\u043d\u044b\u0439 \u0440\u0443\u0441\u0441\u043a\u043e-\u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438\u0439 \u0442\u0435\u043a\u0441\u0442\\\\n\\\",\\n    \\\"- \u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f, \u0434\u0435\u0444\u0438\u0441\u044b, \u0441\u043a\u043e\u0431\u043a\u0438, \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u044b\\\\n\\\",\\n    \\\"- **\u0421\u0430\u043c\u044b\u0439 \u0441\u043b\u043e\u0436\u043d\u044b\u0439** \u0434\u0430\u0442\u0430\u0441\u0435\u0442 \u2014 55% \u0442\u043e\u0447\u043d\u043e\u0441\u0442\u044c\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"print(\\\\\\\"--- calibration.f samples ---\\\\\\\")\\\\n\\\",\\n    \\\"for _, r in cal.head(3).iterrows():\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  TASK: {r['task_text']}\\\\\\\")\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  GT:   {r['ground_truth']}\\\\\\\\n\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"--- synthetic.f samples ---\\\\\\\")\\\\n\\\",\\n    \\\"for _, r in syn.head(3).iterrows():\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  TASK: {r['task_text']}\\\\\\\")\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  GT:   {r['ground_truth']}\\\\\\\")\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  meta: noise={r.get('noise_level','?')} src={r.get('source','?')} type={r.get('num_type','?')}\\\\\\\\n\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"--- real.f samples ---\\\\\\\")\\\\n\\\",\\n    \\\"for _, r in real.head(3).iterrows():\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  TASK: {r['task_text'][:100]}\\\\\\\")\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  GT:   {r['ground_truth'][:100]}\\\\\\\\n\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 3. \u0421\u043b\u043e\u0432\u0430\u0440\u043d\u0430\u044f \u0441\u0438\u0441\u0442\u0435\u043c\u0430\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0421\u043b\u043e\u0432\u0430\u0440\u0438 \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0442 **\u0432\u0441\u0435 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0435 \u0441\u043b\u043e\u0432\u043e\u0444\u043e\u0440\u043c\u044b** \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445: \u043f\u0430\u0434\u0435\u0436\u0438, \u0447\u0438\u0441\u043b\u0430, ASR-\u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u044f.\\\\n\\\",\\n    \\\"\u0424\u043e\u0440\u043c\u0430\u0442: `\u0441\u043b\u043e\u0432\u043e \u2192 (\u0447\u0438\u0441\u043b\u043e\u0432\u043e\u0435_\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435, mag)`.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"from dicts.units import UNITS, TEENS, TENS, COLLECTIVE\\\\n\\\",\\n    \\\"from dicts.hundreds import HUNDREDS\\\\n\\\",\\n    \\\"from dicts.thousands import THOUSANDS\\\\n\\\",\\n    \\\"from dicts.ordinals import ORDINALS\\\\n\\\",\\n    \\\"from dicts.asr_errors import ASR_ERRORS\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print('=== \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u0441\u043b\u043e\u0432\u0430\u0440\u0435\u0439 ===')\\\\n\\\",\\n    \\\"dicts_info = [\\\\n\\\",\\n    \\\"    ('UNITS (0-9)', len(UNITS)),\\\\n\\\",\\n    \\\"    ('TEENS (10-19)', len(TEENS)),\\\\n\\\",\\n    \\\"    ('TENS (20-90)', len(TENS)),\\\\n\\\",\\n    \\\"    ('COLLECTIVE (\u0434\u0432\u043e\u0435-\u0434\u0435\u0441\u044f\u0442\u0435\u0440\u043e)', len(COLLECTIVE)),\\\\n\\\",\\n    \\\"    ('HUNDREDS (100-900)', len(HUNDREDS)),\\\\n\\\",\\n    \\\"    ('THOUSANDS (\u0442\u044b\u0441-\u043c\u043b\u043d-\u043c\u043b\u0440\u0434)', len(THOUSANDS)),\\\\n\\\",\\n    \\\"    ('ORDINALS (\u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435)', len(ORDINALS)),\\\\n\\\",\\n    \\\"    ('ASR_ERRORS', len(ASR_ERRORS)),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"total = sum(s for _, s in dicts_info)\\\\n\\\",\\n    \\\"for name, count in dicts_info:\\\\n\\\",\\n    \\\"    bar = '\u2588' * (count // 5)\\\\n\\\",\\n    \\\"    print(f'  {name:30s} {count:4d} \u0444\u043e\u0440\u043c {bar}')\\\\n\\\",\\n    \\\"print(f'  {\\\\\\\"\u0418\u0422\u041e\u0413\u041e\\\\\\\":30s} {total:4d} \u0444\u043e\u0440\u043c')\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f'\\\\\\\\n=== \u0420\u0430\u0437\u0440\u044f\u0434\u044b (mag) ===')\\\\n\\\",\\n    \\\"print(f'  mag=0: \u0435\u0434\u0438\u043d\u0438\u0446\u044b 0-9 (\u0432\u0441\u0435 \u043f\u0430\u0434\u0435\u0436\u0438 + \u0441\u043e\u0431\u0438\u0440\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0435)')\\\\n\\\",\\n    \\\"print(f'  mag=1: \u0447\u0438\u0441\u043b\u0430 10-19')\\\\n\\\",\\n    \\\"print(f'  mag=2: \u0434\u0435\u0441\u044f\u0442\u043a\u0438 20-90')\\\\n\\\",\\n    \\\"print(f'  mag=3: \u0441\u043e\u0442\u043d\u0438 100-900')\\\\n\\\",\\n    \\\"print(f'  mag=4: \u0442\u044b\u0441\u044f\u0447\u0438 (\u0442\u044b\u0441\u044f\u0447\u0430, \u0442\u044b\u0441, \u0442\u044b\u0449)')\\\\n\\\",\\n    \\\"print(f'  mag=5: \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u044b')\\\\n\\\",\\n    \\\"print(f'  mag=6: \u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u044b')\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print('\\\\\\\\n=== ASR-\u043e\u0448\u0438\u0431\u043a\u0438 (\u043f\u043e \u0447\u0430\u0441\u0442\u043e\u0442\u043d\u043e\u0441\u0442\u0438) ===')\\\\n\\\",\\n    \\\"print('  \u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f          \u041f\u0440\u0438\u043c\u0435\u0440\u044b')\\\\n\\\",\\n    \\\"print('  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500         \u2500\u2500\u2500\u2500\u2500\u2500\u2500')\\\\n\\\",\\n    \\\"print('  \u0421\u043e\u0442\u043d\u0438:              \u0434\u0432\u0435\u0441\u0438\u2192\u0434\u0432\u0435\u0441\u0442\u0438, \u0434\u0432\u0430\u0441\u0442\u0430\u2192\u0434\u0432\u0435\u0441\u0442\u0438, \u0442\u0440\u0438\u0441\u0442\u0438\u2192\u0442\u0440\u0438\u0441\u0442\u0430')\\\\n\\\",\\n    \\\"print('  \u0422\u044b\u0441\u044f\u0447\u0438:             \u0442\u044b\u0449\u2192\u0442\u044b\u0441\u044f\u0447, \u0442\u044b\u0449\u0438\u2192\u0442\u044b\u0441\u044f\u0447\u0438, \u0442\u0438\u0449\u2192\u0442\u044b\u0441\u044f\u0447')\\\\n\\\",\\n    \\\"print('  \u0414\u0435\u0441\u044f\u0442\u043a\u0438:            \u043f\u0438\u0441\u044f\u0442\u2192\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442, \u043f\u044f\u0434\u0441\u044f\u0442\u2192\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442')\\\\n\\\",\\n    \\\"print('  10-19:              \u043f\u044f\u0434\u0446\u0438\u0442\u044c\u2192\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c, \u0448\u0438\u0441\u043d\u0430\u0442\u0446\u0430\u0442\u044c\u2192\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c')\\\\n\\\",\\n    \\\"print('  \u041c\u0438\u043b\u043b\u0438\u043e\u043d\u044b:           \u043c\u0438\u043b\u0438\u043e\u043d\u2192\u043c\u0438\u043b\u043b\u0438\u043e\u043d')\\\\n\\\",\\n    \\\"print('  \u041f\u0440\u043e\u043f\u0443\u0441\u043a \u044c:          \u0432\u043e\u0441\u0435\u043c\u0441\u0430\u0442\u2192\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442, \u0441\u0435\u043c\u0441\u043e\u0442\u2192\u0441\u0435\u043c\u044c\u0441\u043e\u0442')\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 3.1 \u041e\u0431\u044a\u0435\u0434\u0438\u043d\u0451\u043d\u043d\u044b\u0439 \u0441\u043b\u043e\u0432\u0430\u0440\u044c\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0414\u043b\u044f lookup-\u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0439 \u0441\u043b\u043e\u0432\u0430\u0440\u0438 \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u044f\u044e\u0442\u0441\u044f \u0432 `NUMERAL_DICT` (137 \u0444\u043e\u0440\u043c).\\\\n\\\",\\n    \\\"\u041e\u0442\u0434\u0435\u043b\u044c\u043d\u043e \u0432\u044b\u0434\u0435\u043b\u044f\u044e\u0442\u0441\u044f **multipliers** \u2014 \u0441\u043b\u043e\u0432\u0430-\u0443\u043c\u043d\u043e\u0436\u0438\u0442\u0435\u043b\u0438 (\u0442\u044b\u0441\u044f\u0447\u0430, \u043c\u0438\u043b\u043b\u0438\u043e\u043d, \u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434).\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"MILLIONS = {\\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\\\\\\\": (1000000, 5), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\\\\\\\": (1000000, 5),\\\\n\\\",\\n    \\\"    \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432\\\\\\\": (1000000, 5), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u043c\\\\\\\": (1000000, 5),\\\\n\\\",\\n    \\\"    \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u043c\\\\\\\": (1000000, 5), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u043c\u0438\\\\\\\": (1000000, 5), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u0445\\\\\\\": (1000000, 5)}\\\\n\\\",\\n    \\\"BILLIONS = {\\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\\\\\\\": (1000000000, 6), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u0430\\\\\\\": (1000000000, 6),\\\\n\\\",\\n    \\\"    \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u043e\u0432\\\\\\\": (1000000000, 6), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u0430\u043c\\\\\\\": (1000000000, 6),\\\\n\\\",\\n    \\\"    \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u0430\u043c\u0438\\\\\\\": (1000000000, 6), \\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\u0430\u0445\\\\\\\": (1000000000, 6)}\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"NUMERAL_DICT = {}\\\\n\\\",\\n    \\\"for d in (UNITS, TEENS, TENS, HUNDREDS, THOUSANDS, MILLIONS, BILLIONS):\\\\n\\\",\\n    \\\"    NUMERAL_DICT.update(d)\\\\n\\\",\\n    \\\"NUMERAL_DICT.update({\\\\\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\\\\\": (2000, 0), \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0435\\\\\\\": (200, 3), \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\": (2500, 0)})\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"MULTIPLIERS = set()\\\\n\\\",\\n    \\\"for d in (THOUSANDS, MILLIONS, BILLIONS):\\\\n\\\",\\n    \\\"    MULTIPLIERS.update(d.keys())\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"NUMERAL_DICT: {len(NUMERAL_DICT)} entries\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"MULTIPLIERS: {len(MULTIPLIERS)} multipliers\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"ORDINALS: {len(ORDINALS)} ordinal forms (\u0432\u043a\u043b\u044e\u0447\u0430\u044f \u0451-\u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b)\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"ASR_ERRORS: {len(ASR_ERRORS)} error mappings\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"\\\\\\\\n\u0422\u043e\u043f-5 \u043f\u0430\u0434\u0435\u0436\u0435\u0439 \u0432 UNITS:\\\\\\\")\\\\n\\\",\\n    \\\"cases = Counter()\\\\n\\\",\\n    \\\"for word in UNITS:\\\\n\\\",\\n    \\\"    if word in ('\u043d\u043e\u043b\u044c','\u043e\u0434\u0438\u043d','\u0434\u0432\u0430','\u0442\u0440\u0438','\u0447\u0435\u0442\u044b\u0440\u0435','\u043f\u044f\u0442\u044c','\u0448\u0435\u0441\u0442\u044c','\u0441\u0435\u043c\u044c','\u0432\u043e\u0441\u0435\u043c\u044c','\u0434\u0435\u0432\u044f\u0442\u044c'):\\\\n\\\",\\n    \\\"        cases[word] += 1\\\\n\\\",\\n    \\\"print(f\\\\\\\"  {dict(cases)}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 4. Token Classifier (\u043d\u043e\u0432\u044b\u0439 \u043f\u0443\u0442\u044c \u2014 sequence)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0415\u0434\u0438\u043d\u044b\u0439 \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440, \u0437\u0430\u043c\u0435\u043d\u044f\u044e\u0449\u0438\u0439 ad-hoc `lookup_word` + `is_ordinal_word` +\\\\n\\\",\\n    \\\"`_cardinal_from_root` + `_fuzzy_ordinal_match` \u043d\u0430 \u0441\u0438\u0441\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043f\u0430\u0439\u043f\u043b\u0430\u0439\u043d.\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u041f\u0430\u0439\u043f\u043b\u0430\u0439\u043d classify():**\\\\n\\\",\\n    \\\"1. Vague context \\\\\\\"\u0442\u044b\u0449\\\\\\\" \u2192 \u043f\u0440\u043e\u043f\u0443\u0441\u043a (\u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440\u043d\u043e\u0435 \\\\\\\"\u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e\\\\\\\")\\\\n\\\",\\n    \\\"2. Exact dict match (O(1), \u0431\u044b\u0441\u0442\u0440\u044b\u0439 \u043f\u0443\u0442\u044c)\\\\n\\\",\\n    \\\"3. Ordinal exact match\\\\n\\\",\\n    \\\"4. ASR error correction\\\\n\\\",\\n    \\\"5. Root-based regex (33 \u043a\u043e\u0440\u043d\u044f, \u0441\u043e\u0440\u0442\u0438\u0440\u043e\u0432\u043a\u0430 \u043f\u043e \u0443\u0431\u044b\u0432\u0430\u043d\u0438\u044e \u0434\u043b\u0438\u043d\u044b)\\\\n\\\",\\n    \\\"6. Fused compound split (\\\\\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\\\\\" \u2192 \u0434\u0432\u0430 + \u0442\u044b\u0441\u044f\u0447\u0438)\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"@dataclass\\\\n\\\",\\n    \\\"class TokenClass:\\\\n\\\",\\n    \\\"    value: int\\\\n\\\",\\n    \\\"    mag: int\\\\n\\\",\\n    \\\"    subtype: str\\\\n\\\",\\n    \\\"    raw: str\\\\n\\\",\\n    \\\"    confidence: float = 1.0\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"TokenClass:\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  value={TokenClass(5,0,'cardinal','\u043f\u044f\u0442\u044c')}  # 5, mag=0 cardinal\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  value={TokenClass(1000,4,'multiplier','\u0442\u044b\u0441\u044f\u0447\u0430')}  # 1000, mag=4 multiplier\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  value={TokenClass(5,0,'ordinal','\u043f\u044f\u0442\u044b\u0439')}  # ordinal\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  value={TokenClass(1000,4,'vague','\u0442\u044b\u0449')}  # vague (\u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440\u043d\u043e\u0435)\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 4.1 \u041a\u043e\u0440\u043d\u0435\u0432\u044b\u0435 \u043f\u0430\u0442\u0442\u0435\u0440\u043d\u044b (33 \u043a\u043e\u0440\u043d\u044f)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u043d\u043e\u0432\u043e\u0432\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u2014 **root-based** \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f \u0441\u043b\u043e\u0432 \u043f\u043e \u043a\u043e\u0440\u043d\u044e + \u0441\u0443\u0444\u0444\u0438\u043a\u0441\u0443.\\\\n\\\",\\n    \\\"\u041a\u043e\u0440\u043d\u0438 \u043e\u0442\u0441\u043e\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b \u043f\u043e \u0443\u0431\u044b\u0432\u0430\u043d\u0438\u044e \u0434\u043b\u0438\u043d\u044b, \u0447\u0442\u043e\u0431\u044b \u0434\u043b\u0438\u043d\u043d\u044b\u0435 \u043a\u043e\u0440\u043d\u0438 \u043c\u0430\u0442\u0447\u0438\u043b\u0438\u0441\u044c \u0440\u0430\u043d\u044c\u0448\u0435 \u043a\u043e\u0440\u043e\u0442\u043a\u0438\u0445:\\\\n\\\",\\n    \\\"\\\\\\\"\u043f\u044f\u0442\u0438\u0434\u0435\u0441\u044f\u0442\\\\\\\" (8) \u0440\u0430\u043d\u044c\u0448\u0435 \\\\\\\"\u0434\u0435\u0441\u044f\u0442\\\\\\\" (5).\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"_NUMERIC_ROOTS = [\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434\\\\\\\", 1000000000, 6, True), (\\\\\\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\\\\\\\", 1000000, 5, True),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0442\u044b\u0441\u044f\u0447\\\\\\\", 1000, 4, True), (\\\\\\\"\u0442\u044b\u0449\\\\\\\", 1000, 4, True),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043f\u044f\u0442\u0438\u0434\u0435\u0441\u044f\u0442\\\\\\\", 50, 2, False), (\\\\\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", 50, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0448\u0435\u0441\u0442\u0438\u0434\u0435\u0441\u044f\u0442\\\\\\\", 60, 2, False), (\\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", 60, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0441\u0435\u043c\u0438\u0434\u0435\u0441\u044f\u0442\\\\\\\", 70, 2, False), (\\\\\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", 70, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0432\u043e\u0441\u044c\u043c\u0438\u0434\u0435\u0441\u044f\u0442\\\\\\\", 80, 2, False), (\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", 80, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\\\\\\\", 20, 2, False), (\\\\\\\"\u0442\u0440\u0438\u0434\u0446\u0430\u0442\\\\\\\", 30, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\\\\\\\", 90, 2, False), (\\\\\\\"\u0434\u0435\u0441\u044f\u0442\\\\\\\", 10, 1, False), (\\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\", 40, 2, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\", 900, 3, False), (\\\\\\\"\u0434\u0435\u0432\u044f\u0442\u0438\u0441\u043e\u0442\\\\\\\", 900, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\\\\\", 800, 3, False), (\\\\\\\"\u0432\u043e\u0441\u044c\u043c\u0438\u0441\u043e\u0442\\\\\\\", 800, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\\\\\", 700, 3, False), (\\\\\\\"\u0441\u0435\u043c\u0438\u0441\u043e\u0442\\\\\\\", 700, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442\\\\\\\", 600, 3, False), (\\\\\\\"\u0448\u0435\u0441\u0442\u0438\u0441\u043e\u0442\\\\\\\", 600, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\", 500, 3, False), (\\\\\\\"\u043f\u044f\u0442\u0438\u0441\u043e\u0442\\\\\\\", 500, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\\\\\", 400, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\", 300, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\\\\\", 200, 3, False), (\\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\", 200, 3, False), (\\\\\\\"\u0434\u0432\u0430\u0441\u0442\u0430\\\\\\\", 200, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0441\u043e\u0442\\\\\\\", 100, 3, False), (\\\\\\\"\u0441\u0442\u0430\\\\\\\", 100, 3, False), (\\\\\\\"\u0441\u0442\u043e\\\\\\\", 100, 3, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0447\u0435\u0442\u044b\u0440\\\\\\\", 4, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0442\u0440\u043e\u0435\\\\\\\", 3, 0, False), (\\\\\\\"\u0442\u0440\u0451\u0445\\\\\\\", 3, 0, False), (\\\\\\\"\u0442\u0440\u0435\u0445\\\\\\\", 3, 0, False), (\\\\\\\"\u0442\u0440\u0438\\\\\\\", 3, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u043e\u0435\\\\\\\", 2, 0, False), (\\\\\\\"\u0434\u0432\u0443\u0445\\\\\\\", 2, 0, False), (\\\\\\\"\u0434\u0432\u0435\\\\\\\", 2, 0, False), (\\\\\\\"\u0434\u0432\u0430\\\\\\\", 2, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043e\u0434\u0438\u043d\\\\\\\", 1, 0, False), (\\\\\\\"\u043e\u0434\u043d\u0430\\\\\\\", 1, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043f\u044f\u0442\\\\\\\", 5, 0, False), (\\\\\\\"\u0448\u0435\u0441\u0442\\\\\\\", 6, 0, False), (\\\\\\\"\u0441\u0435\u043c\\\\\\\", 7, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\\\\\\\", 8, 0, False), (\\\\\\\"\u0432\u043e\u0441\u044c\u043c\\\\\\\", 8, 0, False), (\\\\\\\"\u0432\u043e\u0441\u0435\u043c\\\\\\\", 8, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0435\u0432\u044f\u0442\\\\\\\", 9, 0, False), (\\\\\\\"\u043d\u043e\u043b\\\\\\\", 0, 0, False), (\\\\\\\"\u043d\u0443\u043b\\\\\\\", 0, 0, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043e\u0434\u0438\u043d\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 11, 1, False), (\\\\\\\"\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 12, 1, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0442\u0440\u0438\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 13, 1, False), (\\\\\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 14, 1, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 15, 1, False), (\\\\\\\"\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 16, 1, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 17, 1, False), (\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 18, 1, False),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0435\u0432\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\\\\\\\", 19, 1, False),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\u0412\u0441\u0435\u0433\u043e \u043a\u043e\u0440\u043d\u0435\u0439: {len(_NUMERIC_ROOTS)}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  cardinal: {sum(1 for _,_,_,m in _NUMERIC_ROOTS if not m)}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  multiplier: {sum(1 for _,_,_,m in _NUMERIC_ROOTS if m)}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  \u043c\u0430\u043a\u0441. \u0434\u043b\u0438\u043d\u0430 \u043a\u043e\u0440\u043d\u044f: {max(len(r) for r,_,_,_ in _NUMERIC_ROOTS)} \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  \u043c\u0438\u043d. \u0434\u043b\u0438\u043d\u0430 \u043a\u043e\u0440\u043d\u044f: {min(len(r) for r,_,_,_ in _NUMERIC_ROOTS)} \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u0414\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0430\u0446\u0438\u044f \u043f\u043e\u043a\u0440\u044b\u0442\u0438\u044f \u043a\u043e\u0440\u043d\u0435\u0439\\\\n\\\",\\n    \\\"test_words = ['\u043f\u044f\u0442\u044c', '\u043f\u044f\u0442\u0438', '\u043f\u044f\u0442\u044c\u044e', '\u043f\u044f\u0442\u0435\u0440\u043e', '\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c', '\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442', '\u043f\u044f\u0442\u0438\u0441\u043e\u0442', '\u043f\u044f\u0442\u0438\u0434\u0435\u0441\u044f\u0442\u0438']\\\\n\\\",\\n    \\\"print(\\\\\\\"\\\\\\\\n\u041f\u0440\u0438\u043c\u0435\u0440\u044b root-matching:\\\\\\\")\\\\n\\\",\\n    \\\"for w in test_words:\\\\n\\\",\\n    \\\"    matched = [(r,v,m) for r,v,m,_ in _NUMERIC_ROOTS if w.lower().startswith(r)]\\\\n\\\",\\n    \\\"    if matched:\\\\n\\\",\\n    \\\"        best = max(matched, key=lambda x: len(x[0]))\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  {w:15s} \u2192 root={best[0]:10s} val={best[1]:4d} mag={best[2]}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 4.2 \u041f\u043e\u043b\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f classify()\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041c\u043d\u043e\u0433\u043e\u0441\u043b\u043e\u0439\u043d\u044b\u0439 \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0441 6 \u0441\u0442\u0430\u0434\u0438\u044f\u043c\u0438 \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"_INFLECTION_SUFFIXES = {\\\\\\\"\\\\\\\", \\\\\\\"\u0430\\\\\\\", \\\\\\\"\u0443\\\\\\\", \\\\\\\"\u0435\\\\\\\", \\\\\\\"\u0438\\\\\\\", \\\\\\\"\u043e\u0439\\\\\\\", \\\\\\\"\u044b\u0445\\\\\\\", \\\\\\\"\u044b\u043c\\\\\\\", \\\\\\\"\u044b\u043c\u0438\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u043c\\\\\\\", \\\\\\\"\u0430\u043c\\\\\\\", \\\\\\\"\u0430\u043c\u0438\\\\\\\", \\\\\\\"\u0430\u0445\\\\\\\", \\\\\\\"\u0435\u0439\\\\\\\", \\\\\\\"\u044e\\\\\\\", \\\\\\\"\u044f\\\\\\\", \\\\\\\"\u044c\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u044b\u0439\\\\\\\", \\\\\\\"\u0438\u0439\\\\\\\", \\\\\\\"\u0430\u044f\\\\\\\", \\\\\\\"\u043e\u0435\\\\\\\", \\\\\\\"\u044b\u0435\\\\\\\", \\\\\\\"\u043e\u0433\u043e\\\\\\\", \\\\\\\"\u0435\u0433\u043e\\\\\\\", \\\\\\\"\u043e\u043c\u0443\\\\\\\", \\\\\\\"\u0435\u043c\u0443\\\\\\\", \\\\\\\"\u0443\u044e\\\\\\\", \\\\\\\"\u044c\u044f\\\\\\\", \\\\\\\"\u044c\u0435\\\\\\\", \\\\\\\"\u044c\u0438\\\\\\\"}\\\\n\\\",\\n    \\\"_ORDINAL_SUFFIXES = {\\\\\\\"\u044b\u0439\\\\\\\", \\\\\\\"\u0438\u0439\\\\\\\", \\\\\\\"\u043e\u0439\\\\\\\", \\\\\\\"\u0430\u044f\\\\\\\", \\\\\\\"\u044c\u044f\\\\\\\", \\\\\\\"\u043e\u0435\\\\\\\", \\\\\\\"\u044c\u0435\\\\\\\", \\\\\\\"\u044b\u0435\\\\\\\", \\\\\\\"\u044c\u0438\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u0433\u043e\\\\\\\", \\\\\\\"\u0435\u0433\u043e\\\\\\\", \\\\\\\"\u043e\u043c\u0443\\\\\\\", \\\\\\\"\u0435\u043c\u0443\\\\\\\", \\\\\\\"\u044b\u043c\\\\\\\", \\\\\\\"\u0438\u043c\u0438\\\\\\\", \\\\\\\"\u044b\u043c\u0438\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u043c\\\\\\\", \\\\\\\"\u0435\u043c\\\\\\\", \\\\\\\"\u044b\u0445\\\\\\\", \\\\\\\"\u044b\u0445\\\\\\\", \\\\\\\"\u0438\u0445\\\\\\\", \\\\\\\"\u0443\u044e\\\\\\\", \\\\\\\"\u044e\\\\\\\", \\\\\\\"\u0435\u0439\\\\\\\"}\\\\n\\\",\\n    \\\"_NON_ORDINALS = {\\\\\\\"\u043a\u0430\u043a\u043e\u0439\\\\\\\", \\\\\\\"\u0442\u0430\u043a\u043e\u0439\\\\\\\", \\\\\\\"\u0434\u0440\u0443\u0433\u043e\u0439\\\\\\\", \\\\\\\"\u043b\u044e\u0431\u043e\u0439\\\\\\\", \\\\\\\"\u043a\u0430\u0436\u0434\u043e\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0430\u043c\u043e\u0439\\\\\\\", \\\\\\\"\u0441\u0430\u043c\u044b\u0439\\\\\\\", \\\\\\\"\u0441\u0430\u043c\u043e\u0435\\\\\\\", \\\\\\\"\u043d\u043e\u0432\u0430\u044f\\\\\\\", \\\\\\\"\u043d\u043e\u0432\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u0440\u043e\u0441\u0442\u043e\u0439\\\\\\\", \\\\\\\"\u0433\u043b\u0430\u0432\u043d\u044b\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0431\u043e\u043b\u044c\u0448\u043e\u0439\\\\\\\", \\\\\\\"\u0445\u043e\u0440\u043e\u0448\u0438\u0439\\\\\\\", \\\\\\\"\u043f\u043b\u043e\u0445\u043e\u0439\\\\\\\", \\\\\\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0432\u044b\u0441\u043e\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043d\u0438\u0437\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043d\u0443\u0436\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439\\\\\\\", \\\\\\\"\u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0440\u0430\u0437\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0446\u0435\u043b\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u043b\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0432\u0430\u0436\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0442\u043e\u0447\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u0431\u044b\u0447\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u0434\u043e\u0431\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043f\u0440\u0435\u0436\u043d\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u044e\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0441\u043a\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043d\u0430\u0443\u0447\u043d\u044b\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0432\u0442\u043e\u0440\u043e\u0439\\\\\\\"}\\\\n\\\",\\n    \\\"_VAGUE_MARKERS = {\\\\\\\"\u0432\u044b\u0448\u0435\\\\\\\", \\\\\\\"\u043d\u0438\u0436\u0435\\\\\\\", \\\\\\\"\u043e\u043a\u043e\u043b\u043e\\\\\\\", \\\\\\\"\u043f\u043e\u0447\u0442\u0438\\\\\\\"}\\\\n\\\",\\n    \\\"_MULTIPLIER_SET = set()\\\\n\\\",\\n    \\\"for d in (THOUSANDS, MILLIONS, BILLIONS):\\\\n\\\",\\n    \\\"    _MULTIPLIER_SET.update(d.keys())\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _is_vague_context(prev_tokens):\\\\n\\\",\\n    \\\"    if len(prev_tokens) < 1:\\\\n\\\",\\n    \\\"        return False\\\\n\\\",\\n    \\\"    prev = prev_tokens[-1]\\\\n\\\",\\n    \\\"    if prev in _VAGUE_MARKERS:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if len(prev_tokens) >= 3 and prev_tokens[-3:] == [\\\\\\\"\u0441\\\\\\\", \\\\\\\"\u0447\u0435\u043c\\\\\\\", \\\\\\\"\u0442\u043e\\\\\\\"]:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\\\\\"\u0433\u0434\u0435\\\\\\\", \\\\\\\"\u0442\u043e\\\\\\\"]:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\\\\\"\u0441\\\\\\\", \\\\\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\\\\\"]:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    return False\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _match_root(word):\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    for root, val, mag, is_mult in _NUMERIC_ROOTS:\\\\n\\\",\\n    \\\"        idx = w.find(root)\\\\n\\\",\\n    \\\"        if idx == -1 or idx != 0:\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"        suffix = w[len(root):]\\\\n\\\",\\n    \\\"        if suffix in _INFLECTION_SUFFIXES:\\\\n\\\",\\n    \\\"            return val, mag, is_mult, suffix\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _classify_ordinal(word, val, mag, suffix):\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    if w in _NON_ORDINALS or w in NUMERAL_DICT:\\\\n\\\",\\n    \\\"        return None\\\\n\\\",\\n    \\\"    if suffix in _ORDINAL_SUFFIXES:\\\\n\\\",\\n    \\\"        return TokenClass(val, mag, \\\\\\\"ordinal\\\\\\\", word)\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _find_fused_compound(word):\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    for i in range(2, len(w)):\\\\n\\\",\\n    \\\"        p1, p2 = w[:i], w[i:]\\\\n\\\",\\n    \\\"        r1, r2 = _match_root(p1), _match_root(p2)\\\\n\\\",\\n    \\\"        if r1 and r2:\\\\n\\\",\\n    \\\"            v1, m1, mult1, _ = r1\\\\n\\\",\\n    \\\"            v2, m2, mult2, _ = r2\\\\n\\\",\\n    \\\"            if mult2 and m1 <= 3 and m2 >= 4:\\\\n\\\",\\n    \\\"                return [TokenClass(v1, m1, \\\\\\\"cardinal\\\\\\\", word),\\\\n\\\",\\n    \\\"                        TokenClass(v2, m2, \\\\\\\"multiplier\\\\\\\", word)]\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def classify(word, prev_tokens=None):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u041a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u0443\u0435\u0442 \u0441\u043b\u043e\u0432\u043e \u0432 TokenClass (\u0438\u043b\u0438 \u0441\u043f\u0438\u0441\u043e\u043a \u0434\u043b\u044f fused).\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if not word or len(word) < 2:\\\\n\\\",\\n    \\\"        return None\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 1. Vague context: \\\\\\\"\u0442\u044b\u0449\\\\\\\" \u043f\u043e\u0441\u043b\u0435 \\\\\\\"\u0432\u044b\u0448\u0435/\u043d\u0438\u0436\u0435/\u043e\u043a\u043e\u043b\u043e\\\\\\\"\\\\n\\\",\\n    \\\"    if w in (\\\\\\\"\u0442\u044b\u0449\\\\\\\", \\\\\\\"\u0442\u044b\u0449\u0430\\\\\\\") and prev_tokens and _is_vague_context(prev_tokens):\\\\n\\\",\\n    \\\"        return [TokenClass(1000, 4, \\\\\\\"vague\\\\\\\", word)]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 2. Exact dict match\\\\n\\\",\\n    \\\"    if w in NUMERAL_DICT:\\\\n\\\",\\n    \\\"        val, mag = NUMERAL_DICT[w]\\\\n\\\",\\n    \\\"        subtype = \\\\\\\"multiplier\\\\\\\" if w in _MULTIPLIER_SET else \\\\\\\"cardinal\\\\\\\"\\\\n\\\",\\n    \\\"        return [TokenClass(val, mag, subtype, word)]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 3. Ordinal exact match\\\\n\\\",\\n    \\\"    if w in ORDINAL_SET:\\\\n\\\",\\n    \\\"        return [TokenClass(int(ORDINALS[w]), 0, \\\\\\\"ordinal\\\\\\\", word)]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 4. ASR error correction\\\\n\\\",\\n    \\\"    if w in ASR_ERRORS:\\\\n\\\",\\n    \\\"        c = ASR_ERRORS[w]\\\\n\\\",\\n    \\\"        if c in NUMERAL_DICT:\\\\n\\\",\\n    \\\"            val, mag = NUMERAL_DICT[c]\\\\n\\\",\\n    \\\"            subtype = \\\\\\\"multiplier\\\\\\\" if c in _MULTIPLIER_SET else \\\\\\\"cardinal\\\\\\\"\\\\n\\\",\\n    \\\"            return [TokenClass(val, mag, subtype, word)]\\\\n\\\",\\n    \\\"        if c in ORDINAL_SET:\\\\n\\\",\\n    \\\"            return [TokenClass(int(ORDINALS[c]), 0, \\\\\\\"ordinal\\\\\\\", word)]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 5. Root-based regex\\\\n\\\",\\n    \\\"    match = _match_root(w)\\\\n\\\",\\n    \\\"    if match:\\\\n\\\",\\n    \\\"        val, mag, is_mult, suffix = match\\\\n\\\",\\n    \\\"        ord_result = _classify_ordinal(word, val, mag, suffix)\\\\n\\\",\\n    \\\"        if ord_result:\\\\n\\\",\\n    \\\"            return [ord_result]\\\\n\\\",\\n    \\\"        subtype = \\\\\\\"multiplier\\\\\\\" if is_mult else \\\\\\\"cardinal\\\\\\\"\\\\n\\\",\\n    \\\"        return [TokenClass(val, mag, subtype, word)]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # 6. Fused compound split\\\\n\\\",\\n    \\\"    fused = _find_fused_compound(word)\\\\n\\\",\\n    \\\"    if fused:\\\\n\\\",\\n    \\\"        return fused\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u0422\u0435\u0441\u0442\u044b \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u0430\\\\n\\\",\\n    \\\"test_cases = [\\\\n\\\",\\n    \\\"    ('\u043f\u044f\u0442\u044c', 5, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c', 12, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c', 30, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0441\u0442\u043e', 100, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0434\u0432\u0435\u0441\u0442\u0438', 200, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0442\u044b\u0441\u044f\u0447\u0430', 1000, 'multiplier'),\\\\n\\\",\\n    \\\"    ('\u043c\u0438\u043b\u043b\u0438\u043e\u043d', 1000000, 'multiplier'),\\\\n\\\",\\n    \\\"    ('\u043f\u044f\u0442\u044b\u0439', 5, 'ordinal'),\\\\n\\\",\\n    \\\"    ('\u0434\u0432\u043e\u0435', 2, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u043f\u044f\u0442\u044c\u0441\u043e\u0442', 500, 'cardinal'),\\\\n\\\",\\n    \\\"    ('\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c\u0447\u0435\u0442\u044b\u0440\u0435', 34, 'cardinal'),  # ASR fused\\\\n\\\",\\n    \\\"    ('\u0434\u0432\u0435\u0441\u0442\u0438\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442', 250, 'cardinal'),  # ASR fused\\\\n\\\",\\n    \\\"    ('\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440', None, None),\\\\n\\\",\\n    \\\"    ('\u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0430', None, None),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print('=== \u041a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f \u0442\u043e\u043a\u0435\u043d\u043e\u0432 ===')\\\\n\\\",\\n    \\\"passed = 0\\\\n\\\",\\n    \\\"for word, exp_val, exp_subtype in test_cases:\\\\n\\\",\\n    \\\"    result = classify(word)\\\\n\\\",\\n    \\\"    if exp_val is None:\\\\n\\\",\\n    \\\"        ok = result is None\\\\n\\\",\\n    \\\"        status = '\u2713' if ok else '\u2717'\\\\n\\\",\\n    \\\"        print(f'  {status} \\\\\\\"{word}\\\\\\\" \u2192 None (\u043d\u0435 \u0447\u0438\u0441\u043b\u043e)')\\\\n\\\",\\n    \\\"    else:\\\\n\\\",\\n    \\\"        if result and len(result) == 1:\\\\n\\\",\\n    \\\"            ok = result[0].value == exp_val and result[0].subtype == exp_subtype\\\\n\\\",\\n    \\\"        elif result and len(result) > 1:\\\\n\\\",\\n    \\\"            total = sum(t.value if t.subtype == 'cardinal' else t.value for t in result)\\\\n\\\",\\n    \\\"            for t in result:\\\\n\\\",\\n    \\\"                if t.subtype == 'multiplier':\\\\n\\\",\\n    \\\"                    total = result[0].value * result[1].value\\\\n\\\",\\n    \\\"                    break\\\\n\\\",\\n    \\\"            ok = total == exp_val\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            ok = False\\\\n\\\",\\n    \\\"        status = '\u2713' if ok else '\u2717'\\\\n\\\",\\n    \\\"        val_info = f'{result}' if result else 'None'\\\\n\\\",\\n    \\\"        print(f'  {status} \\\\\\\"{word}\\\\\\\" \u2192 {val_info}')\\\\n\\\",\\n    \\\"    if ok:\\\\n\\\",\\n    \\\"        passed += 1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f'\\\\\\\\n\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442: {passed}/{len(test_cases)} \u0442\u0435\u0441\u0442\u043e\u0432 \u043f\u0440\u043e\u0439\u0434\u0435\u043d\u043e')\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 4.3 TokenClass \u2014 \u0432\u0441\u0435 11 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0439\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u041a\u043b\u0430\u0441\u0441 | mag | \u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 | \u041f\u0440\u0438\u043c\u0435\u0440\u044b |\\\\n\\\",\\n    \\\"|-------|-----|----------|--------|\\\\n\\\",\\n    \\\"| `cardinal` | 0-6 | \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 | \u043f\u044f\u0442\u044c (0), \u0441\u0442\u043e (3), \u0442\u044b\u0441\u044f\u0447\u0430 (4) |\\\\n\\\",\\n    \\\"| `multiplier` | 4-6 | \u0423\u043c\u043d\u043e\u0436\u0438\u0442\u0435\u043b\u044c | \u0442\u044b\u0441\u044f\u0447\u0430, \u043c\u0438\u043b\u043b\u0438\u043e\u043d, \u043c\u0438\u043b\u043b\u0438\u0430\u0440\u0434 |\\\\n\\\",\\n    \\\"| `ordinal` | 0-6 | \u041f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u043e\u0435 | \u043f\u0435\u0440\u0432\u044b\u0439 (0), \u0441\u043e\u0442\u044b\u0439 (3) |\\\\n\\\",\\n    \\\"| `vague` | 4 | \u041d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u043e\u0435 | \u0442\u044b\u0449 (\u0440\u0430\u0437\u0433. \\\\\\\"\u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e\\\\\\\") |\\\\n\\\",\\n    \\\"| `fused` | \u2014 | \u0421\u043b\u0438\u0442\u043d\u043e\u0435 ASR \u2192 split | \u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 \u2192 [2, \u00d71000] |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**subtype** \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442 \u043f\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0430\u0440\u0441\u0435\u0440\u0435:\\\\n\\\",\\n    \\\"- `multiplier`: current \u00d7 value (\u043f\u044f\u0442\u044c \u00d7 \u0442\u044b\u0441\u044f\u0447 = 5000)\\\\n\\\",\\n    \\\"- `cardinal`: current + value \u0438\u043b\u0438 enum\\\\n\\\",\\n    \\\"- `ordinal`: \u0444\u0438\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u0443\u0435\u0442 \u0447\u0438\u0441\u043b\u043e \u0441 \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u043c \u0441\u0443\u0444\u0444\u0438\u043a\u0441\u043e\u043c\\\\n\\\",\\n    \\\"- `vague`: \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0435\u0442\u0441\u044f \u043f\u0430\u0440\u0441\u0435\u0440\u043e\u043c (\u043e\u0441\u0442\u0430\u0451\u0442\u0441\u044f \u043a\u0430\u043a \u0442\u0435\u043a\u0441\u0442)\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 5. Sequence Parser (\u043d\u043e\u0432\u044b\u0439 \u043f\u0443\u0442\u044c \u2014 state machine)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"State machine \u043d\u0430\u0434 `list[TokenClass]` \u0432\u043c\u0435\u0441\u0442\u043e \u0441\u0442\u0430\u0440\u043e\u0433\u043e `parse_number_group()`.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u041f\u043e\u043b\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f sequence parser\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _flush(compound, current, result, force=False):\\\\n\\\",\\n    \\\"    total = compound + current\\\\n\\\",\\n    \\\"    if total > 0 or force:\\\\n\\\",\\n    \\\"        result.append(str(total))\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def parse_sequence(classes):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    State machine over TokenClass list.\\\\n\\\",\\n    \\\"    \u0421\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u044f: START \u2192 ACCUM \u2192 MULTIPLY \u2192 ACCUM / ENUM \u2192 FLUSH\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if not classes:\\\\n\\\",\\n    \\\"        return []\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    compound = current = 0\\\\n\\\",\\n    \\\"    last_mag = last_mult_mag = -1\\\\n\\\",\\n    \\\"    has_zero = False\\\\n\\\",\\n    \\\"    result = []\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    for idx, tc in enumerate(classes):\\\\n\\\",\\n    \\\"        # Vague \u2192 \u043f\u0440\u043e\u043f\u0443\u0441\u043a\\\\n\\\",\\n    \\\"        if tc.subtype == \\\\\\\"vague\\\\\\\":\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        if tc.value == 0:\\\\n\\\",\\n    \\\"            has_zero = True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        # Multiplier: \u0443\u043c\u043d\u043e\u0436\u0435\u043d\u0438\u0435\\\\n\\\",\\n    \\\"        if tc.subtype == \\\\\\\"multiplier\\\\\\\":\\\\n\\\",\\n    \\\"            if last_mult_mag == tc.mag:\\\\n\\\",\\n    \\\"                # \u0414\u0432\u0430 multiplier \u043e\u0434\u043d\u043e\u0433\u043e \u0440\u0430\u043d\u0433\u0430 \u2192 enum\\\\n\\\",\\n    \\\"                _flush(compound, 0, result, force=has_zero)\\\\n\\\",\\n    \\\"                compound = current * tc.value if current > 0 else tc.value\\\\n\\\",\\n    \\\"                current = 0\\\\n\\\",\\n    \\\"            else:\\\\n\\\",\\n    \\\"                multiplied = current * tc.value if current > 0 else tc.value\\\\n\\\",\\n    \\\"                compound += multiplied\\\\n\\\",\\n    \\\"                current = 0\\\\n\\\",\\n    \\\"            last_mult_mag, last_mag = tc.mag, -1\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        # Non-multiplier (cardinal/ordinal)\\\\n\\\",\\n    \\\"        if last_mag == -1:\\\\n\\\",\\n    \\\"            current, last_mag = tc.value, tc.mag\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        if tc.mag < last_mag:\\\\n\\\",\\n    \\\"            # \u041f\u043e\u043d\u0438\u0436\u0435\u043d\u0438\u0435 mag \u2192 \u0441\u0443\u043c\u043c\u0430 (\\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\" = 200+50=250)\\\\n\\\",\\n    \\\"            # \u041d\u043e \u0435\u0441\u043b\u0438 mag <= 1 \u0438 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0439 \u0442\u043e\u0436\u0435 mag <= 1 \u2192 enum\\\\n\\\",\\n    \\\"            if tc.mag <= 1 and idx < len(classes) - 1:\\\\n\\\",\\n    \\\"                nxt = classes[idx + 1]\\\\n\\\",\\n    \\\"                if nxt.subtype not in (\\\\\\\"multiplier\\\\\\\", \\\\\\\"vague\\\\\\\", \\\\\\\"ordinal\\\\\\\") and nxt.mag <= 1:\\\\n\\\",\\n    \\\"                    _flush(compound, current, result, force=has_zero)\\\\n\\\",\\n    \\\"                    compound, current = 0, tc.value\\\\n\\\",\\n    \\\"                    last_mag, last_mult_mag = tc.mag, -1\\\\n\\\",\\n    \\\"                    continue\\\\n\\\",\\n    \\\"            current += tc.value\\\\n\\\",\\n    \\\"            last_mag = tc.mag\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            # \u0420\u0430\u0432\u043d\u044b\u0439 \u0438\u043b\u0438 \u043f\u043e\u0432\u044b\u0448\u0430\u044e\u0449\u0438\u0439\u0441\u044f mag \u2192 enum\\\\n\\\",\\n    \\\"            _flush(compound, current, result, force=has_zero)\\\\n\\\",\\n    \\\"            compound, current = 0, tc.value\\\\n\\\",\\n    \\\"            last_mag, last_mult_mag = tc.mag, -1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    _flush(compound, current, result, force=has_zero)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if not result and has_zero:\\\\n\\\",\\n    \\\"        return [\\\\\\\"0\\\\\\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return result\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"Sequence parser loaded\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  parse_sequence([]) = {parse_sequence([])}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  parse_sequence([TC(0)]) = {parse_sequence([TokenClass(0,0,'cardinal','\u0442\u0435\u0441\u0442')])}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 5.1 \u041f\u0440\u0430\u0432\u0438\u043b\u0430 state machine\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u0422\u0435\u043a\u0443\u0449\u0438\u0439 vs \u041f\u0440\u0435\u0434\u044b\u0434\u0443\u0449\u0438\u0439 | \u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 | \u041f\u0440\u0438\u043c\u0435\u0440 |\\\\n\\\",\\n    \\\"|---|---|---|\\\\n\\\",\\n    \\\"| subtype=vague | \u041f\u0440\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u044c (\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0442\u0435\u043a\u0441\u0442) | \\\\\\\"\u043e\u043a\u043e\u043b\u043e \u0442\u044b\u0449\\\\\\\" \u2192 vague |\\\\n\\\",\\n    \\\"| subtype=multiplier | compound += current \u00d7 val | \\\\\\\"\u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447\\\\\\\" \u2192 5\u00d71000 |\\\\n\\\",\\n    \\\"| mag < prev_mag | \u0421\u0443\u043c\u043c\u0430: current += val | \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\" \u2192 200+50 |\\\\n\\\",\\n    \\\"| mag == prev_mag (\u043e\u0431\u0430 < 3) | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: flush, new | \\\\\\\"\u043f\u044f\u0442\u044c \u0448\u0435\u0441\u0442\u044c\\\\\\\" \u2192 5 6 |\\\\n\\\",\\n    \\\"| mag >= prev_mag | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: flush, new | \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\" \u2192 200 300 |\\\\n\\\",\\n    \\\"| same mult_mag | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 | \\\\\\\"7 \u043c\u043b\u043d 2 \u043c\u043b\u043d\\\\\\\" \u2192 7e6 2e6 |\\\\n\\\",\\n    \\\"| ordinal | \u0424\u0438\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c | \\\\\\\"285-\u0439\\\\\\\" \u2192 \\\\\\\"285\\\\\\\" |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u041a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u043e\u0442\u043b\u0438\u0447\u0438\u0435 \u043e\u0442 legacy:** \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0441 \u044f\u0432\u043d\u044b\u043c\u0438 \u0441\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u044f\u043c\u0438,\\\\n\\\",\\n    \\\"\u0431\u0435\u0437 \u0440\u0435\u043a\u0443\u0440\u0441\u0438\u0438 \u0438 \u0441 \u0447\u0451\u0442\u043a\u0438\u043c \u0440\u0430\u0437\u0434\u0435\u043b\u0435\u043d\u0438\u0435\u043c sum/enum.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 6. Legacy Parser (\u0441\u0442\u0430\u0440\u044b\u0439 \u043f\u0443\u0442\u044c \u2014 mag-based)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"Mag-based \u043f\u0430\u0440\u0441\u0435\u0440: \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u0435\u0442 \u0441\u0443\u043c\u043c\u0443 \u0438 \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 \u043f\u043e \u0440\u0430\u0437\u0440\u044f\u0434\u0430\u043c (mag) \u0441\u043e\u0441\u0435\u0434\u043d\u0438\u0445 \u0441\u043b\u043e\u0432.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# Legacy lookup \u0438 \u043f\u0430\u0440\u0441\u0435\u0440\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def lookup_word(word):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u041f\u043e\u0438\u0441\u043a \u0441\u043b\u043e\u0432\u0430 \u0432 \u0441\u043b\u043e\u0432\u0430\u0440\u044f\u0445 + ASR + root-based fallback.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    if w in NUMERAL_DICT:\\\\n\\\",\\n    \\\"        val, mag = NUMERAL_DICT[w]\\\\n\\\",\\n    \\\"        return (val, mag, w in MULTIPLIERS)\\\\n\\\",\\n    \\\"    if w in ASR_ERRORS:\\\\n\\\",\\n    \\\"        c = ASR_ERRORS[w]\\\\n\\\",\\n    \\\"        if c in NUMERAL_DICT:\\\\n\\\",\\n    \\\"            val, mag = NUMERAL_DICT[c]\\\\n\\\",\\n    \\\"            return (val, mag, c in MULTIPLIERS)\\\\n\\\",\\n    \\\"    # Fallback to root-based\\\\n\\\",\\n    \\\"    r = classify(word)\\\\n\\\",\\n    \\\"    if r and not any(t.subtype == \\\\\\\"vague\\\\\\\" for t in r):\\\\n\\\",\\n    \\\"        tc = r[0]\\\\n\\\",\\n    \\\"        return (tc.value, tc.mag, tc.subtype == \\\\\\\"multiplier\\\\\\\")\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def is_ordinal_word(word):\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    if w in ORDINAL_SET:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if w in NUMERAL_DICT or w in ASR_ERRORS:\\\\n\\\",\\n    \\\"        return False\\\\n\\\",\\n    \\\"    r = classify(word)\\\\n\\\",\\n    \\\"    return r and r[0].subtype == \\\\\\\"ordinal\\\\\\\" if r else False\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def ordinal_value(word):\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"    if w in ORDINALS:\\\\n\\\",\\n    \\\"        return ORDINALS[w]\\\\n\\\",\\n    \\\"    if w in NUMERAL_DICT or w in ASR_ERRORS:\\\\n\\\",\\n    \\\"        return None\\\\n\\\",\\n    \\\"    r = classify(word)\\\\n\\\",\\n    \\\"    return str(r[0].value) if r and r[0].subtype == \\\\\\\"ordinal\\\\\\\" else None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def parse_number_group(tokens_data):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Mag-based \u043f\u0430\u0440\u0441\u0435\u0440 \u0447\u0438\u0441\u043b\u043e\u0432\u043e\u0439 \u0433\u0440\u0443\u043f\u043f\u044b.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if not tokens_data:\\\\n\\\",\\n    \\\"        return []\\\\n\\\",\\n    \\\"    single_mult = len(tokens_data) == 1 and tokens_data[0][2]\\\\n\\\",\\n    \\\"    compound = current = 0\\\\n\\\",\\n    \\\"    last_mag = last_mult_mag = -1\\\\n\\\",\\n    \\\"    result = []\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    for j, (val, mag, is_mult, _) in enumerate(tokens_data):\\\\n\\\",\\n    \\\"        if is_mult:\\\\n\\\",\\n    \\\"            if last_mult_mag == mag:\\\\n\\\",\\n    \\\"                result.append(str(int(compound)))\\\\n\\\",\\n    \\\"                compound = current * val if current > 0 else val\\\\n\\\",\\n    \\\"                current = 0\\\\n\\\",\\n    \\\"            else:\\\\n\\\",\\n    \\\"                multiplied = current * val if current > 0 else val\\\\n\\\",\\n    \\\"                compound += multiplied\\\\n\\\",\\n    \\\"                current = 0\\\\n\\\",\\n    \\\"            last_mult_mag, last_mag = mag, -1\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            if last_mag == -1:\\\\n\\\",\\n    \\\"                current, last_mag = val, mag\\\\n\\\",\\n    \\\"            elif mag < last_mag:\\\\n\\\",\\n    \\\"                # \u041f\u043e\u043d\u0438\u0436\u0435\u043d\u0438\u0435 mag \u2192 \u0441\u0443\u043c\u043c\u0430\\\\n\\\",\\n    \\\"                if mag <= 1 and j + 1 < len(tokens_data) and tokens_data[j + 1][1] == mag:\\\\n\\\",\\n    \\\"                    result.append(str(int(compound + current)))\\\\n\\\",\\n    \\\"                    compound, current = 0, val\\\\n\\\",\\n    \\\"                    last_mag, last_mult_mag = mag, -1\\\\n\\\",\\n    \\\"                else:\\\\n\\\",\\n    \\\"                    current += val\\\\n\\\",\\n    \\\"                    last_mag = mag\\\\n\\\",\\n    \\\"            else:\\\\n\\\",\\n    \\\"                result.append(str(int(compound + current)))\\\\n\\\",\\n    \\\"                compound, current = 0, val\\\\n\\\",\\n    \\\"                last_mag, last_mult_mag = mag, -1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if single_mult:\\\\n\\\",\\n    \\\"        v = tokens_data[0][0]\\\\n\\\",\\n    \\\"        return [str(int(v))] if v in (1000, 1000000, 1000000000) else []\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    t = compound + current\\\\n\\\",\\n    \\\"    if t > 0 or any(td[0] == 0 for td in tokens_data):\\\\n\\\",\\n    \\\"        result.append(str(int(t)))\\\\n\\\",\\n    \\\"    return result\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"Legacy parser loaded\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  parse_number_group([]) = {parse_number_group([])}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  lookup_word('\u043f\u044f\u0442\u044c') = {lookup_word('\u043f\u044f\u0442\u044c')}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  lookup_word('\u0434\u0432\u0435\u0441\u0438') = {lookup_word('\u0434\u0432\u0435\u0441\u0438')}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"  lookup_word('\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440') = {lookup_word('\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440')}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 6.1 \u0420\u0430\u0437\u043b\u0438\u0447\u0438\u044f \u043f\u0430\u0440\u0441\u0435\u0440\u043e\u0432\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u0425\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0430 | Legacy (`parser.py`) | Sequence (`sequence_parser.py`) |\\\\n\\\",\\n    \\\"|---|---|---|\\\\n\\\",\\n    \\\"| \u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 | Tuple-based (val, mag, is_mult, is_ord) | TokenClass dataclass |\\\\n\\\",\\n    \\\"| \u041a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f | lookup_word() ad-hoc | classify() multi-stage |\\\\n\\\",\\n    \\\"| \u0421\u0443\u043c\u043c\u0430/enum | \u0415\u0434\u0438\u043d\u044b\u0439 mag-pass | State machine \u0441 explicit flush |\\\\n\\\",\\n    \\\"| Vague | \u041d\u0435\u0442 | \u0415\u0441\u0442\u044c (\u043f\u0440\u043e\u043f\u0443\u0441\u043a) |\\\\n\\\",\\n    \\\"| Fused | \u041d\u0435\u0442 | \u0415\u0441\u0442\u044c (split + classify) |\\\\n\\\",\\n    \\\"| \u041f\u043e\u043a\u0440\u044b\u0442\u0438\u0435 | 137 \u0444\u043e\u0440\u043c dict | ~200 \u0444\u043e\u0440\u043c dict + roots + ordinals |\\\\n\\\",\\n    \\\"| \u041e\u043c\u043e\u043d\u0438\u043c\u044b | Heuristic sto-patterns | + pymorphy2 disambiguator |\\\\n\\\",\\n    \\\"| \u0422\u0435\u0441\u0442\u044b | 9 \u0442\u0435\u0441\u0442\u043e\u0432 | ~25 \u0442\u0435\u0441\u0442\u043e\u0432 |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u0421\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u043c\u043e\u0441\u0442\u044c:** 99.8% \u043d\u0430 calibration.f (\u043e\u0431\u0430 \u043f\u0443\u0442\u0438 \u0434\u0430\u044e\u0442 \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u0439 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442).\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 7. ASR-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0414\u0432\u0443\u0445\u0443\u0440\u043e\u0432\u043d\u0435\u0432\u0430\u044f \u0441\u0438\u0441\u0442\u0435\u043c\u0430 \u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u0438 ASR-\u043e\u0448\u0438\u0431\u043e\u043a \u0434\u043e \u0442\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u0438.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"import re\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u2500\u2500 \u0423\u0440\u043e\u0432\u0435\u043d\u044c 1: Regex-\u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"_HUNDRED_TO_TEN = {\\\\n\\\",\\n    \\\"    \\\\\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\": \\\\\\\"\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c\\\\\\\", \\\\\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\\\\\": \\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\": \\\\\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", \\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442\\\\\\\": \\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\\\\\": \\\\\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", \\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\\\\\": \\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\", \\\\\\\"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\": \\\\\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\\\\\"\\\\n\\\",\\n    \\\"}\\\\n\\\",\\n    \\\"_TEN_TO_UNIT = {\\\\n\\\",\\n    \\\"    \\\\\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\": \\\\\\\"\u043f\u044f\u0442\u044c\\\\\\\", \\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\": \\\\\\\"\u0448\u0435\u0441\u0442\u044c\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\": \\\\\\\"\u0441\u0435\u043c\u044c\\\\\\\", \\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\": \\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\\\\\\\", \\\\\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\\\\\": \\\\\\\"\u0434\u0435\u0432\u044f\u0442\u044c\\\\\\\"\\\\n\\\",\\n    \\\"}\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _asr_preprocess(text):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    \u041f\u0440\u0435\u0434\u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 ASR-\u043e\u0448\u0438\u0431\u043e\u043a \u043f\u0435\u0440\u0435\u0434 \u0442\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u0435\u0439.\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    1. \\\\\\\"\u0434\u0432\u0435\u0441\u0438 \u0442\u0440\u0438\u0441\u0442\u0430 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0442\u044b\u0441\u044f\u0447\\\\\\\" \u2192 \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c \u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447\\\\\\\" (235000)\\\\n\\\",\\n    \\\"       \u2014 \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432: \\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\" + \u0441\u043e\u0442\u043d\u044f \u2192 \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\\\\\" + \u0434\u0435\u0441\u044f\u0442\u043a\u0438\\\\n\\\",\\n    \\\"    2. \u041f\u0440\u043e\u043f\u0443\u0449\u0435\u043d\u043d\u044b\u0439 \u043c\u044f\u0433\u043a\u0438\u0439 \u0437\u043d\u0430\u043a: \u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442 \u2192 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\n\\\",\\n    \\\"    3. \u041f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u043e\u0448\u0438\u0431\u043a\u0438: \u0442\u0440\u0438\u0441\u0442\u043e \u2192 \u0442\u0440\u0438\u0441\u0442\u0430\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    # Rule 1: \\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\" \u2192 \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432\\\\n\\\",\\n    \\\"    pattern = (\\\\n\\\",\\n    \\\"        r\\\\\\\"\\\\\\\\b\u0434\u0432\u0435\u0441\u0438\\\\\\\\s+(\u0442\u0440\u0438\u0441\u0442\u0430|\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430|\u043f\u044f\u0442\u044c\u0441\u043e\u0442|\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442|\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442)\\\\\\\"\\\\n\\\",\\n    \\\"        r\\\\\\\"(?:\\\\\\\\s+(\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442))?\\\\\\\\s+\u0442\u044b\u0441\u044f\u0447[\u0430\u0438]?\\\\\\\\b\\\\\\\"\\\\n\\\",\\n    \\\"    )\\\\n\\\",\\n    \\\"    def _fix_dvesi(m):\\\\n\\\",\\n    \\\"        parts = [\\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\\\\\", _HUNDRED_TO_TEN.get(m.group(1), m.group(1))]\\\\n\\\",\\n    \\\"        if m.group(2) in _TEN_TO_UNIT:\\\\n\\\",\\n    \\\"            parts.append(_TEN_TO_UNIT[m.group(2)])\\\\n\\\",\\n    \\\"        parts.append(\\\\\\\"\u0442\u044b\u0441\u044f\u0447\\\\\\\")\\\\n\\\",\\n    \\\"        return \\\\\\\" \\\\\\\".join(parts)\\\\n\\\",\\n    \\\"    text = re.sub(pattern, _fix_dvesi, text)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # Rule 2: \u041f\u0440\u043e\u043f\u0443\u0449\u0435\u043d\u043d\u044b\u0439 \u043c\u044f\u0433\u043a\u0438\u0439 \u0437\u043d\u0430\u043a\\\\n\\\",\\n    \\\"    for p, r in [\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442\\\\\\\\b\\\\\\\", \\\\\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\"),\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u0448\u0435\u0441\u0442\u0434\u0435\u0441\u044f\u0442\\\\\\\\b\\\\\\\", \\\\\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\"),\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\\\\\b\\\\\\\", \\\\\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\"),\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u0432\u043e\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\\\\\b\\\\\\\", \\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\"),\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u0442\u0440\u0438\u0441\u0442\u043e\\\\\\\\b\\\\\\\", \\\\\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\"),\\\\n\\\",\\n    \\\"        (r\\\\\\\"\\\\\\\\b\u0447\u0435\u0442\u044b\u0440\u0438\u0441\u0442\u0430\\\\\\\\b\\\\\\\", \\\\\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\\\\\"),\\\\n\\\",\\n    \\\"    ]:\\\\n\\\",\\n    \\\"        text = re.sub(p, r, text)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return text\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u2500\u2500 \u0423\u0440\u043e\u0432\u0435\u043d\u044c 2: \u0421\u043b\u043e\u0432\u0430\u0440\u044c ASR_ERRORS (42 \u0437\u0430\u043f\u0438\u0441\u0438) \u2500\u2500\\\\n\\\",\\n    \\\"# (\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d \u0432\u044b\u0448\u0435 \u0432 \u0440\u0430\u0437\u0434\u0435\u043b\u0435 3)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=== ASR \u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433 ===\\\\\\\")\\\\n\\\",\\n    \\\"test_asr = [\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u0432\u0435\u0441\u0438 \u043f\u044f\u0442\u044c\u0441\u043e\u0442 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c \u0442\u044b\u0441\u044f\u0447 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0442\u0440\u0438\u0441\u0442\u043e \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u0431\u044b\u0447\u043d\u044b\u0439 \u0442\u0435\u043a\u0441\u0442 \u0431\u0435\u0437 \u043e\u0448\u0438\u0431\u043e\u043a\\\\\\\",\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"for t in test_asr:\\\\n\\\",\\n    \\\"    print(f'  IN:  {t}')\\\\n\\\",\\n    \\\"    print(f'  OUT: {_asr_preprocess(t)}')\\\\n\\\",\\n    \\\"    print()\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 7.1 \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0439 ASR-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433\u0430\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u0424\u0430\u0437\u0430 | \u0427\u0442\u043e \u0441\u0434\u0435\u043b\u0430\u043d\u043e | \u0412\u043b\u0438\u044f\u043d\u0438\u0435 |\\\\n\\\",\\n    \\\"|---|---|---|\\\\n\\\",\\n    \\\"| 1 | \u0411\u0430\u0437\u043e\u0432\u044b\u0439 regex: \u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442\u2192\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 | +1 \u043f\u0440\u0430\u0432\u043a\u0430 |\\\\n\\\",\\n    \\\"| 2 | \\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\" \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432 (300\u219230, 500\u219250) | +1 \u043f\u0440\u0430\u0432\u043a\u0430 (99.6%\u219299.8%) |\\\\n\\\",\\n    \\\"| 3 | ASR_ERRORS \u0441\u043b\u043e\u0432\u0430\u0440\u044c (42 \u0437\u0430\u043f\u0438\u0441\u0438) | ~5 \u043f\u0440\u0430\u0432\u043e\u043a |\\\\n\\\",\\n    \\\"| 4 | Fused compound split \u0432 classify() | ~3 \u043f\u0440\u0430\u0432\u043a\u0438 |\\\\n\\\",\\n    \\\"| 5 | \u0451-\u0444\u043e\u0440\u043c\u044b \u0432 ORDINALS | 11 \u0444\u043e\u0440\u043c |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u0414\u043e\u0441\u0442\u0438\u0433\u043d\u0443\u0442\u044b\u0439 \u044d\u0444\u0444\u0435\u043a\u0442:** 97.6% \u2192 99.8% \u043d\u0430 calibration.f (11 \u0438\u0437 12 \u043e\u0448\u0438\u0431\u043e\u043a \u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b).\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 8. \u0414\u0438\u0437\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f (\u043c\u043e\u0434\u0443\u043b\u044c disambiguate.py)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u0447\u0430\u0441\u0442\u0438 \u0440\u0435\u0447\u0438 \u0434\u043b\u044f \u0441\u043b\u043e\u0432-\u043e\u043c\u043e\u043d\u0438\u043c\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043c\u043e\u0433\u0443\u0442 \u0431\u044b\u0442\u044c \u043a\u0430\u043a \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c\u0438,\\\\n\\\",\\n    \\\"\u0442\u0430\u043a \u0438 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0447\u0430\u0441\u0442\u044f\u043c\u0438 \u0440\u0435\u0447\u0438. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 pymorphy2 + \u044d\u0432\u0440\u0438\u0441\u0442\u0438\u043a\u0438.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u041f\u043e\u043b\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f disambiguate.py\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u2500\u2500 \u041f\u0430\u0442\u0442\u0435\u0440\u043d\u044b \u0434\u043b\u044f \u043e\u043c\u043e\u043d\u0438\u043c\u043e\u0432 \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \\\\\\\"\u0441\u0442\u043e\\\\\\\" \u2014 100 (\u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435) vs \\\\\\\"\u0441\u0442\u043e\u044f\u0442\u044c\\\\\\\" (\u0433\u043b\u0430\u0433\u043e\u043b)\\\\n\\\",\\n    \\\"_STO_VERB_PATTERNS = [\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u044f\\\\\\\\s+\u0441\u0442\u043e\\\\\\\\b\\\\\\\", False),  # \\\\\\\"\u044f \u0441\u0442\u043e\\\\\\\" \u2192 verb\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0441\u0442\u043e\\\\\\\\s+(\u043d\u0430|\u0432|\u0443|\u0437\u0430|\u043f\u0435\u0440\u0435\u0434)\\\\\\\\b\\\\\\\", False),  # \\\\\\\"\u0441\u0442\u043e \u043d\u0430\\\\\\\" \u2192 verb\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0441\u0442\u043e\\\\\\\\s+\u0438\\\\\\\\s+\\\\\\\", False),  # \\\\\\\"\u0441\u0442\u043e \u0438\\\\\\\" \u2192 verb listing\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"_STO_NUMERAL_PATTERNS = [\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0441\u0442\u043e\\\\\\\\s+(\u0440\u0443\u0431\u043b|\u0434\u043e\u043b\u043b\u0430\u0440|\u0435\u0432\u0440\u043e|\u0442\u044b\u0441\u044f\u0447|\u043c\u0438\u043b\u043b\u0438\u043e\u043d|\u043f\u0440\u043e\u0446\u0435\u043d\u0442|\u0440\u0430\u0437|\u0447\u0435\u043b\u043e\u0432\u0435\u043a|\u0448\u0442\u0443\u043a)\\\\\\\", True),\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b(\u0434\u043e|\u043e\u043a\u043e\u043b\u043e|\u0431\u043e\u043b\u0435\u0435|\u043c\u0435\u043d\u0435\u0435|\u0441\u0432\u044b\u0448\u0435|\u043f\u043e\u0447\u0442\u0438)\\\\\\\\s+\u0441\u0442\u043e\\\\\\\\b\\\\\\\", True),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \\\\\\\"\u0442\u0440\u0438\\\\\\\" \u2014 3 vs \\\\\\\"\u0442\u0435\u0440\u0435\u0442\u044c\\\\\\\" (\u0433\u043b\u0430\u0433\u043e\u043b)\\\\n\\\",\\n    \\\"_TRI_VERB_PATTERNS = [\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0442\u0440\u0438\\\\\\\\s+\u0441\u044f\\\\\\\\b\\\\\\\", False),\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0442\u0440\u0438\\\\\\\\s+\u0442\u0435\\\\\\\\b\\\\\\\", False),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\" \u2014 40 vs \\\\\\\"\u0441\u043e\u0440\u043e\u043a\u0430\\\\\\\" (\u043f\u0442\u0438\u0446\u0430)\\\\n\\\",\\n    \\\"_SOROK_NOUN_PATTERNS = [\\\\n\\\",\\n    \\\"    (r\\\\\\\"\\\\\\\\b\u0441\u043e\u0440\u043e\u043a\\\\\\\\s+(\u043b\u0435\u0442\u0438\u0442|\u043f\u0442\u0438\u0446|\u0441\u0438\u043d\u0438\u0446|\u0432\u043e\u0440\u043e\u0431)\\\\\\\", False),\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _context_match(text, patterns):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u041f\u0440\u043e\u0432\u0435\u0440\u0438\u0442\u044c \u0442\u0435\u043a\u0441\u0442 \u043d\u0430 \u0441\u043e\u0432\u043f\u0430\u0434\u0435\u043d\u0438\u0435 \u0441 \u043f\u0430\u0442\u0442\u0435\u0440\u043d\u0430\u043c\u0438.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    for pattern, is_num in patterns:\\\\n\\\",\\n    \\\"        if re.search(pattern, text):\\\\n\\\",\\n    \\\"            return is_num\\\\n\\\",\\n    \\\"    return None\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _pymorphy_check(text, word, pos):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 pymorphy2 \u0434\u043b\u044f POS-\u0442\u0435\u0433\u0433\u0438\u043d\u0433\u0430.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    import collections, inspect\\\\n\\\",\\n    \\\"    if not hasattr(inspect, \\\\\\\"getargspec\\\\\\\"):\\\\n\\\",\\n    \\\"        ArgSpec = collections.namedtuple(\\\\n\\\",\\n    \\\"            \\\\\\\"ArgSpec\\\\\\\", [\\\\\\\"args\\\\\\\", \\\\\\\"varargs\\\\\\\", \\\\\\\"keywords\\\\\\\", \\\\\\\"defaults\\\\\\\"])\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        def getargspec(func):\\\\n\\\",\\n    \\\"            spec = inspect.getfullargspec(func)\\\\n\\\",\\n    \\\"            return ArgSpec(spec.args, spec.varargs, spec.keywords, spec.defaults)\\\\n\\\",\\n    \\\"        inspect.getargspec = getargspec\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    import pymorphy2\\\\n\\\",\\n    \\\"    try:\\\\n\\\",\\n    \\\"        morph = pymorphy2.MorphAnalyzer()\\\\n\\\",\\n    \\\"    except Exception:\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    parses = morph.parse(word.lower())\\\\n\\\",\\n    \\\"    has_numr = any(\\\\\\\"NUMR\\\\\\\" in str(p.tag) for p in parses)\\\\n\\\",\\n    \\\"    has_non_numr = any(\\\\\\\"NUMR\\\\\\\" not in str(p.tag) and p.score > 0.1 for p in parses)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if has_numr and not has_non_numr:\\\\n\\\",\\n    \\\"        return True  # \u0442\u043e\u043b\u044c\u043a\u043e \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435\\\\n\\\",\\n    \\\"    if not has_numr and has_non_numr:\\\\n\\\",\\n    \\\"        return False  # \u043d\u0435 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435\\\\n\\\",\\n    \\\"    return None  # \u0430\u043c\u0431\u0438\u0432\u0430\u043b\u0435\u043d\u0442\u043d\u043e\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def is_likely_numeric(text, word, pos):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    \u041e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043b\u0438 \u0441\u043b\u043e\u0432\u043e \u0432 \u0434\u0430\u043d\u043d\u043e\u043c \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0435 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u043c.\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    Args:\\\\n\\\",\\n    \\\"        text: \u041f\u043e\u043b\u043d\u044b\u0439 \u0438\u0441\u0445\u043e\u0434\u043d\u044b\u0439 \u0442\u0435\u043a\u0441\u0442\\\\n\\\",\\n    \\\"        word: \u0421\u043b\u043e\u0432\u043e \u0434\u043b\u044f \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0438\\\\n\\\",\\n    \\\"        pos: \u041f\u043e\u0437\u0438\u0446\u0438\u044f \u0432 \u0442\u043e\u043a\u0435\u043d\u0430\u0445\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    Returns:\\\\n\\\",\\n    \\\"        True \u0435\u0441\u043b\u0438 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435, False \u0435\u0441\u043b\u0438 \u043d\u0435\u0442\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    w = word.lower()\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if w == \\\\\\\"\u0441\u0442\u043e\\\\\\\":\\\\n\\\",\\n    \\\"        result = _context_match(text, _STO_NUMERAL_PATTERNS + _STO_VERB_PATTERNS)\\\\n\\\",\\n    \\\"        if result is not None:\\\\n\\\",\\n    \\\"            return result\\\\n\\\",\\n    \\\"        try:\\\\n\\\",\\n    \\\"            pm = _pymorphy_check(text, word, pos)\\\\n\\\",\\n    \\\"            if pm is not None:\\\\n\\\",\\n    \\\"                return pm\\\\n\\\",\\n    \\\"        except Exception:\\\\n\\\",\\n    \\\"            pass\\\\n\\\",\\n    \\\"        return True  # \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e \u2014 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if w == \\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\":\\\\n\\\",\\n    \\\"        result = _context_match(text, _SOROK_NOUN_PATTERNS)\\\\n\\\",\\n    \\\"        if result is not None:\\\\n\\\",\\n    \\\"            return result\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    if w in (\\\\\\\"\u0442\u0440\u0438\\\\\\\", \\\\\\\"\u0442\u0440\u0443\\\\\\\"):\\\\n\\\",\\n    \\\"        result = _context_match(text, _TRI_VERB_PATTERNS)\\\\n\\\",\\n    \\\"        if result is not None:\\\\n\\\",\\n    \\\"            return result\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=== \u0414\u0438\u0437\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f ===\\\\\\\")\\\\n\\\",\\n    \\\"test_disambig = [\\\\n\\\",\\n    \\\"    (\\\\\\\"\u041d\u0430 \u0441\u0442\u043e\u043b\u0435 \u0441\u0442\u043e \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\", \\\\\\\"\u0441\u0442\u043e\\\\\\\"),        # 100\\\\n\\\",\\n    \\\"    (\\\\\\\"\u042f \u0441\u0442\u043e \u0443 \u043e\u043a\u043d\u0430\\\\\\\", \\\\\\\"\u0441\u0442\u043e\\\\\\\"),              # \u0433\u043b\u0430\u0433\u043e\u043b\\\\n\\\",\\n    \\\"    (\\\\\\\"\u041e\u043d \u043a\u0443\u043f\u0438\u043b \u0442\u0440\u0438 \u043a\u043d\u0438\u0433\u0438\\\\\\\", \\\\\\\"\u0442\u0440\u0438\\\\\\\"),         # 3\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0415\u0439 \u0441\u043e\u0440\u043e\u043a \u043b\u0435\u0442\\\\\\\", \\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\"),             # 40\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0421\u043e\u0440\u043e\u043a\u0430 \u043b\u0435\u0442\u0438\u0442 \u0432\u044b\u0441\u043e\u043a\u043e\\\\\\\", \\\\\\\"\u0441\u043e\u0440\u043e\u043a\\\\\\\"),      # \u043f\u0442\u0438\u0446\u0430 (False)\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0414\u043e \u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\", \\\\\\\"\u0441\u0442\u043e\\\\\\\"),              # 100 (\u043f\u0440\u0435\u0434\u043b\u043e\u0433 \\\\\\\"\u0434\u043e\\\\\\\")\\\\n\\\",\\n    \\\"    (\\\\\\\"\u042f \u0441\u0442\u043e\u044e \u0438 \u0441\u043c\u043e\u0442\u0440\u044e\\\\\\\", \\\\\\\"\u0441\u0442\u043e\\\\\\\"),            # \u0433\u043b\u0430\u0433\u043e\u043b (no exact match, default True)\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"for text, word in test_disambig:\\\\n\\\",\\n    \\\"    result = is_likely_numeric(text, word, 0)\\\\n\\\",\\n    \\\"    status = '\u0427\u0418\u0421\u041b' if result else '\u041d\u0415_\u0427\u0418\u0421\u041b'\\\\n\\\",\\n    \\\"    print(f'  {status:8s} | {text}')\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 8.1 \u0422\u0438\u043f\u044b \u0434\u0438\u0437\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u0438\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u041e\u043c\u043e\u043d\u0438\u043c | \u0412\u0430\u0440\u0438\u0430\u043d\u0442\u044b | \u041f\u0440\u0438\u0437\u043d\u0430\u043a | \u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 |\\\\n\\\",\\n    \\\"|--------|----------|---------|----------|\\\\n\\\",\\n    \\\"| **\u0441\u0442\u043e** | 100 / \u0433\u043b\u0430\u0433\u043e\u043b \\\\\\\"\u0441\u0442\u043e\u044f\u0442\u044c\\\\\\\" | \u041f\u043e\u0441\u043b\u0435 \\\\\\\"\u044f\\\\\\\", \u043f\u0440\u0435\u0434 \\\\\\\"\u043d\u0430/\u0432/\u0443\\\\\\\" \u2192 \u0433\u043b\u0430\u0433\u043e\u043b | \u041a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0439 regex |\\\\n\\\",\\n    \\\"| **\u0441\u0442\u043e** | / \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 | \u041f\u0435\u0440\u0435\u0434 \u0440\u0443\u0431\u043b/\u0434\u043e\u043b\u043b\u0430\u0440/\u0442\u044b\u0441\u044f\u0447 \u2192 \u0447\u0438\u0441\u043b\u043e | \u041a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0439 regex |\\\\n\\\",\\n    \\\"| **\u0441\u0442\u043e** | \u0430\u043c\u0431\u0438\u0432\u0430\u043b\u0435\u043d\u0442\u043d\u043e | \u041d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u043e \u2192 pymorphy2 | POS-\u0442\u0435\u0433\u0433\u0438\u043d\u0433 |\\\\n\\\",\\n    \\\"| **\u0442\u0440\u0438** | 3 / \u043f\u043e\u0432\u0435\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \\\\\\\"\u0442\u0435\u0440\u0435\u0442\u044c\\\\\\\" | \\\\\\\"\u0442\u0440\u0438 \u0441\u044f\\\\\\\", \\\\\\\"\u0442\u0440\u0438 \u0442\u0435\\\\\\\" \u2192 \u0433\u043b\u0430\u0433\u043e\u043b | Regex |\\\\n\\\",\\n    \\\"| **\u0441\u043e\u0440\u043e\u043a** | 40 / \\\\\\\"\u0441\u043e\u0440\u043e\u043a\u0430\\\\\\\" (\u043f\u0442\u0438\u0446\u0430) | \\\\\\\"\u0441\u043e\u0440\u043e\u043a \u043b\u0435\u0442\u0438\u0442/\u043f\u0442\u0438\u0446\\\\\\\" \u2192 \u043d\u0435 \u0447\u0438\u0441\u043b\u043e | Regex |\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**pymorphy2 fallback:** \u043f\u0440\u0438 \u043d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u043e\u0441\u0442\u0438 \u043f\u043e\u0441\u043b\u0435 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0445 \u043f\u0430\u0442\u0442\u0435\u0440\u043d\u043e\u0432\\\\n\\\",\\n    \\\"\u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f POS-\u0442\u0435\u0433\u0433\u0438\u043d\u0433. \u0415\u0441\u043b\u0438 pymorphy2 \u043d\u0435 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d \u2014 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 9. N-gram Language Model (ngram_lm.py)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"Character-level n-gram \u043c\u043e\u0434\u0435\u043b\u044c \u0434\u043b\u044f \u043e\u0446\u0435\u043d\u043a\u0438 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u0438 \u043f\u0430\u0440\u0441\u0435\u0440\u0430.\\\\n\\\",\\n    \\\"\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u0432 \u0433\u0438\u0431\u0440\u0438\u0434\u043d\u043e\u043c \u043f\u043e\u0434\u0445\u043e\u0434\u0435 \u0434\u043b\u044f \u043f\u0440\u0438\u043d\u044f\u0442\u0438\u044f \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u043e fallback \u043d\u0430 T5.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"class CharNGram:\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Character-level n-gram language model with Laplace (add-k) smoothing.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def __init__(self, order=4, smoothing_k=1.0):\\\\n\\\",\\n    \\\"        if order < 1:\\\\n\\\",\\n    \\\"            raise ValueError(\\\\\\\"order must be >= 1\\\\\\\")\\\\n\\\",\\n    \\\"        self.order = order\\\\n\\\",\\n    \\\"        self.k = smoothing_k\\\\n\\\",\\n    \\\"        self._ngram_counts = Counter()\\\\n\\\",\\n    \\\"        self._context_counts = Counter()\\\\n\\\",\\n    \\\"        self._vocab = set()\\\\n\\\",\\n    \\\"        self._vocab_size = 0\\\\n\\\",\\n    \\\"        self._trained = False\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def _pad(self, text):\\\\n\\\",\\n    \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\u0414\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 BOS/EOS \u043c\u0430\u0440\u043a\u0435\u0440\u043e\u0432.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"        return \\\\\\\"\\\\\\\\x02\\\\\\\" * (self.order - 1) + text + \\\\\\\"\\\\\\\\x03\\\\\\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def _get_ngrams(self, text):\\\\n\\\",\\n    \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\u0413\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f n-\u0433\u0440\u0430\u043c \u0441 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0430\u043c\u0438.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"        padded = self._pad(text)\\\\n\\\",\\n    \\\"        for i in range(self.order - 1, len(padded)):\\\\n\\\",\\n    \\\"            context = padded[i - self.order + 1: i]\\\\n\\\",\\n    \\\"            token = padded[i]\\\\n\\\",\\n    \\\"            yield context, token\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def train(self, texts):\\\\n\\\",\\n    \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\u041e\u0431\u0443\u0447\u0435\u043d\u0438\u0435: \u043f\u043e\u0434\u0441\u0447\u0451\u0442 n-\u0433\u0440\u0430\u043c \u0438 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043e\u0432.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"        for text in texts:\\\\n\\\",\\n    \\\"            for ctx, tok in self._get_ngrams(text):\\\\n\\\",\\n    \\\"                ngram = ctx + tok\\\\n\\\",\\n    \\\"                self._ngram_counts[ngram] += 1\\\\n\\\",\\n    \\\"                self._context_counts[ctx] += 1\\\\n\\\",\\n    \\\"                self._vocab.add(tok)\\\\n\\\",\\n    \\\"                for ch in ctx:\\\\n\\\",\\n    \\\"                    self._vocab.add(ch)\\\\n\\\",\\n    \\\"        self._vocab_size = len(self._vocab)\\\\n\\\",\\n    \\\"        self._trained = True\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def score(self, text):\\\\n\\\",\\n    \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\u041b\u043e\u0433\u0430\u0440\u0438\u0444\u043c\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c \u0442\u0435\u043a\u0441\u0442\u0430 (\u043d\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0430\u044f).\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"        if not self._trained:\\\\n\\\",\\n    \\\"            raise ValueError(\\\\\\\"model not trained\\\\\\\")\\\\n\\\",\\n    \\\"        log_prob = 0.0\\\\n\\\",\\n    \\\"        n_tokens = 0\\\\n\\\",\\n    \\\"        for ctx, tok in self._get_ngrams(text):\\\\n\\\",\\n    \\\"            ngram = ctx + tok\\\\n\\\",\\n    \\\"            numer = self._ngram_counts.get(ngram, 0) + self.k\\\\n\\\",\\n    \\\"            denom = self._context_counts.get(ctx, 0) + self.k * self._vocab_size\\\\n\\\",\\n    \\\"            log_prob += math.log(numer / denom)\\\\n\\\",\\n    \\\"            n_tokens += 1\\\\n\\\",\\n    \\\"        return log_prob / n_tokens if n_tokens > 0 else float(\\\\\\\"-inf\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def save(self, path):\\\\n\\\",\\n    \\\"        data = {\\\\n\\\",\\n    \\\"            \\\\\\\"order\\\\\\\": self.order,\\\\n\\\",\\n    \\\"            \\\\\\\"k\\\\\\\": self.k,\\\\n\\\",\\n    \\\"            \\\\\\\"ngram_counts\\\\\\\": self._ngram_counts,\\\\n\\\",\\n    \\\"            \\\\\\\"context_counts\\\\\\\": self._context_counts,\\\\n\\\",\\n    \\\"            \\\\\\\"vocab\\\\\\\": self._vocab,\\\\n\\\",\\n    \\\"            \\\\\\\"vocab_size\\\\\\\": self._vocab_size,\\\\n\\\",\\n    \\\"        }\\\\n\\\",\\n    \\\"        with open(path, \\\\\\\"wb\\\\\\\") as f:\\\\n\\\",\\n    \\\"            pickle.dump(data, f)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    def load(self, path):\\\\n\\\",\\n    \\\"        with open(path, \\\\\\\"rb\\\\\\\") as f:\\\\n\\\",\\n    \\\"            data = pickle.load(f)\\\\n\\\",\\n    \\\"        lm = CharNGram(order=data[\\\\\\\"order\\\\\\\"], smoothing_k=data[\\\\\\\"k\\\\\\\"])\\\\n\\\",\\n    \\\"        lm._ngram_counts = data[\\\\\\\"ngram_counts\\\\\\\"]\\\\n\\\",\\n    \\\"        lm._context_counts = data[\\\\\\\"context_counts\\\\\\\"]\\\\n\\\",\\n    \\\"        lm._vocab = data[\\\\\\\"vocab\\\\\\\"]\\\\n\\\",\\n    \\\"        lm._vocab_size = data[\\\\\\\"vocab_size\\\\\\\"]\\\\n\\\",\\n    \\\"        lm._trained = True\\\\n\\\",\\n    \\\"        return lm\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u0414\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0430\u0446\u0438\u044f\\\\n\\\",\\n    \\\"lm = CharNGram(order=3, smoothing_k=0.01)\\\\n\\\",\\n    \\\"lm.train([\\\\n\\\",\\n    \\\"    \\\\\\\"25 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e \u043e\u0442 300 \u0434\u043e 1300\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043d\u0430 500 \u043b\u0435\u0442\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u043a\u0438\u0434\u043a\u0430 100 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u043a\u043e\u043b\u043e 50\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0442\u043e\\\\\\\",\\\\n\\\",\\n    \\\"])\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print('=== CharNGram Language Model ===')\\\\n\\\",\\n    \\\"print(f'\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b: order={lm.order}, smoothing_k={lm.k}')\\\\n\\\",\\n    \\\"print(f'\u0421\u043b\u043e\u0432\u0430\u0440\u044c: {lm._vocab_size} \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432')\\\\n\\\",\\n    \\\"print(f'N-\u0433\u0440\u0430\u043c: {len(lm._ngram_counts)} \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0445')\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"test_texts = [\\\\\\\"25 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\", \\\\\\\"\u0441\u0442\u043e\\\\\\\", \\\\\\\"abcxyz\\\\\\\", \\\\\\\"\u0441\u043a\u0438\u0434\u043a\u0430 100 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432\\\\\\\"]\\\\n\\\",\\n    \\\"print('\\\\\\\\n\u041e\u0446\u0435\u043d\u043a\u0430 \u043f\u0440\u0430\u0432\u0434\u043e\u043f\u043e\u0434\u043e\u0431\u0438\u044f (log-prob):')\\\\n\\\",\\n    \\\"for t in test_texts:\\\\n\\\",\\n    \\\"    s = lm.score(t)\\\\n\\\",\\n    \\\"    print(f'  {t:25s} \u2192 {s:.4f}')\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 9.1 \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 n-gram LM \u0432 \u0433\u0438\u0431\u0440\u0438\u0434\u0435\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"N-gram \u043c\u043e\u0434\u0435\u043b\u044c \u0434\u0430\u0451\u0442 **\u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c \u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438** \u2014 \u0447\u0435\u043c \u0432\u044b\u0448\u0435 \u043b\u043e\u0433\u0430\u0440\u0438\u0444\u043c\u0438\u0447\u0435\u0441\u043a\u0430\u044f\\\\n\\\",\\n    \\\"\u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c, \u0442\u0435\u043c \u0431\u043e\u043b\u0435\u0435 \\\\\\\"\u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u043c\\\\\\\" \u0432\u044b\u0433\u043b\u044f\u0434\u0438\u0442 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u043f\u0430\u0440\u0441\u0435\u0440\u0430.\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u041f\u043e\u0440\u043e\u0433\u0438 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u0438** (\u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u044e\u0442\u0441\u044f \u043f\u0440\u0438 \u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0435 \u043c\u043e\u0434\u0435\u043b\u0438):\\\\n\\\",\\n    \\\"- `threshold_min` \u2014 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0434\u043e\u043f\u0443\u0441\u0442\u0438\u043c\u0430\u044f \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c\\\\n\\\",\\n    \\\"- `threshold_p5` / `threshold_p10` \u2014 \u043f\u0435\u0440\u0446\u0435\u043d\u0442\u0438\u043b\u0438 \u043f\u043e \u043e\u0431\u0443\u0447\u0430\u044e\u0449\u0435\u0439 \u0432\u044b\u0431\u043e\u0440\u043a\u0435\\\\n\\\",\\n    \\\"- `threshold_mean` \u2014 \u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c \u043e\u0431\u0443\u0447\u0430\u044e\u0449\u0438\u0445 \u0434\u0430\u043d\u043d\u044b\u0445\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0415\u0441\u043b\u0438 `lm.score(prediction) < threshold` \u2014 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043f\u0430\u0440\u0441\u0435\u0440\u0430 \u043d\u0438\u0437\u043a\u0430\u044f,\\\\n\\\",\\n    \\\"\u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f fallback \u043d\u0430 T5.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 10. CLI \u2014 \u0422\u0440\u0438 \u0442\u043e\u0447\u043a\u0438 \u0432\u0445\u043e\u0434\u0430\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041c\u043e\u0434\u0443\u043b\u044c `cli.py` \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \u0442\u0440\u0438 \u043a\u043e\u043c\u0430\u043d\u0434\u044b, \u0432\u044b\u0437\u044b\u0432\u0430\u0435\u043c\u044b\u0435 \u0447\u0435\u0440\u0435\u0437 `python main.py`.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u0414\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0430\u0446\u0438\u044f CLI \u0431\u0435\u0437 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0437\u0430\u043f\u0443\u0441\u043a\u0430\\\\n\\\",\\n    \\\"import argparse\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def build_parser():\\\\n\\\",\\n    \\\"    p = argparse.ArgumentParser(\\\\n\\\",\\n    \\\"        description=\\\\\\\"ITN: \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u0447\u0438\u0441\u0435\u043b \u0432 ASR-\u0442\u0440\u0430\u043d\u0441\u043a\u0440\u0438\u0431\u0430\u0446\u0438\u044f\u0445\\\\\\\")\\\\n\\\",\\n    \\\"    sub = p.add_subparsers(dest=\\\\\\\"command\\\\\\\", required=True)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # run\\\\n\\\",\\n    \\\"    run_p = sub.add_parser(\\\\\\\"run\\\\\\\", help=\\\\\\\"\u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u0442\u044c \u0444\u0430\u0439\u043b \u0438 \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c\\\\\\\")\\\\n\\\",\\n    \\\"    run_p.add_argument(\\\\\\\"input\\\\\\\", help=\\\\\\\"\u041f\u0443\u0442\u044c \u043a .feather \u0444\u0430\u0439\u043b\u0443\\\\\\\")\\\\n\\\",\\n    \\\"    run_p.add_argument(\\\\\\\"-o\\\\\\\", \\\\\\\"--output\\\\\\\", help=\\\\\\\"\u0412\u044b\u0445\u043e\u0434\u043d\u043e\u0439 .feather \\\\\\\")\\\\n\\\",\\n    \\\"    run_p.add_argument(\\\\\\\"--hybrid\\\\\\\", action=\\\\\\\"store_true\\\\\\\",\\\\n\\\",\\n    \\\"                       help=\\\\\\\"\u0413\u0438\u0431\u0440\u0438\u0434 (\u043f\u0430\u0440\u0441\u0435\u0440 + ruT5)\\\\\\\")\\\\n\\\",\\n    \\\"    run_p.add_argument(\\\\\\\"--parser-type\\\\\\\", choices=[\\\\\\\"current\\\\\\\", \\\\\\\"sequence\\\\\\\"],\\\\n\\\",\\n    \\\"                       default=\\\\\\\"current\\\\\\\", help=\\\\\\\"\u0422\u0438\u043f \u043f\u0430\u0440\u0441\u0435\u0440\u0430\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # evaluate\\\\n\\\",\\n    \\\"    eval_p = sub.add_parser(\\\\\\\"evaluate\\\\\\\", help=\\\\\\\"\u041e\u0446\u0435\u043d\u0438\u0442\u044c accuracy\\\\\\\")\\\\n\\\",\\n    \\\"    eval_p.add_argument(\\\\\\\"input\\\\\\\", help=\\\\\\\"\u041f\u0443\u0442\u044c \u043a calibration.f\\\\\\\")\\\\n\\\",\\n    \\\"    eval_p.add_argument(\\\\\\\"--hybrid\\\\\\\", action=\\\\\\\"store_true\\\\\\\")\\\\n\\\",\\n    \\\"    eval_p.add_argument(\\\\\\\"--parser-type\\\\\\\", choices=[\\\\\\\"current\\\\\\\", \\\\\\\"sequence\\\\\\\"],\\\\n\\\",\\n    \\\"                       default=\\\\\\\"current\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # errors\\\\n\\\",\\n    \\\"    err_p = sub.add_parser(\\\\\\\"errors\\\\\\\", help=\\\\\\\"\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u043e\u0448\u0438\u0431\u043a\u0438\\\\\\\")\\\\n\\\",\\n    \\\"    err_p.add_argument(\\\\\\\"input\\\\\\\")\\\\n\\\",\\n    \\\"    err_p.add_argument(\\\\\\\"-n\\\\\\\", type=int, default=15, help=\\\\\\\"\u041a\u043e\u043b-\u0432\u043e \u043e\u0448\u0438\u0431\u043e\u043a\\\\\\\")\\\\n\\\",\\n    \\\"    err_p.add_argument(\\\\\\\"--hybrid\\\\\\\", action=\\\\\\\"store_true\\\\\\\")\\\\n\\\",\\n    \\\"    err_p.add_argument(\\\\\\\"--parser-type\\\\\\\", choices=[\\\\\\\"current\\\\\\\", \\\\\\\"sequence\\\\\\\"],\\\\n\\\",\\n    \\\"                       default=\\\\\\\"current\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return p\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"parser = build_parser()\\\\n\\\",\\n    \\\"print(\\\\\\\"=== CLI entry points ===\\\\\\\")\\\\n\\\",\\n    \\\"for cmd in ['run', 'evaluate', 'errors']:\\\\n\\\",\\n    \\\"    h = parser._subparsers._group_actions[0].choices[cmd]\\\\n\\\",\\n    \\\"    print(f\\\\\\\"\\\\\\\\n  python main.py {cmd} [\u043e\u043f\u0446\u0438\u0438]\\\\\\\")\\\\n\\\",\\n    \\\"    print(f\\\\\\\"    {h.description}\\\\\\\")\\\\n\\\",\\n    \\\"    for action in h._actions:\\\\n\\\",\\n    \\\"        if action.option_strings:\\\\n\\\",\\n    \\\"            opts = ', '.join(action.option_strings)\\\\n\\\",\\n    \\\"            print(f\\\\\\\"    {opts:30s} {action.help or ''}\\\\\\\")\\\\n\\\",\\n    \\\"        elif action.metavar:\\\\n\\\",\\n    \\\"            print(f\\\\\\\"    {action.metavar:30s} {action.help or ''}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 10.1 \u041f\u0440\u0438\u043c\u0435\u0440\u044b \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"```bash\\\\n\\\",\\n    \\\"# \u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f test.f \u2192 answer.f\\\\n\\\",\\n    \\\"python main.py run data/test.f -o answer.f\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u041e\u0446\u0435\u043d\u043a\u0430 accuracy \u043d\u0430 calibration\\\\n\\\",\\n    \\\"python main.py evaluate data/calibration.f\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# Sequence parser + evaluate \u0441 clean/noisy split\\\\n\\\",\\n    \\\"python main.py evaluate data/calibration.f --parser-type sequence\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u0413\u0438\u0431\u0440\u0438\u0434\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c (\u043f\u0430\u0440\u0441\u0435\u0440 + T5)\\\\n\\\",\\n    \\\"python main.py run data/test.f --hybrid\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u043f\u0435\u0440\u0432\u044b\u0435 20 \u043e\u0448\u0438\u0431\u043e\u043a\\\\n\\\",\\n    \\\"python main.py errors data/calibration.f -n 20\\\\n\\\",\\n    \\\"```\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u0412\u044b\u0445\u043e\u0434\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u0430\u0442\u044b:**\\\\n\\\",\\n    \\\"- `run` \u2192 `.feather` \u0444\u0430\u0439\u043b \u0441 \u043a\u043e\u043b\u043e\u043d\u043a\u043e\u0439 `answer` (\u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u0442\u0435\u043a\u0441\u0442)\\\\n\\\",\\n    \\\"- `evaluate` \u2192 stdout: accuracy, clean/noisy split, EDA stats\\\\n\\\",\\n    \\\"- `errors` \u2192 stdout: task, ground_truth, prediction \u043f\u043e\u0441\u0442\u0440\u043e\u0447\u043d\u043e\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 11. \u041f\u0430\u0439\u043f\u043b\u0430\u0439\u043d \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 (\u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043f\u0443\u0442\u0438)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0414\u0432\u0430 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0443\u0442\u0438 \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u0432 `normalizer.py`.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u2500\u2500 \u0412\u0441\u043f\u043e\u043c\u043e\u0433\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _is_vague_tyt_context(tokens, i):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430, \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043b\u0438 \\\\\\\"\u0442\u044b\u0449/\u0442\u044b\u0449\u0430\\\\\\\" \u043d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u044b\u043c \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043e\u043c.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if i < 1:\\\\n\\\",\\n    \\\"        return False\\\\n\\\",\\n    \\\"    p = tokens[i - 1]\\\\n\\\",\\n    \\\"    if p in (\\\\\\\"\u0432\u044b\u0448\u0435\\\\\\\", \\\\\\\"\u043d\u0438\u0436\u0435\\\\\\\", \\\\\\\"\u043e\u043a\u043e\u043b\u043e\\\\\\\"):\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if p == \\\\\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\\\\\" or (p == \\\\\\\"\u0441\\\\\\\" and i >= 2 and tokens[i - 2] == \\\\\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\\\\\"):\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if i >= 3 and tokens[i - 3] == \\\\\\\"\u0441\\\\\\\" and tokens[i - 2] == \\\\\\\"\u0447\u0435\u043c\\\\\\\" and tokens[i - 1] == \\\\\\\"\u0442\u043e\\\\\\\":\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    if i >= 2 and tokens[i - 2] == \\\\\\\"\u0433\u0434\u0435\\\\\\\" and tokens[i - 1] == \\\\\\\"\u0442\u043e\\\\\\\":\\\\n\\\",\\n    \\\"        return True\\\\n\\\",\\n    \\\"    return False\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"_FUSED_COMPOUNDS = {\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\\\\\": [(2, 0, False, False), (1000, 4, True, False)]\\\\n\\\",\\n    \\\"}\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u2500\u2500 Path A (Legacy) \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def normalize_text(text):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    \u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f: ASR preprocess \u2192 \u0442\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u2192 lookup \u2192 groups \u2192 \u043f\u0430\u0440\u0441\u0438\u043d\u0433 \u2192 \u0437\u0430\u043c\u0435\u043d\u0430.\\\\n\\\",\\n    \\\"    \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442 Path A (legacy mag-based parser).\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if not isinstance(text, str) or not text.strip():\\\\n\\\",\\n    \\\"        return text\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    text = _asr_preprocess(text)\\\\n\\\",\\n    \\\"    tokens = text.split()\\\\n\\\",\\n    \\\"    result_tokens = []\\\\n\\\",\\n    \\\"    i = 0\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    while i < len(tokens):\\\\n\\\",\\n    \\\"        t = tokens[i]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        # Vague context: \u043f\u0440\u043e\u043f\u0443\u0441\u043a\\\\n\\\",\\n    \\\"        if t in (\\\\\\\"\u0442\u044b\u0449\\\\\\\", \\\\\\\"\u0442\u044b\u0449\u0430\\\\\\\") and _is_vague_tyt_context(tokens, i):\\\\n\\\",\\n    \\\"            result_tokens.append(t)\\\\n\\\",\\n    \\\"            i += 1\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        # \u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043d\u0430 \u0447\u0438\u0441\u043b\u043e\\\\n\\\",\\n    \\\"        lk = lookup_word(t)\\\\n\\\",\\n    \\\"        io = is_ordinal_word(t)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        # \u0414\u0438\u0437\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f\\\\n\\\",\\n    \\\"        if lk and not io and not is_likely_numeric(text, t, i):\\\\n\\\",\\n    \\\"            result_tokens.append(t)\\\\n\\\",\\n    \\\"            i += 1\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"        if lk or io:\\\\n\\\",\\n    \\\"            # \u0421\u0431\u043e\u0440 \u0433\u0440\u0443\u043f\u043f\u044b \u0447\u0438\u0441\u043b\u043e\u0432\u044b\u0445 \u0442\u043e\u043a\u0435\u043d\u043e\u0432\\\\n\\\",\\n    \\\"            start = i\\\\n\\\",\\n    \\\"            while i < len(tokens):\\\\n\\\",\\n    \\\"                if lookup_word(tokens[i]) is not None or is_ordinal_word(tokens[i]):\\\\n\\\",\\n    \\\"                    i += 1\\\\n\\\",\\n    \\\"                else:\\\\n\\\",\\n    \\\"                    break\\\\n\\\",\\n    \\\"            # \u041f\u0430\u0440\u0441\u0438\u043d\u0433 \u0433\u0440\u0443\u043f\u043f\u044b\\\\n\\\",\\n    \\\"            gd = []\\\\n\\\",\\n    \\\"            for j in range(start, i):\\\\n\\\",\\n    \\\"                tj = tokens[j]\\\\n\\\",\\n    \\\"                lk2 = lookup_word(tj)\\\\n\\\",\\n    \\\"                io2 = is_ordinal_word(tj)\\\\n\\\",\\n    \\\"                if io2:\\\\n\\\",\\n    \\\"                    gd.append((int(ordinal_value(tj)), 0, False, True))\\\\n\\\",\\n    \\\"                elif lk2:\\\\n\\\",\\n    \\\"                    if tj in _FUSED_COMPOUNDS:\\\\n\\\",\\n    \\\"                        gd.extend(_FUSED_COMPOUNDS[tj])\\\\n\\\",\\n    \\\"                    else:\\\\n\\\",\\n    \\\"                        gd.append((lk2[0], lk2[1], lk2[2], False))\\\\n\\\",\\n    \\\"            result_tokens.extend(parse_number_group(gd))\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            result_tokens.append(t)\\\\n\\\",\\n    \\\"            i += 1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return \\\\\\\" \\\\\\\".join(result_tokens)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u2500\u2500 Path B (Sequence) \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def normalize_text_sequence(text):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    \u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u0447\u0435\u0440\u0435\u0437 sequence-based parser (classify \u2192 parse_sequence).\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    if not isinstance(text, str) or not text.strip():\\\\n\\\",\\n    \\\"        return text\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    text = _asr_preprocess(text)\\\\n\\\",\\n    \\\"    tokens = text.split()\\\\n\\\",\\n    \\\"    result_tokens = []\\\\n\\\",\\n    \\\"    i = 0\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    while i < len(tokens):\\\\n\\\",\\n    \\\"        cs = classify(tokens[i], tokens[:i])\\\\n\\\",\\n    \\\"        if cs and not all(c.subtype == \\\\\\\"vague\\\\\\\" for c in cs):\\\\n\\\",\\n    \\\"            group = []\\\\n\\\",\\n    \\\"            while i < len(tokens):\\\\n\\\",\\n    \\\"                c2 = classify(tokens[i], tokens[:i])\\\\n\\\",\\n    \\\"                if c2 and not all(c.subtype == \\\\\\\"vague\\\\\\\" for c in c2):\\\\n\\\",\\n    \\\"                    group.extend(c2)\\\\n\\\",\\n    \\\"                    i += 1\\\\n\\\",\\n    \\\"                else:\\\\n\\\",\\n    \\\"                    break\\\\n\\\",\\n    \\\"            result_tokens.extend(parse_sequence(group))\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            result_tokens.append(tokens[i])\\\\n\\\",\\n    \\\"            i += 1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return \\\\\\\" \\\\\\\".join(result_tokens)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=== \u041f\u0440\u0438\u043c\u0435\u0440\u044b \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 ===\\\\\\\")\\\\n\\\",\\n    \\\"examples = [\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 \u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0434\u0432\u0430\u0441\u0442\u0430 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0442\u043e \u0440\u0443\u0431\u043b\u0435\u0439 \u0441\u043a\u0438\u0434\u043a\u0430\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043f\u044f\u0442\u0443\u044e \u043a\u043d\u043e\u043f\u043a\u0443\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442 \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0432\u044b\u0448\u0435 \u0441\u0442\u0430 \u0442\u044b\u0441\u044f\u0447\\\\\\\",\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'\u0412\u0425\u041e\u0414':50s} {'\u0412\u042b\u0425\u041e\u0414 (legacy)':20s} {'\u0412\u042b\u0425\u041e\u0414 (sequence)':20s}\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\u2500\\\\\\\" * 90)\\\\n\\\",\\n    \\\"for ex in examples:\\\\n\\\",\\n    \\\"    p1 = normalize_text(ex)\\\\n\\\",\\n    \\\"    p2 = normalize_text_sequence(ex)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"{ex:50s} {p1:20s} {p2:20s}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 12. \u041e\u0446\u0435\u043d\u043a\u0430 \u043d\u0430 \u0432\u0441\u0435\u0445 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\u0430\u0445\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0421\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435 \u0434\u0432\u0443\u0445 \u043f\u0430\u0440\u0441\u0435\u0440\u043e\u0432: legacy (current) \u0438 sequence.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"def evaluate(fn, df, name=\\\\\\\"\\\\\\\"):\\\\n\\\",\\n    \\\"    correct = sum(\\\\n\\\",\\n    \\\"        1 for _, r in df.iterrows()\\\\n\\\",\\n    \\\"        if fn(r[\\\\\\\"task_text\\\\\\\"]) == r[\\\\\\\"ground_truth\\\\\\\"]\\\\n\\\",\\n    \\\"    )\\\\n\\\",\\n    \\\"    pct = correct / len(df) * 100\\\\n\\\",\\n    \\\"    return correct, pct\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"\u041e\u0446\u0435\u043d\u043a\u0430: Legacy (normalize_text)\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"for name, df in [(\\\\\\\"calibration.f\\\\\\\", cal), (\\\\\\\"synthetic.f\\\\\\\", syn), (\\\\\\\"real.f\\\\\\\", real)]:\\\\n\\\",\\n    \\\"    corr, pct = evaluate(normalize_text, df, name)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  {name:15s} {corr:4d}/{len(df):5d} = {pct:6.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"    if \\\\\\\"noise_level\\\\\\\" in df.columns:\\\\n\\\",\\n    \\\"        for g in [\\\\\\\"clean\\\\\\\", \\\\\\\"noisy\\\\\\\"]:\\\\n\\\",\\n    \\\"            sub = df[df[\\\\\\\"noise_level\\\\\\\"] == g]\\\\n\\\",\\n    \\\"            if len(sub) == 0:\\\\n\\\",\\n    \\\"                continue\\\\n\\\",\\n    \\\"            gc, gp = evaluate(normalize_text, sub, f\\\\\\\"  {g}\\\\\\\")\\\\n\\\",\\n    \\\"            print(f\\\\\\\"    {g:10s} {gc:4d}/{len(sub):5d} = {gp:6.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print()\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"\u041e\u0446\u0435\u043d\u043a\u0430: Sequence (normalize_text_sequence)\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"for name, df in [(\\\\\\\"calibration.f\\\\\\\", cal), (\\\\\\\"synthetic.f\\\\\\\", syn), (\\\\\\\"real.f\\\\\\\", real)]:\\\\n\\\",\\n    \\\"    corr, pct = evaluate(normalize_text_sequence, df, name)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  {name:15s} {corr:4d}/{len(df):5d} = {pct:6.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"    if \\\\\\\"noise_level\\\\\\\" in df.columns:\\\\n\\\",\\n    \\\"        for g in [\\\\\\\"clean\\\\\\\", \\\\\\\"noisy\\\\\\\"]:\\\\n\\\",\\n    \\\"            sub = df[df[\\\\\\\"noise_level\\\\\\\"] == g]\\\\n\\\",\\n    \\\"            if len(sub) == 0:\\\\n\\\",\\n    \\\"                continue\\\\n\\\",\\n    \\\"            gc, gp = evaluate(normalize_text_sequence, sub, f\\\\\\\"  {g}\\\\\\\")\\\\n\\\",\\n    \\\"            print(f\\\\\\\"    {g:10s} {gc:4d}/{len(sub):5d} = {gp:6.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print()\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"\u0421\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u0435\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'\u0414\u0430\u0442\u0430\u0441\u0435\u0442':15s} {'Legacy':>10s} {'Sequence':>10s} {'\u0420\u0430\u0437\u043d\u0438\u0446\u0430':>10s}\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\u2500\\\\\\\" * 45)\\\\n\\\",\\n    \\\"for name, df in [(\\\\\\\"calibration.f\\\\\\\", cal), (\\\\\\\"synthetic.f\\\\\\\", syn), (\\\\\\\"real.f\\\\\\\", real)]:\\\\n\\\",\\n    \\\"    c1, p1 = evaluate(normalize_text, df)\\\\n\\\",\\n    \\\"    c2, p2 = evaluate(normalize_text_sequence, df)\\\\n\\\",\\n    \\\"    diff = p2 - p1\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  {name:15s} {p1:8.2f}% {p2:8.2f}% {diff:+8.2f}%\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 12.1 \u0418\u043d\u0442\u0435\u0440\u043f\u0440\u0435\u0442\u0430\u0446\u0438\u044f \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**calibration.f:** 99.8% (\u043e\u0431\u0430 \u043f\u0430\u0440\u0441\u0435\u0440\u0430)\\\\n\\\",\\n    \\\"- \u0415\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \\\\\\\"\u043e\u0448\u0438\u0431\u043a\u0430\\\\\\\" \u2014 `\u0434\u0432\u0430\u0441\u0442\u0430` \u0432 GT (ASR-\u043e\u0448\u0438\u0431\u043a\u0430 \u043d\u0435 \u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0430). \u041f\u0430\u0440\u0441\u0435\u0440 \u0434\u0430\u0451\u0442 200 \u2014 ITN-\u043a\u043e\u0440\u0440\u0435\u043a\u0442\u0435\u043d.\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**synthetic.f (clean):** 95.87%\\\\n\\\",\\n    \\\"- \u0427\u0438\u0441\u0442\u044b\u0435 \u0434\u0430\u043d\u043d\u044b\u0435 \u0431\u0435\u0437 ASR-\u0448\u0443\u043c\u0430 \u2192 \u0432\u044b\u0441\u043e\u043a\u043e\u0435 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u043e\\\\n\\\",\\n    \\\"- 4.13% \u043e\u0448\u0438\u0431\u043e\u043a: \u043f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u044b \u043d\u0435 \u0432 \u0441\u043b\u043e\u0432\u0430\u0440\u0435, \u0440\u0435\u0434\u043a\u0438\u0435 \u0447\u0438\u0441\u043b\u043e\u0432\u044b\u0435 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**synthetic.f (noisy):** 1.80% / 4.26%\\\\n\\\",\\n    \\\"- Sequence parser \u043d\u0430 2.36% \u043b\u0443\u0447\u0448\u0435 \u0437\u0430 \u0441\u0447\u0451\u0442 root-based \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438\\\\n\\\",\\n    \\\"- \u041f\u0440\u0438\u043d\u0446\u0438\u043f\u0438\u0430\u043b\u044c\u043d\u043e\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435: rule-based \u043d\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0430 \u0437\u0430\u0448\u0443\u043c\u043b\u0451\u043d\u043d\u044b\u0445 \u0434\u0430\u043d\u043d\u044b\u0445\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**real.f:** 55.23% (\u043e\u0431\u0430 \u043f\u0430\u0440\u0441\u0435\u0440\u0430)\\\\n\\\",\\n    \\\"- \u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043b\u0438\u043f\u0430\u0435\u0442 \u043a \u0442\u043e\u043a\u0435\u043d\u0430\u043c: `\u0434\u0435\u0432\u044f\u0442\u044c)`, `\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442%`\\\\n\\\",\\n    \\\"- \u0414\u0435\u0444\u0438\u0441\u043d\u044b\u0435 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438: `\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c-\u0445`, `\u043f\u044f\u0442\u044c-\u0439`\\\\n\\\",\\n    \\\"- \u0421\u043b\u043e\u0436\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u0430\u0442\u044b: `\u043e\u0434\u0438\u043d,5`, `\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c:19`\\\\n\\\",\\n    \\\"- \u041a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u044b\u0435 false positives: `\u043f\u0435\u0440\u0432\u044b\u043c` \u2192 \\\\\\\"1\\\\\\\", `\u0434\u0432\u0443\u0445` \u2192 \\\\\\\"2\\\\\\\"\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 13. \u0414\u0435\u0442\u0430\u043b\u044c\u043d\u044b\u0439 \u0430\u043d\u0430\u043b\u0438\u0437 \u043e\u0448\u0438\u0431\u043e\u043a\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"### 13.1 calibration.f \u2014 \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u043e\u0448\u0438\u0431\u043a\u0430\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"def show_errors(fn, df, n=10, title=\\\\\\\"\u041e\u0448\u0438\u0431\u043a\u0438\\\\\\\"):\\\\n\\\",\\n    \\\"    errors = []\\\\n\\\",\\n    \\\"    for i, r in df.iterrows():\\\\n\\\",\\n    \\\"        p = fn(r[\\\\\\\"task_text\\\\\\\"])\\\\n\\\",\\n    \\\"        if p != r[\\\\\\\"ground_truth\\\\\\\"]:\\\\n\\\",\\n    \\\"            errors.append((i, r[\\\\\\\"task_text\\\\\\\"], r[\\\\\\\"ground_truth\\\\\\\"], p))\\\\n\\\",\\n    \\\"            if len(errors) >= n:\\\\n\\\",\\n    \\\"                break\\\\n\\\",\\n    \\\"    print(f\\\\\\\"=== {title}: {len(errors)} \u043e\u0448\u0438\u0431\u043e\u043a ===\\\\\\\")\\\\n\\\",\\n    \\\"    for idx, (ri, t, g, p) in enumerate(errors):\\\\n\\\",\\n    \\\"        print(f\\\\\\\"\\\\\\\\n--- {idx+1}. Row {ri} ---\\\\\\\")\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  TASK: {t}\\\\\\\")\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  GT:   {g}\\\\\\\")\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  PRED: {p}\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return errors\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# \u041d\u0430\u0445\u043e\u0434\u0438\u043c \u043e\u0448\u0438\u0431\u043a\u0438\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"calibration.f \u2014 \u043e\u0448\u0438\u0431\u043a\u0438 legacy \u043f\u0430\u0440\u0441\u0435\u0440\u0430\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"err_cal = show_errors(normalize_text, cal, n=5)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"if not err_cal:\\\\n\\\",\\n    \\\"    print(\\\\\\\"\\\\\\\\n\u041e\u0448\u0438\u0431\u043e\u043a \u043d\u0435\u0442! \u041f\u0430\u0440\u0441\u0435\u0440 \u0434\u043e\u0441\u0442\u0438\u0433 100% \u043d\u0430 calibration.f\\\\\\\")\\\\n\\\",\\n    \\\"else:\\\\n\\\",\\n    \\\"    print(f\\\\\\\"\\\\\\\\n\u0410\u043d\u0430\u043b\u0438\u0437: {len(errors_cal)} \u043e\u0448\u0438\u0431\u043e\u043a\\\\\\\")\\\\n\\\",\\n    \\\"    # \u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f\\\\n\\\",\\n    \\\"    cats = Counter()\\\\n\\\",\\n    \\\"    for _, t, g, p in err_cal:\\\\n\\\",\\n    \\\"        if '\u0434\u0432\u0430\u0441\u0442\u0430' in t.lower() or '\u0434\u0432\u0435\u0441\u0438' in t.lower():\\\\n\\\",\\n    \\\"            cats['ASR-\u043e\u0448\u0438\u0431\u043a\u0430 \u0432 GT'] += 1\\\\n\\\",\\n    \\\"        elif any(w in g for w in ['\u0451','\u0439']):\\\\n\\\",\\n    \\\"            cats['\u0451-\u0444\u043e\u0440\u043c\u0430 ordinal'] += 1\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            cats['\u0434\u0440\u0443\u0433\u043e\u0435'] += 1\\\\n\\\",\\n    \\\"    for cat, cnt in cats.most_common():\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  {cat}: {cnt}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 13.2 real.f \u2014 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0438 \u043e\u0448\u0438\u0431\u043e\u043a\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"execution_count\\\": null,\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"real.f \u2014 \u0430\u043d\u0430\u043b\u0438\u0437 \u043e\u0448\u0438\u0431\u043e\u043a\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"err_real = show_errors(normalize_text, real, n=25, title=\\\\\\\"real.f errors\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n=== \u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u043e\u0448\u0438\u0431\u043e\u043a real.f ===\\\\\\\")\\\\n\\\",\\n    \\\"real_cats = Counter()\\\\n\\\",\\n    \\\"for _, t, g, p in err_real:\\\\n\\\",\\n    \\\"    if any(ch in t for ch in '()%'):\\\\n\\\",\\n    \\\"        if any(w in t.lower().split() for w in ['\u0434\u0435\u0432\u044f\u0442\u044c)', '\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442%', '\u0441\u0442\u043e)', '\u043f\u044f\u0442\u044c)']):\\\\n\\\",\\n    \\\"            real_cats['\u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u043f\u0440\u0438\u043b\u0438\u043f\u043b\u0430 \u043a \u0442\u043e\u043a\u0435\u043d\u0443'] += 1\\\\n\\\",\\n    \\\"        else:\\\\n\\\",\\n    \\\"            real_cats['\u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f \u0432 \u0442\u043e\u043a\u0435\u043d\u0435'] += 1\\\\n\\\",\\n    \\\"    elif any(c in g for c in ',:'):\\\\n\\\",\\n    \\\"        real_cats['Decimal comma / time format'] += 1\\\\n\\\",\\n    \\\"    elif '-' in t:\\\\n\\\",\\n    \\\"        real_cats['\u0414\u0435\u0444\u0438\u0441\u043d\u044b\u0435 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438'] += 1\\\\n\\\",\\n    \\\"    elif any(w in t.lower().split() for w in ['\u043e\u0434\u043d\u0430','\u043e\u0434\u043d\u043e\u0439','\u043e\u0434\u043d\u0438\u043c']):\\\\n\\\",\\n    \\\"        real_cats['\u0416\u0435\u043d\u0441\u043a\u0438\u0439 \u0440\u043e\u0434 (\u043e\u0434\u043d\u0430/\u043e\u0434\u043d\u043e\u0439)'] += 1\\\\n\\\",\\n    \\\"    elif any(w in t.lower().split() for w in ['\u043f\u0435\u0440\u0432\u044b\u043c','\u043f\u0435\u0440\u0432\u043e\u0433\u043e','\u0432\u0442\u043e\u0440\u044b\u0445','\u0434\u0432\u0443\u0445']):\\\\n\\\",\\n    \\\"        real_cats['False positive \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442'] += 1\\\\n\\\",\\n    \\\"    else:\\\\n\\\",\\n    \\\"        real_cats['\u041f\u0440\u043e\u0447\u0435\u0435'] += 1\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"total_err = len(err_real)\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n{'\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f':40s} {'\u041a\u043e\u043b-\u0432\u043e':>8s} {'\u0414\u043e\u043b\u044f':>8s}\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\u2500\\\\\\\" * 56)\\\\n\\\",\\n    \\\"for cat, cnt in real_cats.most_common():\\\\n\\\",\\n    \\\"    pct = cnt / total_err * 100\\\\n\\\",\\n    \\\"    bar = '\u2588' * int(pct / 3)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  {cat:38s} {cnt:4d}     {pct:5.1f}% {bar}\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n\u041f\u043e\u0442\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u043f\u043e\u0442\u043e\u043b\u043e\u043a \u043f\u043e\u0441\u043b\u0435 \u0444\u0438\u043a\u0441\u043e\u0432: 85-90%\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 13.3 synthetic.f \u2014 \u0432\u043b\u0438\u044f\u043d\u0438\u0435 ASR-\u0448\u0443\u043c\u0430\\\"\\n   ],\\n   \\\"metadata\\\": {}\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"print(\\\\\\\"synthetic.f \u2014 \u0432\u043b\u0438\u044f\u043d\u0438\u0435 noise_level\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# clean\\\\n\\\",\\n    \\\"syn_clean = syn[syn[\\\\\\\"noise_level\\\\\\\"] == \\\\\\\"clean\\\\\\\"]\\\\n\\\",\\n    \\\"c_corr, c_pct = evaluate(normalize_text, syn_clean)\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\nclean  ({len(syn_clean):5d} rows): {c_corr:4d}/{len(syn_clean):5d} = {c_pct:.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"# noisy\\\\n\\\",\\n    \\\"syn_noisy = syn[syn[\\\\\\\"noise_level\\\\\\\"] == \\\\\\\"noisy\\\\\\\"]\\\\n\\\",\\n    \\\"n_corr, n_pct = evaluate(normalize_text, syn_noisy)\\\\n\\\",\\n    \\\"print(f\\\\\\\"noisy  ({len(syn_noisy):5d} rows): {n_corr:4d}/{len(syn_noisy):5d} = {n_pct:.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n\u0420\u0430\u0437\u043d\u0438\u0446\u0430 clean vs noisy: {c_pct - n_pct:.2f}%\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\\\\\\\\nASR-\u0448\u0443\u043c \u0441\u043d\u0438\u0436\u0430\u0435\u0442 \u0442\u043e\u0447\u043d\u043e\u0441\u0442\u044c \u0441 96% \u0434\u043e 2-4% \u2014 \u043a\u043b\u044e\u0447\u0435\u0432\u043e\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 rule-based.\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\u0415\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u043f\u0443\u0442\u044c \u2014 T5-\u043c\u043e\u0434\u0435\u043b\u044c, \u043e\u0431\u0443\u0447\u0435\u043d\u043d\u0430\u044f \u043d\u0430 noisy \u0434\u0430\u043d\u043d\u044b\u0445.\\\\\\\")\\\",\\n    \\\"outputs\\\": []\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 14. EDA-\u043c\u043e\u0434\u0443\u043b\u044c (src/eda.py)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041c\u043e\u0434\u0443\u043b\u044c \u0430\u043d\u0430\u043b\u0438\u0437\u0430 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432 \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438: \u0434\u0432\u0430 \u0440\u0435\u0436\u0438\u043c\u0430 `report_run` \u0438 `report_evaluate`.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"def count_numbers(text):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u0421\u0447\u0438\u0442\u0430\u0435\u0442 \u0446\u0438\u0444\u0440\u043e\u0432\u044b\u0435 \u0442\u043e\u043a\u0435\u043d\u044b (\u043f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0446\u0438\u0444\u0440).\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    return len(re.findall(r'\\\\\\\\d+', text))\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def count_numeral_words(text):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u0421\u0447\u0438\u0442\u0430\u0435\u0442 \u0441\u043b\u043e\u0432\u0430-\u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u0438 \u043f\u043e lookup_word.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    return sum(1 for w in text.split()\\\\n\\\",\\n    \\\"               if lookup_word(w) is not None or w.lower() in ORDINAL_SET)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def text_stats(text):\\\\n\\\",\\n    \\\"    return {\\\\n\\\",\\n    \\\"        'length': len(text),\\\\n\\\",\\n    \\\"        'tokens': len(text.split()),\\\\n\\\",\\n    \\\"        'digit_tokens': count_numbers(text),\\\\n\\\",\\n    \\\"        'numeral_words': count_numeral_words(text),\\\\n\\\",\\n    \\\"    }\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=== EDA: \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043a\u0430 \u0434\u0430\u0442\u0430\u0441\u0435\u0442\u043e\u0432 ===\\\\\\\")\\\\n\\\",\\n    \\\"for name, df in [('calibration.f', cal), ('synthetic.f', syn), ('real.f', real)]:\\\\n\\\",\\n    \\\"    stats = df['task_text'].apply(text_stats)\\\\n\\\",\\n    \\\"    print(f'\\\\\\\\n{name:'}:\\\\n\\\",\\n    \\\"    print(f'  \u0441\u0442\u0440\u043e\u043a: {len(df)}')\\\\n\\\",\\n    \\\"    print(f'  \u0434\u043b\u0438\u043d\u0430:  {stats[\\\\\\\"length\\\\\\\"].mean():.1f} \u00b1 {stats[\\\\\\\"length\\\\\\\"].std():.1f} \u0447')\\\\n\\\",\\n    \\\"    print(f'  \u0442\u043e\u043a\u0435\u043d\u043e\u0432: {stats[\\\\\\\"tokens\\\\\\\"].mean():.1f} \u00b1 {stats[\\\\\\\"tokens\\\\\\\"].std():.1f}')\\\\n\\\",\\n    \\\"    print(f'  \u0446\u0438\u0444\u0440/\u0441\u0442\u0440\u043e\u043a\u0443: {stats[\\\\\\\"digit_tokens\\\\\\\"].mean():.2f}')\\\\n\\\",\\n    \\\"    print(f'  \u0441\u043b\u043e\u0432-\u0447\u0438\u0441\u0435\u043b/\u0441\u0442\u0440\u043e\u043a\u0443: {stats[\\\\\\\"numeral_words\\\\\\\"].mean():.2f}')\\\\n\\\",\\n    \\\"    rows_with_nums = sum(1 for s in stats if s['digit_tokens'] > 0)\\\\n\\\",\\n    \\\"    print(f'  \u0441\u0442\u0440\u043e\u043a \u0441 \u0447\u0438\u0441\u043b\u0430\u043c\u0438: {rows_with_nums}/{len(df)} ({100*rows_with_nums/len(df):.1f}%)')\\\",\\n    \\\"outputs\\\": []\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 15. \u0422\u0435\u0441\u0442\u044b\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u0414\u0432\u0430 \u043c\u043e\u0434\u0443\u043b\u044f \u0442\u0435\u0441\u0442\u043e\u0432: `test_parser.py` (legacy) \u0438 `test_sequence_parser.py` (sequence).\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u0422\u0435\u0441\u0442\u044b sequence parser (\u0438\u0437 test_sequence_parser.py)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def TC(v, m, s):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Helper: \u0441\u043e\u0437\u0434\u0430\u0451\u0442 TokenClass \u0434\u043b\u044f \u0442\u0435\u0441\u0442\u043e\u0432.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    return TokenClass(v, m, s, \\\\\\\"test\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def run_seq_tests():\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u0417\u0430\u043f\u0443\u0441\u043a ~25 \u0442\u0435\u0441\u0442\u043e\u0432 sequence parser.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    tests = []\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # classify() tests\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify unit\\\\\\\", classify(\\\\\\\"\u043f\u044f\u0442\u044c\\\\\\\") is not None and classify(\\\\\\\"\u043f\u044f\u0442\u044c\\\\\\\")[0].value == 5))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify teen\\\\\\\", classify(\\\\\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\\\\\") is not None and classify(\\\\\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\\\\\")[0].value == 14))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify ten\\\\\\\", classify(\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\") is not None and classify(\\\\\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\\\\\")[0].value == 80))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify hundred\\\\\\\", classify(\\\\\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\") is not None and classify(\\\\\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\\\\\")[0].value == 300))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify ordinal\\\\\\\", classify(\\\\\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435\\\\\\\") is not None and classify(\\\\\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435\\\\\\\")[0].subtype == \\\\\\\"ordinal\\\\\\\"))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify non-numeral\\\\\\\", classify(\\\\\\\"\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\\\\\\\") is None))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify ASR error\\\\\\\", classify(\\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\") is not None and classify(\\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\")[0].value == 200))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify multiplier\\\\\\\", classify(\\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\u0438\\\\\\\") is not None and classify(\\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\u0438\\\\\\\")[0].subtype == \\\\\\\"multiplier\\\\\\\"))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify fused\\\\\\\", len(classify(\\\\\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\\\\\") or []) == 2))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"classify vague\\\\\\\", classify(\\\\\\\"\u0442\u044b\u0449\\\\\\\", [\\\\\\\"\u0441\\\\\\\",\\\\\\\"\u0447\u0435\u043c\\\\\\\",\\\\\\\"\u0442\u043e\\\\\\\"]) is not None and classify(\\\\\\\"\u0442\u044b\u0449\\\\\\\", [\\\\\\\"\u0441\\\\\\\",\\\\\\\"\u0447\u0435\u043c\\\\\\\",\\\\\\\"\u0442\u043e\\\\\\\"])[0].subtype == \\\\\\\"vague\\\\\\\"))\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # parse_sequence() tests\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"sum 200+50=250\\\\\\\", parse_sequence([TC(200,3,\\\\\\\"cardinal\\\\\\\"), TC(50,2,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"250\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"enum 200 300\\\\\\\", parse_sequence([TC(200,3,\\\\\\\"cardinal\\\\\\\"), TC(300,3,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"200\\\\\\\",\\\\\\\"300\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"full 2843\\\\\\\", parse_sequence([TC(2,0,\\\\\\\"cardinal\\\\\\\"),TC(1000,4,\\\\\\\"multiplier\\\\\\\"),TC(800,3,\\\\\\\"cardinal\\\\\\\"),TC(40,2,\\\\\\\"cardinal\\\\\\\"),TC(3,0,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"2843\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"two blocks 70M 2M\\\\\\\", parse_sequence([TC(70,2,\\\\\\\"cardinal\\\\\\\"),TC(1000000,5,\\\\\\\"multiplier\\\\\\\"),TC(2,0,\\\\\\\"cardinal\\\\\\\"),TC(1000000,5,\\\\\\\"multiplier\\\\\\\")]) == [\\\\\\\"70000000\\\\\\\",\\\\\\\"2000000\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"standalone 1000\\\\\\\", parse_sequence([TC(1000,4,\\\\\\\"multiplier\\\\\\\")]) == [\\\\\\\"1000\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"zero\\\\\\\", parse_sequence([TC(0,0,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"0\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"zero+7\\\\\\\", parse_sequence([TC(0,0,\\\\\\\"cardinal\\\\\\\"),TC(7,0,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"0\\\\\\\",\\\\\\\"7\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"ordinal 285\\\\\\\", parse_sequence([TC(200,3,\\\\\\\"cardinal\\\\\\\"),TC(80,1,\\\\\\\"cardinal\\\\\\\"),TC(5,0,\\\\\\\"ordinal\\\\\\\")]) == [\\\\\\\"285\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"empty\\\\\\\", parse_sequence([]) == []))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"fused 2000\\\\\\\", parse_sequence([TC(2,0,\\\\\\\"cardinal\\\\\\\"),TC(1000,4,\\\\\\\"multiplier\\\\\\\")]) == [\\\\\\\"2000\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"vague skip\\\\\\\", parse_sequence([TC(1000,4,\\\\\\\"vague\\\\\\\")]) == []))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"dva dva enum\\\\\\\", parse_sequence([TC(2,0,\\\\\\\"cardinal\\\\\\\"),TC(2,0,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"2\\\\\\\",\\\\\\\"2\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"20+5=25\\\\\\\", parse_sequence([TC(20,2,\\\\\\\"cardinal\\\\\\\"),TC(5,0,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"25\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"5\u00d71000+200=5200\\\\\\\", parse_sequence([TC(5,0,\\\\\\\"cardinal\\\\\\\"),TC(1000,4,\\\\\\\"multiplier\\\\\\\"),TC(200,3,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"5200\\\\\\\"]))\\\\n\\\",\\n    \\\"    tests.append((\\\\\\\"20 30 enum\\\\\\\", parse_sequence([TC(20,2,\\\\\\\"cardinal\\\\\\\"),TC(30,2,\\\\\\\"cardinal\\\\\\\")]) == [\\\\\\\"20\\\\\\\",\\\\\\\"30\\\\\\\"]))\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    passed = sum(1 for _, ok in tests if ok)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"Sequence parser tests: {passed}/{len(tests)} \u043f\u0440\u043e\u0439\u0434\u0435\u043d\u043e\\\\\\\")\\\\n\\\",\\n    \\\"    for name, ok in tests:\\\\n\\\",\\n    \\\"        status = '\u2713' if ok else '\u2717'\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  {status} {name}\\\\\\\")\\\\n\\\",\\n    \\\"    return passed == len(tests)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def run_legacy_tests():\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\u0417\u0430\u043f\u0443\u0441\u043a 9 \u0442\u0435\u0441\u0442\u043e\u0432 legacy parser.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    tests = [\\\\n\\\",\\n    \\\"        (\\\\\\\"sum 200+50=250\\\\\\\", parse_number_group([(200,3,False,False),(50,2,False,False)]) == [\\\\\\\"250\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"enum 200 300\\\\\\\", parse_number_group([(200,3,False,False),(300,3,False,False)]) == [\\\\\\\"200\\\\\\\",\\\\\\\"300\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"full 2843\\\\\\\", parse_number_group([(2,0,False,False),(1000,4,True,False),(800,3,False,False),(40,2,False,False),(3,0,False,False)]) == [\\\\\\\"2843\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"two blocks 70M 2M\\\\\\\", parse_number_group([(70,2,False,False),(1000000,5,True,False),(2,0,False,False),(1000000,5,True,False)]) == [\\\\\\\"70000000\\\\\\\",\\\\\\\"2000000\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"standalone 1000\\\\\\\", parse_number_group([(1000,4,True,False)]) == [\\\\\\\"1000\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"zero\\\\\\\", parse_number_group([(0,0,False,False)]) == [\\\\\\\"0\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"zero+7\\\\\\\", parse_number_group([(0,0,False,False),(7,0,False,False)]) == [\\\\\\\"0\\\\\\\",\\\\\\\"7\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"ordinal 285\\\\\\\", parse_number_group([(200,3,False,False),(80,1,False,False),(5,0,False,True)]) == [\\\\\\\"285\\\\\\\"]),\\\\n\\\",\\n    \\\"        (\\\\\\\"empty\\\\\\\", parse_number_group([]) == []),\\\\n\\\",\\n    \\\"    ]\\\\n\\\",\\n    \\\"    passed = sum(1 for _, ok in tests if ok)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"Legacy parser tests: {passed}/{len(tests)} \u043f\u0440\u043e\u0439\u0434\u0435\u043d\u043e\\\\\\\")\\\\n\\\",\\n    \\\"    for name, ok in tests:\\\\n\\\",\\n    \\\"        status = '\u2713' if ok else '\u2717'\\\\n\\\",\\n    \\\"        print(f\\\\\\\"  {status} {name}\\\\\\\")\\\\n\\\",\\n    \\\"    return passed == len(tests)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=\\\\\\\" * 60)\\\\n\\\",\\n    \\\"all_ok = run_seq_tests()\\\\n\\\",\\n    \\\"print()\\\\n\\\",\\n    \\\"all_ok = run_legacy_tests() and all_ok\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"if all_ok:\\\\n\\\",\\n    \\\"    print(f\\\\\\\"\\\\\\\\n{'=' * 60}\\\\\\\\n{'':>15}\u0412\u0421\u0415 \u0422\u0415\u0421\u0422\u042b \u041f\u0420\u041e\u0419\u0414\u0415\u041d\u042b \u2713\\\\\\\\n{'=' * 60}\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 15.1 \u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0442\u0435\u0441\u0442\u043e\u0432\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**test_parser.py** (9 \u0442\u0435\u0441\u0442\u043e\u0432):\\\\n\\\",\\n    \\\"- `test_sum_hundreds_tens` \u2014 \u0434\u0432\u0435\u0441\u0442\u0438+\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 = 250\\\\n\\\",\\n    \\\"- `test_enumeration_same_magnitude` \u2014 \u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430 = 200 300\\\\n\\\",\\n    \\\"- `test_sum_with_thousand_multiplier` \u2014 2843\\\\n\\\",\\n    \\\"- `test_two_multiplier_blocks` \u2014 70M 2M (\u0434\u0432\u0430 \u0431\u043b\u043e\u043a\u0430)\\\\n\\\",\\n    \\\"- `test_standalone_thousand` \u2014 1000 \u043e\u0434\u0438\u043d\\\\n\\\",\\n    \\\"- `test_zero` \u2014 \u043d\u043e\u043b\u044c\\\\n\\\",\\n    \\\"- `test_zero_and_seven` \u2014 0 \u0438 7\\\\n\\\",\\n    \\\"- `test_ordinal_in_compound` \u2014 285-\u0439\\\\n\\\",\\n    \\\"- `test_empty` \u2014 \u043f\u0443\u0441\u0442\u043e\u0439 \u0441\u043f\u0438\u0441\u043e\u043a\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**test_sequence_parser.py** (~25 \u0442\u0435\u0441\u0442\u043e\u0432):\\\\n\\\",\\n    \\\"- 10 \u0442\u0435\u0441\u0442\u043e\u0432 `classify()` \u043d\u0430 \u0432\u0441\u0435 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0438 \u0442\u043e\u043a\u0435\u043d\u043e\u0432\\\\n\\\",\\n    \\\"- ~15 \u0442\u0435\u0441\u0442\u043e\u0432 `parse_sequence()` \u043d\u0430 \u0440\u0430\u0437\u043d\u044b\u0435 \u043a\u043e\u043c\u0431\u0438\u043d\u0430\u0446\u0438\u0438 sum/enum/mult\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u0417\u0430\u043f\u0443\u0441\u043a:** `pytest tests/` \u0438\u043b\u0438 `python -m pytest tests/`\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 16. \u0413\u0438\u0431\u0440\u0438\u0434\u043d\u044b\u0439 \u043f\u043e\u0434\u0445\u043e\u0434 (hybrid.py)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041f\u0430\u0440\u0441\u0435\u0440 + ruT5-small fallback: \u043a\u043e\u0433\u0434\u0430 rule-based \u043f\u0430\u0440\u0441\u0435\u0440 \u043d\u0435 \u0443\u0432\u0435\u0440\u0435\u043d \u0432 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0435,\\\\n\\\",\\n    \\\"\u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0430\u0435\u0442\u0441\u044f \u043d\u0435\u0439\u0440\u043e\u0441\u0435\u0442\u044c \u0434\u043b\u044f \u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u0438 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0430.\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u2500\u2500 Confidence estimation \u2500\u2500\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"_ORD_SUFFIXES = (\\\\\\\"\u044b\u0439\\\\\\\", \\\\\\\"\u0438\u0439\\\\\\\", \\\\\\\"\u043e\u0439\\\\\\\", \\\\\\\"\u0430\u044f\\\\\\\", \\\\\\\"\u044c\u044f\\\\\\\", \\\\\\\"\u043e\u0435\\\\\\\", \\\\\\\"\u044c\u0435\\\\\\\", \\\\\\\"\u044b\u0435\\\\\\\", \\\\\\\"\u044c\u0438\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u0433\u043e\\\\\\\", \\\\\\\"\u0435\u0433\u043e\\\\\\\", \\\\\\\"\u043e\u043c\u0443\\\\\\\", \\\\\\\"\u0435\u043c\u0443\\\\\\\", \\\\\\\"\u044b\u043c\\\\\\\", \\\\\\\"\u0438\u043c\u0438\\\\\\\", \\\\\\\"\u044b\u043c\u0438\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u043e\u043c\\\\\\\", \\\\\\\"\u0435\u043c\\\\\\\", \\\\\\\"\u044b\u0445\\\\\\\", \\\\\\\"\u044b\u0445\\\\\\\", \\\\\\\"\u0438\u0445\\\\\\\", \\\\\\\"\u0443\u044e\\\\\\\", \\\\\\\"\u044e\\\\\\\", \\\\\\\"\u0435\u0439\\\\\\\")\\\\n\\\",\\n    \\\"_ORD_ROOTS = (\\\\\\\"\u043f\u0435\u0440\u0432\\\\\\\", \\\\\\\"\u0432\u0442\u043e\u0440\\\\\\\", \\\\\\\"\u0442\u0440\u0435\u0442\\\\\\\", \\\\\\\"\u0447\u0435\u0442\u0432\u0435\u0440\u0442\\\\\\\", \\\\\\\"\u043f\u044f\u0442\\\\\\\", \\\\\\\"\u0448\u0435\u0441\u0442\\\\\\\", \\\\\\\"\u0441\u0435\u0434\u044c\u043c\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0432\u043e\u0441\u044c\u043c\\\\\\\", \\\\\\\"\u0434\u0435\u0432\u044f\u0442\\\\\\\", \\\\\\\"\u0434\u0435\u0441\u044f\u0442\\\\\\\")\\\\n\\\",\\n    \\\"_NON_ORD_CONF = {\\\\\\\"\u043a\u0430\u043a\u043e\u0439\\\\\\\", \\\\\\\"\u0442\u0430\u043a\u043e\u0439\\\\\\\", \\\\\\\"\u0434\u0440\u0443\u0433\u043e\u0439\\\\\\\", \\\\\\\"\u043b\u044e\u0431\u043e\u0439\\\\\\\", \\\\\\\"\u043a\u0430\u0436\u0434\u043e\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0441\u0430\u043c\u043e\u0439\\\\\\\", \\\\\\\"\u0441\u0430\u043c\u044b\u0439\\\\\\\", \\\\\\\"\u0441\u0430\u043c\u043e\u0435\\\\\\\", \\\\\\\"\u043d\u043e\u0432\u0430\u044f\\\\\\\", \\\\\\\"\u043d\u043e\u0432\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u0440\u043e\u0441\u0442\u043e\u0439\\\\\\\", \\\\\\\"\u0433\u043b\u0430\u0432\u043d\u044b\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0431\u043e\u043b\u044c\u0448\u043e\u0439\\\\\\\", \\\\\\\"\u0445\u043e\u0440\u043e\u0448\u0438\u0439\\\\\\\", \\\\\\\"\u043f\u043b\u043e\u0445\u043e\u0439\\\\\\\", \\\\\\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0432\u044b\u0441\u043e\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043d\u0438\u0437\u043a\u0438\u0439\\\\\\\", \\\\\\\"\u043d\u0443\u0436\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439\\\\\\\", \\\\\\\"\u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0439\\\\\\\",\\\\n\\\",\\n    \\\"    \\\\\\\"\u0440\u0430\u0437\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0446\u0435\u043b\u044b\u0439\\\\\\\", \\\\\\\"\u043f\u043e\u043b\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0432\u0430\u0436\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0439\\\\\\\", \\\\\\\"\u0432\u0442\u043e\u0440\u043e\u0439\\\\\\\"}\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"def _parser_confidence(text, pred):\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    \u041e\u0446\u0435\u043d\u0438\u0432\u0430\u0435\u0442 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043f\u0430\u0440\u0441\u0435\u0440\u0430 (0.0 \u2014 1.0).\\\\n\\\",\\n    \\\"    \u0425\u0430\u0440\u0434\u043a\u043e\u0434\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 12 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0445 \u043e\u0448\u0438\u0431\u043e\u043a \u043f\u0430\u0440\u0441\u0435\u0440\u0430.\\\\n\\\",\\n    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n    \\\"    score = 1.0\\\\n\\\",\\n    \\\"    tokens = text.lower().split()\\\\n\\\",\\n    \\\"    pred_tokens = pred.lower().split()\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # \\\\\\\"\u0442\u044b\u0449\\\\\\\"/\\\\\\\"\u0442\u044b\u0449\u0430\\\\\\\" \u2014 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0438\u0442\u0441\u044f \u0432 1000 \u0432\u043c\u0435\u0441\u0442\u043e \\\\\\\"\u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u0442\u044b\u0441\u044f\u0447\u0430\\\\\\\"\\\\n\\\",\\n    \\\"    if any(w in (\\\\\\\"\u0442\u044b\u0449\\\\\\\", \\\\\\\"\u0442\u044b\u0449\u0430\\\\\\\") for w in tokens):\\\\n\\\",\\n    \\\"        score -= 0.4\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # \\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\" \u2014 \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432: 200 350000 \u0432\u043c\u0435\u0441\u0442\u043e 235000\\\\n\\\",\\n    \\\"    if \\\\\\\"\u0434\u0432\u0435\u0441\u0438\\\\\\\" in tokens:\\\\n\\\",\\n    \\\"        nums = [int(x) for x in re.findall(r'\\\\\\\\d+', pred)]\\\\n\\\",\\n    \\\"        for i in range(len(nums) - 1):\\\\n\\\",\\n    \\\"            if nums[i] <= 300 and nums[i + 1] >= 1000:\\\\n\\\",\\n    \\\"                score -= 0.3\\\\n\\\",\\n    \\\"                break\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # \u041f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435 \u0432 \u0432\u044b\u0432\u043e\u0434\u0435 \u2014 \u043d\u0435 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b\\\\n\\\",\\n    \\\"    for w in pred_tokens:\\\\n\\\",\\n    \\\"        wc = w.strip('.,!?;:()[]{}\u00ab\u00bb\\\\\\\"').replace('\u0451','\u0435').replace('\u0401','\u0415').lower()\\\\n\\\",\\n    \\\"        if wc in _NON_ORD_CONF:\\\\n\\\",\\n    \\\"            continue\\\\n\\\",\\n    \\\"        if wc.endswith(_ORD_SUFFIXES):\\\\n\\\",\\n    \\\"            for r in _ORD_ROOTS:\\\\n\\\",\\n    \\\"                if r in wc:\\\\n\\\",\\n    \\\"                    score -= 0.3\\\\n\\\",\\n    \\\"                    break\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # \\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\\\\\\\"/\\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\u0438\\\\\\\" \u2014 \u043d\u0435 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b\\\\n\\\",\\n    \\\"    if any(w in (\\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\\\\\\\", \\\\\\\"\u0442\u044b\u0441\u044f\u0447\u0430\u043c\u0438\\\\\\\") for w in pred_tokens):\\\\n\\\",\\n    \\\"        score -= 0.3\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    # \u0421\u043b\u043e\u0432\u043e \u0441 \u043f\u0440\u0435\u0444\u0438\u043a\u0441\u043e\u043c \u0447\u0438\u0441\u043b\u0430 + \\\\\\\"\u0442\u044b\u0441\u044f\u0447\\\\\\\" \u2014 compound\\\\n\\\",\\n    \\\"    _number_prefixes = {\\\\\\\"\u0434\u0432\u0435\\\\\\\", \\\\\\\"\u0442\u0440\u0438\\\\\\\", \\\\\\\"\u0447\u0435\u0442\u044b\u0440\u0435\\\\\\\", \\\\\\\"\u043f\u044f\u0442\u044c\\\\\\\",\\\\n\\\",\\n    \\\"        \\\\\\\"\u0448\u0435\u0441\u0442\\\\\\\", \\\\\\\"\u0441\u0435\u043c\\\\\\\", \\\\\\\"\u0432\u043e\u0441\u0435\u043c\\\\\\\", \\\\\\\"\u0434\u0435\u0432\u044f\u0442\\\\\\\", \\\\\\\"\u0434\u0435\u0441\u044f\u0442\\\\\\\"}\\\\n\\\",\\n    \\\"    for w in tokens:\\\\n\\\",\\n    \\\"        if \\\\\\\"\u0442\u044b\u0441\u044f\u0447\\\\\\\" in w:\\\\n\\\",\\n    \\\"            for pfx in _number_prefixes:\\\\n\\\",\\n    \\\"                if w.startswith(pfx) and len(w) > len(pfx) + 3:\\\\n\\\",\\n    \\\"                    score -= 0.3\\\\n\\\",\\n    \\\"                    break\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"    return max(0.1, min(1.0, score))\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(\\\\\\\"=== Confidence estimation ===\\\\\\\")\\\\n\\\",\\n    \\\"test_conf = [\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\", \\\\\\\"250 \u0440\u0443\u0431\u043b\u0435\u0439\\\\\\\"),\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u0435\u0441\u0438 \u0442\u0440\u0438\u0441\u0442\u0430 \u0442\u044b\u0441\u044f\u0447\\\\\\\", \\\\\\\"200 300000\\\\\\\"),  # should be 230000\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0442\u044b\u0449 \u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\\\\\", \\\\\\\"1000 500\\\\\\\"),  # vague\\\\n\\\",\\n    \\\"    (\\\\\\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u043f\u044f\u0442\u044b\u0439\\\\\\\", \\\\\\\"250\\\\\\\"),  # ordinal not converted\\\\n\\\",\\n    \\\"]\\\\n\\\",\\n    \\\"for text, pred in test_conf:\\\\n\\\",\\n    \\\"    conf = _parser_confidence(text, pred)\\\\n\\\",\\n    \\\"    print(f\\\\\\\"  confidence={conf:.2f} | IN: {text:30s} \u2192 OUT: {pred}\\\\\\\")\\\\n\\\",\\n    \\\"    if conf < 0.75:\\\\n\\\",\\n    \\\"        print(f\\\\\\\"    \u2192 LOW CONFIDENCE: \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f T5 fallback\\\\\\\")\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n{'=' * 60}\\\\\\\")\\\\n\\\",\\n    \\\"print(\\\\\\\"\u0413\u0438\u0431\u0440\u0438\u0434\u043d\u0430\u044f \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f (\u043f\u0440\u0438 \u043d\u0430\u043b\u0438\u0447\u0438\u0438 \u043c\u043e\u0434\u0435\u043b\u0438):\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"{'=' * 60}\\\\\\\")\\\\n\\\",\\n    \\\"print('''\\\\n\\\",\\n    \\\"def hybrid_normalize(text):\\\\n\\\",\\n    \\\"    pred = normalize_text(text)\\\\n\\\",\\n    \\\"    if _parser_confidence(text, pred) >= 0.75:\\\\n\\\",\\n    \\\"        return pred\\\\n\\\",\\n    \\\"    # T5 fallback (lazy load)\\\\n\\\",\\n    \\\"    if HYBRID_USE_T5 == \\\\\\\"1\\\\\\\" and model_loaded:\\\\n\\\",\\n    \\\"        t5 = _t5_generate(text)\\\\n\\\",\\n    \\\"        if t5 and t5 != text:\\\\n\\\",\\n    \\\"            return t5\\\\n\\\",\\n    \\\"    return pred\\\\n\\\",\\n    \\\"''')\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print(f\\\\\\\"\\\\\\\\n\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0433\u0438\u0431\u0440\u0438\u0434\u0430: 94.4% (\u043f\u0440\u043e\u0442\u0438\u0432 97.6% \u0447\u0438\u0441\u0442\u043e\u0433\u043e \u043f\u0430\u0440\u0441\u0435\u0440\u0430)\\\\\\\")\\\\n\\\",\\n    \\\"print(f\\\\\\\"T5 \u043d\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u0442\u0441\u044f \u2014 \u043d\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0430 \u043d\u0430 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0445 ASR-\u043f\u0430\u0442\u0442\u0435\u0440\u043d\u0430\u0445.\\\\\\\")\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 16.1 \u041f\u0440\u0430\u0432\u0438\u043b\u0430 confidence\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u041f\u0440\u0438\u0437\u043d\u0430\u043a | \u0412\u0435\u0441 | \u041f\u043e\u044f\u0441\u043d\u0435\u043d\u0438\u0435 |\\\\n\\\",\\n    \\\"|---|---|---|\\\\n\\\",\\n    \\\"| has \\\\\\\"\u0442\u044b\u0449\\\\\\\"/\\\\\\\"\u0442\u044b\u0449\u0430\\\\\\\" | **-0.4** | \u041f\u0430\u0440\u0441\u043