 \\\"\u044c\u0435\\\", \\\"\u044b\u0435\\\", \\\"\u044c\u0438\\\",\\n\",\n    \"    \\\"\u043e\u0433\u043e\\\", \\\"\u0435\u0433\u043e\\\", \\\"\u043e\u043c\u0443\\\", \\\"\u0435\u043c\u0443\\\", \\\"\u044b\u043c\\\", \\\"\u0438\u043c\u0438\\\", \\\"\u044b\u043c\u0438\\\",\\n\",\n    \"    \\\"\u043e\u043c\\\", \\\"\u0435\u043c\\\", \\\"\u044b\u0445\\\", \\\"\u044b\u0445\\\", \\\"\u0438\u0445\\\", \\\"\u0443\u044e\\\", \\\"\u044e\\\", \\\"\u0435\u0439\\\"}\\n\",\n    \"_NON_ORDINALS = {\\\"\u043a\u0430\u043a\u043e\u0439\\\", \\\"\u0442\u0430\u043a\u043e\u0439\\\", \\\"\u0434\u0440\u0443\u0433\u043e\u0439\\\", \\\"\u043b\u044e\u0431\u043e\u0439\\\", \\\"\u043a\u0430\u0436\u0434\u043e\u0439\\\",\\n\",\n    \"    \\\"\u0441\u0430\u043c\u043e\u0439\\\", \\\"\u0441\u0430\u043c\u044b\u0439\\\", \\\"\u0441\u0430\u043c\u043e\u0435\\\", \\\"\u043d\u043e\u0432\u0430\u044f\\\", \\\"\u043d\u043e\u0432\u044b\u0439\\\", \\\"\u043f\u0440\u043e\u0441\u0442\u043e\u0439\\\", \\\"\u0433\u043b\u0430\u0432\u043d\u044b\u0439\\\",\\n\",\n    \"    \\\"\u0431\u043e\u043b\u044c\u0448\u043e\u0439\\\", \\\"\u0445\u043e\u0440\u043e\u0448\u0438\u0439\\\", \\\"\u043f\u043b\u043e\u0445\u043e\u0439\\\", \\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0439\\\", \\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f\\\",\\n\",\n    \"    \\\"\u0432\u044b\u0441\u043e\u043a\u0438\u0439\\\", \\\"\u043d\u0438\u0437\u043a\u0438\u0439\\\", \\\"\u043d\u0443\u0436\u043d\u044b\u0439\\\", \\\"\u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439\\\", \\\"\u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0439\\\",\\n\",\n    \"    \\\"\u0440\u0430\u0437\u043d\u044b\u0439\\\", \\\"\u0446\u0435\u043b\u044b\u0439\\\", \\\"\u043f\u043e\u043b\u043d\u044b\u0439\\\", \\\"\u0432\u0430\u0436\u043d\u044b\u0439\\\", \\\"\u0442\u043e\u0447\u043d\u044b\u0439\\\", \\\"\u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439\\\", \\\"\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0439\\\",\\n\",\n    \"    \\\"\u043e\u0431\u044b\u0447\u043d\u044b\u0439\\\", \\\"\u043f\u043e\u0434\u043e\u0431\u043d\u044b\u0439\\\", \\\"\u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\",\\n\",\n    \"    \\\"\u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439\\\", \\\"\u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043f\u0440\u0435\u0436\u043d\u0438\u0439\\\",\\n\",\n    \"    \\\"\u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\",\\n\",\n    \"    \\\"\u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\",\\n\",\n    \"    \\\"\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u044e\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0441\u043a\u0438\u0439\\\",\\n\",\n    \"    \\\"\u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u044b\u0439\\\", \\\"\u043d\u0430\u0443\u0447\u043d\u044b\u0439\\\",\\n\",\n    \"    \\\"\u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0439\\\", \\\"\u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0439\\\", \\\"\u0432\u0442\u043e\u0440\u043e\u0439\\\"}\\n\",\n    \"_VAGUE_MARKERS = {\\\"\u0432\u044b\u0448\u0435\\\", \\\"\u043d\u0438\u0436\u0435\\\", \\\"\u043e\u043a\u043e\u043b\u043e\\\", \\\"\u043f\u043e\u0447\u0442\u0438\\\"}\\n\",\n    \"_MULTIPLIER_SET = set()\\n\",\n    \"for d in (THOUSANDS, MILLIONS, BILLIONS): _MULTIPLIER_SET.update(d.keys())\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"3ea56ab9\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def _is_vague_context(prev_tokens):\\n\",\n    \"    if len(prev_tokens) < 1: return False\\n\",\n    \"    prev = prev_tokens[-1]\\n\",\n    \"    if prev in _VAGUE_MARKERS: return True\\n\",\n    \"    if len(prev_tokens) >= 3 and prev_tokens[-3:] == [\\\"\u0441\\\",\\\"\u0447\u0435\u043c\\\",\\\"\u0442\u043e\\\"]: return True\\n\",\n    \"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\"\u0433\u0434\u0435\\\",\\\"\u0442\u043e\\\"]: return True\\n\",\n    \"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\"\u0441\\\",\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\"]: return True\\n\",\n    \"    return False\\n\",\n    \"\\n\",\n    \"def _match_root(word):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    for root, val, mag, is_mult in _NUMERIC_ROOTS:\\n\",\n    \"        idx = w.find(root)\\n\",\n    \"        if idx == -1 or idx != 0: continue\\n\",\n    \"        suffix = w[len(root):]\\n\",\n    \"        if suffix in _INFLECTION_SUFFIXES:\\n\",\n    \"            return val, mag, is_mult, suffix\\n\",\n    \"    return None\\n\",\n    \"\\n\",\n    \"def _classify_ordinal(word, val, mag, suffix):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    if w in _NON_ORDINALS or w in NUMERAL_DICT: return None\\n\",\n    \"    if suffix in _ORDINAL_SUFFIXES:\\n\",\n    \"        return TokenClass(val, mag, \\\"ordinal\\\", word)\\n\",\n    \"    return None\\n\",\n    \"\\n\",\n    \"def _find_fused_compound(word):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    for i in range(2, len(w)):\\n\",\n    \"        p1, p2 = w[:i], w[i:]\\n\",\n    \"        r1, r2 = _match_root(p1), _match_root(p2)\\n\",\n    \"        if r1 and r2:\\n\",\n    \"            v1, m1, mult1, _ = r1\\n\",\n    \"            v2, m2, mult2, _ = r2\\n\",\n    \"            if mult2 and m1 <= 3 and m2 >= 4:\\n\",\n    \"                return [TokenClass(v1, m1, \\\"cardinal\\\", word), TokenClass(v2, m2, \\\"multiplier\\\", word)]\\n\",\n    \"    return None\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"da5008ae\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def classify(word, prev_tokens=None):\\n\",\n    \"    if not word or len(word) < 2: return None\\n\",\n    \"    w = word.lower()\\n\",\n    \"    if w in (\\\"\u0442\u044b\u0449\\\",\\\"\u0442\u044b\u0449\u0430\\\") and prev_tokens and _is_vague_context(prev_tokens):\\n\",\n    \"        return [TokenClass(1000, 4, \\\"vague\\\", word)]\\n\",\n    \"    if w in NUMERAL_DICT:\\n\",\n    \"        val, mag = NUMERAL_DICT[w]\\n\",\n    \"        return [TokenClass(val, mag, \\\"multiplier\\\" if w in _MULTIPLIER_SET else \\\"cardinal\\\", word)]\\n\",\n    \"    if w in ORDINAL_SET:\\n\",\n    \"        return [TokenClass(int(ORDINALS[w]), 0, \\\"ordinal\\\", word)]\\n\",\n    \"    if w in ASR_ERRORS:\\n\",\n    \"        c = ASR_ERRORS[w]\\n\",\n    \"        if c in NUMERAL_DICT:\\n\",\n    \"            val, mag = NUMERAL_DICT[c]\\n\",\n    \"            return [TokenClass(val, mag, \\\"multiplier\\\" if c in _MULTIPLIER_SET else \\\"cardinal\\\", word)]\\n\",\n    \"        if c in ORDINAL_SET:\\n\",\n    \"            return [TokenClass(int(ORDINALS[c]), 0, \\\"ordinal\\\", word)]\\n\",\n    \"    match = _match_root(w)\\n\",\n    \"    if match:\\n\",\n    \"        val, mag, is_mult, suffix = match\\n\",\n    \"        ord = _classify_ordinal(word, val, mag, suffix)\\n\",\n    \"        if ord: return [ord]\\n\",\n    \"        return [TokenClass(val, mag, \\\"multiplier\\\" if is_mult else \\\"cardinal\\\", word)]\\n\",\n    \"    fused = _find_fused_compound(word)\\n\",\n    \"    if fused: return fused\\n\",\n    \"    return None\\n\",\n    \"\\n\",\n    \"print(\\\"=== classify() tests ===\\\")\\n\",\n    \"for w, exp in [(\\\"\u043f\u044f\u0442\u044c\\\",5),(\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",14),(\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",80),\\n\",\n    \"               (\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\",300),(\\\"\u0442\u044b\u0441\u044f\u0447\u0430\\\",1000),(\\\"\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\\\",None),\\n\",\n    \"               (\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435\\\",20),(\\\"\u0434\u0432\u0435\u0441\u0438\\\",200)]:\\n\",\n    \"    tc = classify(w)\\n\",\n    \"    if exp is None: ok = tc is None\\n\",\n    \"    else: ok = tc and tc[0].value == exp\\n\",\n    \"    print(f\\\"  {chr(10003) if ok else chr(10007)} {w} -> {tc}\\\")\\n\",\n    \"print(f\\\"  {chr(10003) if classify('\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438') and len(classify('\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438'))==2 else chr(10007)} \u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 fused\\\")\\n\",\n    \"print(f\\\"  {chr(10003) if classify('\u0442\u044b\u0449',['\u0441','\u0447\u0435\u043c','\u0442\u043e']) and classify('\u0442\u044b\u0449',['\u0441','\u0447\u0435\u043c','\u0442\u043e'])[0].subtype=='vague' else chr(10007)} \u0442\u044b\u0449 vague\\\")\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"68fae262\",\n   \"metadata\": {},\n   \"source\": [\n    \"**\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0442\u0435\u0441\u0442\u043e\u0432 \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u0430:**\\n\",\n    \"\\n\",\n    \"| \u0421\u043b\u043e\u0432\u043e | \u0421\u0442\u0430\u0442\u0443\u0441 | \u041a\u043b\u0430\u0441\u0441 |\\n\",\n    \"|---|---|---|\\n\",\n    \"| \u043f\u044f\u0442\u044c | \u2713 | cardinal 5 |\\n\",\n    \"| \u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c | \u2713 | cardinal 14 |\\n\",\n    \"| \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 | \u2713 | cardinal 80 |\\n\",\n    \"| \u0442\u0440\u0438\u0441\u0442\u0430 | \u2713 | cardinal 300 |\\n\",\n    \"| \u0442\u044b\u0441\u044f\u0447\u0430 | \u2713 | multiplier 1000 |\\n\",\n    \"| \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435 | \u2713 | ordinal 20 |\\n\",\n    \"| \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440 | \u2713 | None |\\n\",\n    \"| \u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 | \u2713 | fused 2+1000 |\\n\",\n    \"| \u0442\u044b\u0449 (\u0441 \u0447\u0435\u043c \u0442\u043e) | \u2713 | vague |\\n\",\n    \"| \u0434\u0432\u0435\u0441\u0438 | \u2713 | ASR -> 200 |\\n\",\n    \"\\n\",\n    \"\u0412\u0441\u0435 10 \u0442\u0435\u0441\u0442\u043e\u0432 \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442. \u041a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u0435\u0442 \u0432\u0441\u0435 6 \u0442\u0438\u043f\u043e\u0432 \u0442\u043e\u043a\u0435\u043d\u043e\u0432.\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"e0ec4f48\",\n   \"metadata\": {},\n   \"source\": [\n    \"---\\n\",\n    \"## 4. Sequence Parser (\u043d\u043e\u0432\u044b\u0439 \u043f\u0443\u0442\u044c)\\n\",\n    \"\\n\",\n    \"State machine \u043d\u0430\u0434 `list[TokenClass]` \u0432\u043c\u0435\u0441\u0442\u043e `parse_number_group()`.\\n\",\n    \"\\n\",\n    \"**\u0421\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u044f:** START -> ACCUM -> MULTIPLY -> ACCUM / ENUM -> FLUSH -> START -> ORDINAL -> FLUSH\\n\",\n    \"\\n\",\n    \"**\u041f\u0440\u0430\u0432\u0438\u043b\u0430:**\\n\",\n    \"\\n\",\n    \"| Token[i] vs Token[i-1] | \u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 |\\n\",\n    \"|---|---|\\n\",\n    \"| subtype=vague | \u041f\u0440\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u044c (\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043a\u0430\u043a \u0442\u0435\u043a\u0441\u0442) |\\n\",\n    \"| subtype=multiplier | `compound += (current or 1) * val` |\\n\",\n    \"| subtype=ordinal | \u0424\u0438\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c current \u0441 ordinal \u0441\u0443\u0444\u0444\u0438\u043a\u0441\u043e\u043c |\\n\",\n    \"| mag < prev_mag | \u0421\u0443\u043c\u043c\u0430: `current += val` |\\n\",\n    \"| mag == prev_mag (\u043e\u0431\u0430 < 3) | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: flush, start new |\\n\",\n    \"| mag >= prev_mag (\u043e\u0431\u0430 == 3) | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\\\" -> 200 300 |\\n\",\n    \"| same mult_mag | Enum: \\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432...\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\\\" -> 7e7 2e6 |\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"62617952\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def _flush(compound, current, result, force=False):\\n\",\n    \"    total = compound + current\\n\",\n    \"    if total > 0 or force:\\n\",\n    \"        result.append(str(total))\\n\",\n    \"\\n\",\n    \"def parse_sequence(classes):\\n\",\n    \"    if not classes: return []\\n\",\n    \"    compound = current = 0\\n\",\n    \"    last_mag = last_mult_mag = -1\\n\",\n    \"    has_zero = False\\n\",\n    \"    result = []\\n\",\n    \"    for idx, tc in enumerate(classes):\\n\",\n    \"        if tc.subtype == \\\"vague\\\": continue\\n\",\n    \"        if tc.value == 0: has_zero = True\\n\",\n    \"        if tc.subtype == \\\"multiplier\\\":\\n\",\n    \"            if last_mult_mag == tc.mag:\\n\",\n    \"                _flush(compound, 0, result, force=has_zero)\\n\",\n    \"                compound = current * tc.value if current > 0 else tc.value\\n\",\n    \"                current = 0\\n\",\n    \"            else:\\n\",\n    \"                multiplied = current * tc.value if current > 0 else tc.value\\n\",\n    \"                compound += multiplied\\n\",\n    \"                current = 0\\n\",\n    \"            last_mult_mag, last_mag = tc.mag, -1\\n\",\n    \"            continue\\n\",\n    \"        if last_mag == -1:\\n\",\n    \"            current, last_mag = tc.value, tc.mag\\n\",\n    \"            continue\\n\",\n    \"        if tc.mag < last_mag:\\n\",\n    \"            if tc.mag <= 1 and idx < len(classes) - 1:\\n\",\n    \"                nxt = classes[idx + 1]\\n\",\n    \"                if nxt.subtype not in (\\\"multiplier\\\",\\\"vague\\\",\\\"ordinal\\\") and nxt.mag <= 1:\\n\",\n    \"                    _flush(compound, current, result, force=has_zero)\\n\",\n    \"                    compound, current = 0, tc.value\\n\",\n    \"                    last_mag, last_mult_mag = tc.mag, -1\\n\",\n    \"                    continue\\n\",\n    \"            current += tc.value\\n\",\n    \"            last_mag = tc.mag\\n\",\n    \"        else:\\n\",\n    \"            _flush(compound, current, result, force=has_zero)\\n\",\n    \"            compound, current = 0, tc.value\\n\",\n    \"            last_mag, last_mult_mag = tc.mag, -1\\n\",\n    \"    _flush(compound, current, result, force=has_zero)\\n\",\n    \"    if not result and has_zero: return [\\\"0\\\"]\\n\",\n    \"    return result\\n\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"919233b3\",\n   \"metadata\": {},\n   \"source\": [\n    \"**\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0442\u0435\u0441\u0442\u043e\u0432 sequence parser:**\\n\",\n    \"\\n\",\n    \"| \u0422\u0435\u0441\u0442 | \u0421\u0442\u0430\u0442\u0443\u0441 |\\n\",\n    \"|---|---|\\n\",\n    \"| 200+50=250 | \u2713 |\\n\",\n    \"| 200 300 (enum) | \u2713 |\\n\",\n    \"| 2843 (2x1000+800+40+3) | \u2713 |\\n\",\n    \"| 70M 2M (\u0434\u0432\u0430 \u0431\u043b\u043e\u043a\u0430) | \u2713 (\u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d) |\\n\",\n    \"| 285 (ordinal suffix) | \u2713 |\\n\",\n    \"\\n\",\n    \"\u0422\u0435\u0441\u0442 70M 2M \u0440\u0430\u043d\u0435\u0435 \u0432\u044b\u0434\u0430\u0432\u0430\u043b \u043e\u0448\u0438\u0431\u043a\u0443 70000002 \u0438\u0437-\u0437\u0430 \u043d\u0435\u0432\u0435\u0440\u043d\u043e\u0433\u043e compound+current \u043f\u0440\u0438 flush.\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"494af144\",\n   \"metadata\": {},\n   \"source\": [\n    \"---\\n\",\n    \"## 5. Legacy Parser (\u0441\u0442\u0430\u0440\u044b\u0439 \u043f\u0443\u0442\u044c)\\n\",\n    \"\\n\",\n    \"Mag-based parser: \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u0435\u0442 \u0441\u0443\u043c\u043c\u0443 \u0438 \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 \u043f\u043e \u0440\u0430\u0437\u0440\u044f\u0434\u0430\u043c \u0441\u043e\u0441\u0435\u0434\u043d\u0438\u0445 \u0441\u043b\u043e\u0432.\\n\",\n    \"\\n\",\n    \"**\u041b\u043e\u0433\u0438\u043a\u0430:**\\n\",\n    \"- \u0420\u0430\u0437\u0440\u044f\u0434 \u043f\u043e\u043d\u0438\u0436\u0430\u0435\u0442\u0441\u044f (mag 3 -> 2) -> \u0441\u0443\u043c\u043c\u0430: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\" = 200+50 = 250\\n\",\n    \"- \u0420\u0430\u0437\u0440\u044f\u0434 \u043d\u0435 \u043c\u0435\u043d\u044f\u0435\u0442\u0441\u044f (mag 3 -> 3) -> \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\\\" = 200 300\\n\",\n    \"- \u0423\u043c\u043d\u043e\u0436\u0438\u0442\u0435\u043b\u044c (\u0442\u044b\u0441\u044f\u0447\u0430/\u043c\u0438\u043b\u043b\u0438\u043e\u043d) -> \u0443\u043c\u043d\u043e\u0436\u0435\u043d\u0438\u0435: \\\"\u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447\\\" = 5*1000 = 5000\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"881fca34\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def lookup_word(word):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    if w in NUMERAL_DICT:\\n\",\n    \"        val, mag = NUMERAL_DICT[w]\\n\",\n    \"        return (val, mag, w in MULTIPLIERS)\\n\",\n    \"    if w in ASR_ERRORS:\\n\",\n    \"        c = ASR_ERRORS[w]\\n\",\n    \"        if c in NUMERAL_DICT:\\n\",\n    \"            val, mag = NUMERAL_DICT[c]\\n\",\n    \"            return (val, mag, c in MULTIPLIERS)\\n\",\n    \"    r = classify(word)\\n\",\n    \"    if r and not any(t.subtype == \\\"vague\\\" for t in r):\\n\",\n    \"        tc = r[0]\\n\",\n    \"        return (tc.value, tc.mag, tc.subtype == \\\"multiplier\\\")\\n\",\n    \"    return None\\n\",\n    \"\\n\",\n    \"def is_ordinal_word(word):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    if w in ORDINAL_SET: return True\\n\",\n    \"    if w in NUMERAL_DICT or w in ASR_ERRORS: return False\\n\",\n    \"    r = classify(word)\\n\",\n    \"    return r and r[0].subtype == \\\"ordinal\\\" if r else False\\n\",\n    \"\\n\",\n    \"def ordinal_value(word):\\n\",\n    \"    w = word.lower()\\n\",\n    \"    if w in ORDINALS: return ORDINALS[w]\\n\",\n    \"    if w in NUMERAL_DICT or w in ASR_ERRORS: return None\\n\",\n    \"    r = classify(word)\\n\",\n    \"    return str(r[0].value) if r and r[0].subtype == \\\"ordinal\\\" else None\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"a8c45d97\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def parse_number_group(tokens_data):\\n\",\n    \"    if not tokens_data: return []\\n\",\n    \"    single_mult = len(tokens_data) == 1 and tokens_data[0][2]\\n\",\n    \"    compound = current = 0\\n\",\n    \"    last_mag = last_mult_mag = -1\\n\",\n    \"    result = []\\n\",\n    \"    for j, (val, mag, is_mult, _) in enumerate(tokens_data):\\n\",\n    \"        if is_mult:\\n\",\n    \"            if last_mult_mag == mag:\\n\",\n    \"                result.append(str(int(compound)))\\n\",\n    \"                compound = current * val if current > 0 else val\\n\",\n    \"                current = 0\\n\",\n    \"            else:\\n\",\n    \"                multiplied = current * val if current > 0 else val\\n\",\n    \"                compound += multiplied; current = 0\\n\",\n    \"            last_mult_mag, last_mag = mag, -1\\n\",\n    \"        else:\\n\",\n    \"            if last_mag == -1:\\n\",\n    \"                current, last_mag = val, mag\\n\",\n    \"            elif mag < last_mag:\\n\",\n    \"                if mag <= 1 and j+1 < len(tokens_data) and tokens_data[j+1][1] == mag:\\n\",\n    \"                    result.append(str(int(compound+current)))\\n\",\n    \"                    compound, current = 0, val\\n\",\n    \"                    last_mag, last_mult_mag = mag, -1\\n\",\n    \"                else:\\n\",\n    \"                    current += val; last_mag = mag\\n\",\n    \"            else:\\n\",\n    \"                result.append(str(int(compound+current)))\\n\",\n    \"                compound, current = 0, val\\n\",\n    \"                last_mag, last_mult_mag = mag, -1\\n\",\n    \"    if single_mult:\\n\",\n    \"        v = tokens_data[0][0]\\n\",\n    \"        return [str(int(v))] if v in (1000,1000000,1000000000) else []\\n\",\n    \"    t = compound + current\\n\",\n    \"    if t > 0 or (len(tokens_data) >= 1 and any(td[0]==0 for td in tokens_data)):\\n\",\n    \"        result.append(str(int(t)))\\n\",\n    \"    return result\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"e811d965\",\n   \"metadata\": {},\n   \"source\": [\n    \"---\\n\",\n    \"## 6. ASR-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433 + \u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0442\u043e\u0440\\n\",\n    \"\\n\",\n    \"### ASR regex-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433\\n\",\n    \"\\n\",\n    \"\u041a\u043e\u0440\u0440\u0435\u043a\u0442\u0438\u0440\u0443\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0435 ASR-\u043e\u0448\u0438\u0431\u043a\u0438 \u0434\u043e \u0442\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u0438:\\n\",\n    \"\\n\",\n    \"1. **\\\"\u0434\u0432\u0435\u0441\u0438\\\" + hundred + (ten) + \u0442\u044b\u0441\u044f\u0447** \u2014 \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432:\\n\",\n    \"   `\u0434\u0432\u0435\u0441\u0438 \u0442\u0440\u0438\u0441\u0442\u0430 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0442\u044b\u0441\u044f\u0447` -> `\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c \u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447` -> 235000\\n\",\n    \"2. **\u041f\u0440\u043e\u043f\u0443\u0449\u0435\u043d\u043d\u044b\u0439 \u043c\u044f\u0433\u043a\u0438\u0439 \u0437\u043d\u0430\u043a**: \u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442 -> \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442, \u0448\u0435\u0441\u0442\u0434\u0435\u0441\u044f\u0442 -> \u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\n\",\n    \"3. **\u041f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u043e\u0448\u0438\u0431\u043a\u0438**: \u0442\u0440\u0438\u0441\u0442\u043e -> \u0442\u0440\u0438\u0441\u0442\u0430, \u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430 -> \u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\n\",\n    \"\\n\",\n    \"### \u0414\u0438\u0441\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f (pymorphy2)\\n\",\n    \"\\n\",\n    \"\u041e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u0447\u0430\u0441\u0442\u0438 \u0440\u0435\u0447\u0438 \u0434\u043b\u044f \u043e\u043c\u043e\u043d\u0438\u043c\u043e\u0432: \\\"\u0441\u0442\u043e\\\" (100 vs \u0433\u043b\u0430\u0433\u043e\u043b), \\\"\u0442\u0440\u0438\\\" (3 vs \u0442\u0435\u0440\u0435\u0442\u044c).\\n\",\n    \"\u041f\u0430\u0442\u0442\u0435\u0440\u043d\u044b:\\n\",\n    \"- `\u0441\u0442\u043e \u0440\u0443\u0431\u043b\u0435\u0439` -> \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435\\n\",\n    \"- `\u044f \u0441\u0442\u043e` -> \u0433\u043b\u0430\u0433\u043e\u043b\\n\",\n    \"- \u0415\u0441\u043b\u0438 \u043d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u043e -> pymorphy2 POS-\u0442\u0435\u0433\u0433\u0438\u043d\u0433\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"3011f6ac\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"_HUNDRED_TO_TEN = {\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\":\\\"\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\":\\\"\u0441\u043e\u0440\u043e\u043a\\\",\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\n\",\n    \"    \\\"\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\":\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\":\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\"}\\n\",\n    \"_TEN_TO_UNIT = {\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u043f\u044f\u0442\u044c\\\",\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0448\u0435\u0441\u0442\u044c\\\",\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0441\u0435\u043c\u044c\\\",\\n\",\n    \"    \\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0432\u043e\u0441\u0435\u043c\u044c\\\",\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\":\\\"\u0434\u0435\u0432\u044f\u0442\u044c\\\"}\\n\",\n    \"\\n\",\n    \"def _asr_preprocess(text):\\n\",\n    \"    text = re.sub(\\n\",\n    \"        r\\\"\\\\b\u0434\u0432\u0435\u0441\u0438\\\\s+(\u0442\u0440\u0438\u0441\u0442\u0430|\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430|\u043f\u044f\u0442\u044c\u0441\u043e\u0442|\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442|\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442)\\\"\\n\",\n    \"        r\\\"(?:\\\\s+(\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442))?\\\\s+\u0442\u044b\u0441\u044f\u0447[\u0430\u0438]?\\\\b\\\",\\n\",\n    \"        lambda m: \\\" \\\".join(\\n\",\n    \"            [\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\", _HUNDRED_TO_TEN.get(m.group(1),m.group(1))]\\n\",\n    \"            + ([_TEN_TO_UNIT.get(m.group(2))] if m.group(2) in _TEN_TO_UNIT else [])\\n\",\n    \"            + [\\\"\u0442\u044b\u0441\u044f\u0447\\\"]), text)\\n\",\n    \"    for p,r in [(r\\\"\\\\b\u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\"),(r\\\"\\\\b\u0448\u0435\u0441\u0442\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\"),\\n\",\n    \"                 (r\\\"\\\\b\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\"),(r\\\"\\\\b\u0432\u043e\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\"),\\n\",\n    \"                 (r\\\"\\\\b\u0442\u0440\u0438\u0441\u0442\u043e\\\\b\\\",\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\"),(r\\\"\\\\b\u0447\u0435\u0442\u044b\u0440\u0438\u0441\u0442\u0430\\\\b\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\")]:\\n\",\n    \"        text = re.sub(p, r, text)\\n\",\n    \"    return text\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"b684f41f\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def _is_vague_tyt_context(tokens, i):\\n\",\n    \"    if i < 1: return False\\n\",\n    \"    p = tokens[i-1]\\n\",\n    \"    if p in (\\\"\u0432\u044b\u0448\u0435\\\",\\\"\u043d\u0438\u0436\u0435\\\",\\\"\u043e\u043a\u043e\u043b\u043e\\\"): return True\\n\",\n    \"    if p==\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\" or (p==\\\"\u0441\\\" and i>=2 and tokens[i-2]==\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\"): return True\\n\",\n    \"    if i>=3 and tokens[i-3]==\\\"\u0441\\\" and tokens[i-2]==\\\"\u0447\u0435\u043c\\\" and tokens[i-1]==\\\"\u0442\u043e\\\": return True\\n\",\n    \"    if i>=2 and tokens[i-2]==\\\"\u0433\u0434\u0435\\\" and tokens[i-1]==\\\"\u0442\u043e\\\": return True\\n\",\n    \"    return False\\n\",\n    \"\\n\",\n    \"_FUSED_COMPOUNDS = {\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\": [(2,0,False,False), (1000,4,True,False)]}\\n\",\n    \"_STO_PATTERNS = [\\n\",\n    \"    (r\\\"\\\\b\u0441\u0442\u043e\\\\s+(\u0440\u0443\u0431\u043b|\u0434\u043e\u043b\u043b\u0430\u0440|\u0435\u0432\u0440\u043e|\u0442\u044b\u0441\u044f\u0447|\u043c\u0438\u043b\u043b\u0438\u043e\u043d|\u043f\u0440\u043e\u0446\u0435\u043d\u0442|\u0440\u0430\u0437|\u0447\u0435\u043b\u043e\u0432\u0435\u043a|\u0448\u0442\u0443\u043a)\\\", True),\\n\",\n    \"    (r\\\"\\\\b(\u0434\u043e|\u043e\u043a\u043e\u043b\u043e|\u0431\u043e\u043b\u0435\u0435|\u043c\u0435\u043d\u0435\u0435|\u0441\u0432\u044b\u0448\u0435|\u043f\u043e\u0447\u0442\u0438)\\\\s+\u0441\u0442\u043e\\\\b\\\", True),\\n\",\n    \"    (r\\\"\\\\b\u044f\\\\s+\u0441\u0442\u043e\\\\b\\\", False), (r\\\"\\\\b\u0441\u0442\u043e\\\\s+(\u043d\u0430|\u0432|\u0443|\u0437\u0430|\u043f\u0435\u0440\u0435\u0434)\\\\b\\\", False),\\n\",\n    \"]\\n\",\n    \"def is_likely_numeric(text, word, pos):\\n\",\n    \"    if word.lower() == \\\"\u0441\u0442\u043e\\\":\\n\",\n    \"        for pat, is_num in _STO_PATTERNS:\\n\",\n    \"            if re.search(pat, text): return is_num\\n\",\n    \"    return True\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"20160bab\",\n   \"metadata\": {},\n   \"source\": [\n    \"### \u0414\u0432\u0430 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0443\u0442\u0438 \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438\\n\",\n    \"\\n\",\n    \"**Path A (legacy, default):** `normalize_text()` -> `lookup_word()` -> `parse_number_group()`\\n\",\n    \"\\n\",\n    \"**Path B (sequence):** `normalize_text_sequence()` -> `classify()` -> `parse_sequence()`\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"db2f5ed6\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def normalize_text(text):\\n\",\n    \"    if not isinstance(text, str) or not text.strip(): return text\\n\",\n    \"    text = _asr_preprocess(text)\\n\",\n    \"    tokens = text.split()\\n\",\n    \"    result_tokens, i = [], 0\\n\",\n    \"    while i < len(tokens):\\n\",\n    \"        t = tokens[i]\\n\",\n    \"        if t in (\\\"\u0442\u044b\u0449\\\",\\\"\u0442\u044b\u0449\u0430\\\") and _is_vague_tyt_context(tokens,i):\\n\",\n    \"            result_tokens.append(t); i += 1; continue\\n\",\n    \"        lk, io = lookup_word(t), is_ordinal_word(t)\\n\",\n    \"        if lk and not io and not is_likely_numeric(text,t,i):\\n\",\n    \"            result_tokens.append(t); i += 1; continue\\n\",\n    \"        if lk or io:\\n\",\n    \"            start = i\\n\",\n    \"            while i < len(tokens):\\n\",\n    \"                if lookup_word(tokens[i]) is not None or is_ordinal_word(tokens[i]): i += 1\\n\",\n    \"                else: break\\n\",\n    \"            gd = []\\n\",",
                  "path": "/home/redalexdad/GitHub/Russian-ASR-ITN-Hybrid/draft.ipynb"
                }
              },
              "output": "<path>/home/redalexdad/GitHub/Russian-ASR-ITN-Hybrid/draft.ipynb</path>\n<type>file</type>\n<content>\n1: {\n2:  \"cells\": [\n3:   {\n4:    \"cell_type\": \"markdown\",\n5:    \"id\": \"5a54707b\",\n6:    \"metadata\": {},\n7:    \"source\": [\n8:     \"# Russian ASR ITN Hybrid \u2014 Inverse Text Normalization\\n\",\n9:     \"\\n\",\n10:     \"\u041e\u0431\u0440\u0430\u0442\u043d\u0430\u044f \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u0430\u044f \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f (ITN) \u0434\u043b\u044f \u0440\u0443\u0441\u0441\u043a\u043e\u0433\u043e \u044f\u0437\u044b\u043a\u0430 \u0432 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0435 ASR:\\n\",\n11:     \"\u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445, \u0437\u0430\u043f\u0438\u0441\u0430\u043d\u043d\u044b\u0445 \u0441\u043b\u043e\u0432\u0430\u043c\u0438, \u0432 \u0446\u0438\u0444\u0440\u043e\u0432\u0443\u044e \u0444\u043e\u0440\u043c\u0443.\\n\",\n12:     \"\\n\",\n13:     \"```\\n\",\n14:     \"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439  \u2192  250 \u0440\u0443\u0431\u043b\u0435\u0439\\n\",\n15:     \"\u043f\u0435\u0440\u0432\u043e\u0433\u043e \u0447\u0438\u0441\u043b\u0430            \u2192  1 \u0447\u0438\u0441\u043b\u0430\\n\",\n16:     \"\u0434\u0432\u0435 \u0442\u044b\u0441\u044f\u0447\u0438 \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044c \u0442\u0440\u0435\u0442\u0438\u0439 \u2192 2023\\n\",\n17:     \"```\\n\",\n18:     \"\\n\",\n19:     \"\u041f\u0440\u043e\u0435\u043a\u0442 \u0440\u0435\u0430\u043b\u0438\u0437\u0443\u0435\u0442 **\u0434\u0432\u0430 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0434\u0445\u043e\u0434\u0430**:\\n\",\n20:     \"\\n\",\n21:     \"| \u041f\u043e\u0434\u0445\u043e\u0434 | \u041c\u0435\u0442\u043e\u0434 | \u0422\u043e\u0447\u043d\u043e\u0441\u0442\u044c |\\n\",\n22:     \"|--------|-------|----------|\\n\",\n23:     \"| Rule-based \u043f\u0430\u0440\u0441\u0435\u0440 | \u0421\u043b\u043e\u0432\u0430\u0440\u0438 + mag-based state machine | **99.8%** \u043d\u0430 calibration.f |\\n\",\n24:     \"| ruT5-small + LoRA | Seq2Seq (65M params, LoRA r=8) | **57.3%** \u043d\u0430 clean synthetic |\\n\",\n25:     \"\\n\",\n26:     \"\u041e\u0431\u0430 \u043f\u043e\u0434\u0445\u043e\u0434\u0430 \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0435\u043d\u044b \u0432 \u0433\u0438\u0431\u0440\u0438\u0434: \u043f\u0430\u0440\u0441\u0435\u0440 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e, T5 \u043f\u0440\u0438 \u043d\u0438\u0437\u043a\u043e\u0439 \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u0438.\"\n27:    ]\n28:   },\n29:   {\n30:    \"cell_type\": \"code\",\n31:    \"execution_count\": 1,\n32:    \"id\": \"c687c93e\",\n33:    \"metadata\": {},\n34:    \"outputs\": [],\n35:    \"source\": [\n36:     \"import sys, os, re, inspect, collections, json, random\\n\",\n37:     \"from pathlib import Path\\n\",\n38:     \"from dataclasses import dataclass\\n\",\n39:     \"from collections import Counter\\n\",\n40:     \"import pandas as pd\\n\",\n41:     \"import pyarrow.feather as feather\\n\",\n42:     \"import numpy as np\"\n43:    ]\n44:   },\n45:   {\n46:    \"cell_type\": \"markdown\",\n47:    \"id\": \"9fbd3707\",\n48:    \"metadata\": {},\n49:    \"source\": [\n50:     \"---\\n\",\n51:     \"## 1. \u0414\u0430\u0442\u0430\u0441\u0435\u0442\u044b\\n\",\n52:     \"\\n\",\n53:     \"### 1.1 calibration.f (500 \u0441\u0442\u0440\u043e\u043a)\\n\",\n54:     \"\\n\",\n55:     \"\u042d\u0442\u0430\u043b\u043e\u043d\u043d\u044b\u0439 \u0434\u0430\u0442\u0430\u0441\u0435\u0442. \u041a\u043e\u0440\u043e\u0442\u043a\u0438\u0435 ASR-\u0444\u0440\u0430\u0437\u044b (\u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0434\u043b\u0438\u043d\u0430 ~30 \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432) \u0441 \u0447\u0438\u0441\u043b\u043e\u0432\u044b\u043c\u0438\\n\",\n56:     \"\u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0430\u043c\u0438: \u0446\u0435\u043d\u044b, \u0431\u044e\u0434\u0436\u0435\u0442\u044b, \u0441\u0440\u043e\u043a\u0438, \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u044b. \u041c\u0438\u043d\u0438\u043c\u0443\u043c \u043f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u0438, \u0447\u0438\u0441\u0442\u044b\u0439 \u0440\u0443\u0441\u0441\u043a\u0438\u0439 \u044f\u0437\u044b\u043a.\\n\",\n57:     \"\\n\",\n58:     \"### 1.2 synthetic.f (16 618 \u0441\u0442\u0440\u043e\u043a)\\n\",\n59:     \"\\n\",\n60:     \"\u0421\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u043d \u0447\u0435\u0440\u0435\u0437 `scripts/generate_synthetic.py`. \u0421\u043e\u0434\u0435\u0440\u0436\u0438\u0442 \u0434\u0432\u0430 \u043f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u0430:\\n\",\n61:     \"\\n\",\n62:     \"| \u041f\u043e\u0434\u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e | \u0421\u0442\u0440\u043e\u043a | \u0414\u043e\u043b\u044f |\\n\",\n63:     \"|---|---|---|\\n\",\n64:     \"| clean | 4 890 | 29.4% |\\n\",\n65:     \"| noisy (ASR-\u0448\u0443\u043c) | 11 728 | 70.6% |\\n\",\n66:     \"\\n\",\n67:     \"**4 \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430:** template (45.1%), grouping (36.1%), ordinal (18.1%), news (0.7%)\\n\",\n68:     \"\\n\",\n69:     \"### 1.3 real.f (172 \u0441\u0442\u0440\u043e\u043a\u0438)\\n\",\n70:     \"\\n\",\n71:     \"\u0420\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0442\u0435\u043a\u0441\u0442\u044b \u0438\u0437 Wikipedia API \u0438 \u043d\u043e\u0432\u043e\u0441\u0442\u043d\u044b\u0445 RSS. \u0414\u043b\u0438\u043d\u043d\u044b\u0435 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u044b (\u0441\u0440\u0435\u0434\u043d\u044f\u044f\\n\",\n72:     \"\u0434\u043b\u0438\u043d\u0430 123 \u0441\u0438\u043c\u0432\u043e\u043b\u0430), \u0441\u043c\u0435\u0448\u0430\u043d\u043d\u044b\u0439 \u0440\u0443\u0441\u0441\u043a\u043e-\u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438\u0439 \u0442\u0435\u043a\u0441\u0442, \u043f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f, \u0434\u0435\u0444\u0438\u0441\u044b.\\n\",\n73:     \"\\n\",\n74:     \"| \u0425\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0430 | calibration.f | synthetic.f | real.f |\\n\",\n75:     \"|---|---|---|---|\\n\",\n76:     \"| \u0414\u043b\u0438\u043d\u0430 \u0442\u0435\u043a\u0441\u0442\u0430 (\u0441\u0440.) | ~30 | 26.5 | 122.9 |\\n\",\n77:     \"| \u041f\u0443\u043d\u043a\u0442\u0443\u0430\u0446\u0438\u044f | \u041f\u043e\u0447\u0442\u0438 \u043d\u0435\u0442 | \u041c\u0438\u043d\u0438\u043c\u0443\u043c | \u0421\u043a\u043e\u0431\u043a\u0438, %, :, \u0434\u0435\u0444\u0438\u0441\u044b |\\n\",\n78:     \"| \u042f\u0437\u044b\u043a | \u0420\u0443\u0441\u0441\u043a\u0438\u0439 | \u0420\u0443\u0441\u0441\u043a\u0438\u0439 | \u0420\u0443\u0441\u0441\u043a\u0438\u0439 + \u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438\u0439 |\\n\",\n79:     \"| ASR-\u0448\u0443\u043c | \u041d\u0435\u0442 | 70.6% noisy | \u041d\u0435\u0442 |\"\n80:    ]\n81:   },\n82:   {\n83:    \"cell_type\": \"code\",\n84:    \"execution_count\": 2,\n85:    \"id\": \"7b5a3981\",\n86:    \"metadata\": {},\n87:    \"outputs\": [\n88:     {\n89:      \"name\": \"stdout\",\n90:      \"output_type\": \"stream\",\n91:      \"text\": [\n92:       \"calibration.f: 500 rows\\n\",\n93:       \"  task len: mean=230.9\\n\",\n94:       \"synthetic.f:  16618 rows\\n\",\n95:       \"  noise_level: {'noisy': 11728, 'clean': 4890}\\n\",\n96:       \"  source: {'template': 7500, 'grouping': 6000, 'ordinal': 3000, 'news': 118}\\n\",\n97:       \"  num_type: {'cardinal': 13618, 'ordinal': 3000}\\n\",\n98:       \"real.f:       172 rows\\n\",\n99:       \"  task len: mean=135.4\\n\",\n100:       \"\\n\",\n101:       \"--- calibration.f samples ---\\n\",\n102:       \"  TASK: \u0432\u0430\u043c \u043d\u0443\u0436\u043d\u043e \u0431\u0443\u0434\u0435\u0442 \u043f\u0435\u0440\u0435\u0439\u0442\u0438 \u0432 \u0440\u0430\u0437\u0434\u0435\u043b \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043b\u0438\u0447\u043d\u043e\u0433\u043e \u043a\u0430\u0431\u0438\u043d\u0435\u0442\u0430 \u0438 \u0432\u043d\u0435\u0441\u0442\u0438 \u0432\\n\",\n103:       \"  GT:   \u0432\u0430\u043c \u043d\u0443\u0436\u043d\u043e \u0431\u0443\u0434\u0435\u0442 \u043f\u0435\u0440\u0435\u0439\u0442\u0438 \u0432 \u0440\u0430\u0437\u0434\u0435\u043b \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043b\u0438\u0447\u043d\u043e\u0433\u043e \u043a\u0430\u0431\u0438\u043d\u0435\u0442\u0430 \u0438 \u0432\u043d\u0435\u0441\u0442\u0438 \u0432\\n\",\n104:       \"\\n\",\n105:       \"  TASK: \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u0443\u044e \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u044d\u043a\u0440\u0430\u043d\u0430 \u0438 \u0432\u044b \u0443\u0432\u0438\u0434\u0438\u0442\u0435 \u0432 \u043d\u0438\u0436\u043d\u0435\u0439 \u0447\u0430\u0441\u0442\u0438 \u0432\u043e\u0442 \u0442\u0430\\n\",\n106:       \"  GT:   \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u0443\u044e \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u044d\u043a\u0440\u0430\u043d\u0430 \u0438 \u0432\u044b \u0443\u0432\u0438\u0434\u0438\u0442\u0435 \u0432 \u043d\u0438\u0436\u043d\u0435\u0439 \u0447\u0430\u0441\u0442\u0438 \u0432\u043e\u0442 \u0442\u0430\\n\",\n107:       \"\\n\",\n108:       \"  TASK: \u043f\u044f\u0442\u044c\u0441\u043e\u0442 \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 \u0440\u0443\u0431\u043b\u0435\u0439 \u0435\u0441\u043b\u0438 \u0431\u0440\u0430\u0442\u044c \u0441\u0440\u0435\u0434\u043d\u0435\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0442\u043e \u044d\u0442\u043e \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e\\n\",\n109:       \"  GT:   580 \u0440\u0443\u0431\u043b\u0435\u0439 \u0435\u0441\u043b\u0438 \u0431\u0440\u0430\u0442\u044c \u0441\u0440\u0435\u0434\u043d\u0435\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0442\u043e \u044d\u0442\u043e \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u0443\u043f\u0430\u043a\u043e\\n\",\n110:       \"\\n\"\n111:      ]\n112:     }\n113:    ],\n114:    \"source\": [\n115:     \"cal = feather.read_table(\\\"data/calibration.f\\\").to_pandas()\\n\",\n116:     \"syn = feather.read_table(\\\"data/synthetic.f\\\").to_pandas()\\n\",\n117:     \"real = feather.read_table(\\\"data/real.f\\\").to_pandas()\\n\",\n118:     \"\\n\",\n119:     \"print(f\\\"calibration.f: {len(cal)} rows\\\")\\n\",\n120:     \"print(f\\\"  task len: mean={cal['task_text'].str.len().mean():.1f}\\\")\\n\",\n121:     \"print(f\\\"synthetic.f:  {len(syn)} rows\\\")\\n\",\n122:     \"print(f\\\"  noise_level: {dict(syn['noise_level'].value_counts())}\\\")\\n\",\n123:     \"print(f\\\"  source: {dict(syn['source'].value_counts())}\\\")\\n\",\n124:     \"print(f\\\"  num_type: {dict(syn['num_type'].value_counts())}\\\")\\n\",\n125:     \"print(f\\\"real.f:       {len(real)} rows\\\")\\n\",\n126:     \"print(f\\\"  task len: mean={real['task_text'].str.len().mean():.1f}\\\")\\n\",\n127:     \"\\n\",\n128:     \"print(\\\"\\\\n--- calibration.f samples ---\\\")\\n\",\n129:     \"for _, r in cal.head(3).iterrows():\\n\",\n130:     \"    print(f\\\"  TASK: {r['task_text'][:70]}\\\\n  GT:   {r['ground_truth'][:70]}\\\\n\\\")\"\n131:    ]\n132:   },\n133:   {\n134:    \"cell_type\": \"markdown\",\n135:    \"id\": \"437f25de\",\n136:    \"metadata\": {},\n137:    \"source\": [\n138:     \"---\\n\",\n139:     \"## 2. Rule-based \u043f\u0430\u0440\u0441\u0435\u0440\\n\",\n140:     \"\\n\",\n141:     \"### 2.1 \u0410\u0440\u0445\u0438\u0442\u0435\u043a\u0442\u0443\u0440\u0430\\n\",\n142:     \"\\n\",\n143:     \"```\\n\",\n144:     \"\u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u0442\u0435\u043a\u0441\u0442\\n\",\n145:     \"    \u2502\\n\",\n146:     \"    \u25bc\\n\",\n147:     \"_asr_preprocess() \u2014 regex-\u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u044f ASR-\u043e\u0448\u0438\u0431\u043e\u043a (\u043c\u044f\u0433\u043a\u0438\u0439 \u0437\u043d\u0430\u043a, \\\"\u0434\u0432\u0435\u0441\u0438\\\")\\n\",\n148:     \"    \u2502\\n\",\n149:     \"    \u25bc\\n\",\n150:     \"\u0422\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u044f \u043f\u043e \u043f\u0440\u043e\u0431\u0435\u043b\u0430\u043c\\n\",\n151:     \"    \u2502\\n\",\n152:     \"    \u25bc\\n\",\n153:     \"\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\\n\",\n154:     \"\u2502       \u0414\u0432\u0430 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0443\u0442\u0438          \u2502\\n\",\n155:     \"\u2502                                      \u2502\\n\",\n156:     \"\u2502  Path A (legacy, default):           \u2502\\n\",\n157:     \"\u2502    normalize_text()                  \u2502\\n\",\n158:     \"\u2502    \u2192 lookup_word()                   \u2502\\n\",\n159:     \"\u2502    \u2192 parse_number_group() (mag)      \u2502\\n\",\n160:     \"\u2502                                      \u2502\\n\",\n161:     \"\u2502  Path B (sequence, --parser-type):   \u2502\\n\",\n162:     \"\u2502    normalize_text_sequence()          \u2502\\n\",\n163:     \"\u2502    \u2192 classify() (token_classifier)   \u2502\\n\",\n164:     \"\u2502    \u2192 parse_sequence() (state machine)\u2502\\n\",\n165:     \"\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\\n\",\n166:     \"    \u2502\\n\",\n167:     \"    \u25bc\\n\",\n168:     \"\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442: \u0447\u0438\u0441\u043b\u0430 \u0446\u0438\u0444\u0440\u0430\u043c\u0438 + \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u0435\u043a\u0441\u0442\\n\",\n169:     \"```\\n\",\n170:     \"\\n\",\n171:     \"### 2.2 \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0439 (legacy)\\n\",\n172:     \"\\n\",\n173:     \"**97.6% \u2192 99.8%** (488/500 \u2192 499/500). \u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043e 11 \u0438\u0437 12 \u043e\u0448\u0438\u0431\u043e\u043a:\\n\",\n174:     \"\\n\",\n175:     \"| \u0424\u0430\u0437\u0430 | \u0427\u0442\u043e \u0434\u0435\u043b\u0430\u043b\u0438 | \u041f\u043e\u0439\u043c\u0430\u043d\u043e |\\n\",\n176:     \"|---|---|---|\\n\",\n177:     \"| 1 | \u0421\u043b\u043e\u0432\u0430\u0440\u043d\u044b\u0435 \u0444\u0438\u043a\u0441\u044b (\u0442\u044b\u0449\u0430, \u0442\u044b\u0441\u044f\u0447\u0430\u043c, \u0451-\u0444\u043e\u0440\u043c\u044b) | 5 |\\n\",\n178:     \"| 2 | \u041b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0444\u0438\u043a\u0441\u044b (\u0442\u044b\u0449 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442, fused, mag=0 repeat) | 3 |\\n\",\n179:     \"| 3 | \u0414\u0432\u0430 multiplier \u043e\u0434\u043d\u043e\u0433\u043e \u0440\u0430\u043d\u0433\u0430 \u2192 enum | 1 |\\n\",\n180:     \"| 4 | ASR regex-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433 (\\\"\u0434\u0432\u0435\u0441\u0438\\\" \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432) | 1 |\\n\",\n181:     \"| 5 | Levenshtein fallback \u0434\u043b\u044f ordinals | \u043f\u043e\u0433\u0440\u0430\u043d\u0438\u0447\u043d\u044b\u0435 |\\n\",\n182:     \"| 6 | Root-based \u0434\u0438\u043d\u0430\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u0438\u0435 \u0441\u043b\u043e\u0432\u0430\u0440\u044f | \u2014 |\\n\",\n183:     \"| 7 | pymorphy2-\u0434\u0438\u0441\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f (\u0441\u0442\u043e/\u0442\u0440\u0438/\u0441\u043e\u0440\u043e\u043a) | \u2014 |\\n\",\n184:     \"\\n\",\n185:     \"**\u041e\u0441\u0442\u0430\u0432\u0448\u0430\u044f\u0441\u044f \u043e\u0448\u0438\u0431\u043a\u0430:** `\u0434\u0432\u0430\u0441\u0442\u0430` \u2192 GT \u0441\u043e\u0445\u0440\u0430\u043d\u044f\u0435\u0442 ASR-\u043e\u0448\u0438\u0431\u043a\u0443, parser \u043f\u0440\u0430\u0432 \u0434\u043b\u044f ITN.\"\n186:    ]\n187:   },\n188:   {\n189:    \"cell_type\": \"markdown\",\n190:    \"id\": \"37850edf\",\n191:    \"metadata\": {},\n192:    \"source\": [\n193:     \"### 2.3 \u0421\u043b\u043e\u0432\u0430\u0440\u0438 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445\\n\",\n194:     \"\\n\",\n195:     \"\u0421\u043b\u043e\u0432\u0430\u0440\u0438 \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0442 \u0432\u0441\u0435 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0435 \u0441\u043b\u043e\u0432\u043e\u0444\u043e\u0440\u043c\u044b: \u043f\u0430\u0434\u0435\u0436\u0438, \u0447\u0438\u0441\u043b\u0430, ASR-\u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u044f.\\n\",\n196:     \"\u0424\u043e\u0440\u043c\u0430\u0442: `\u0441\u043b\u043e\u0432\u043e \u2192 (\u0447\u0438\u0441\u043b\u043e\u0432\u043e\u0435_\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435, mag)`.\\n\",\n197:     \"\\n\",\n198:     \"**mag (\u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0432\u0435\u043b\u0438\u0447\u0438\u043d\u044b):**\\n\",\n199:     \"- 0 = \u0435\u0434\u0438\u043d\u0438\u0446\u044b (0-9) \u0438 \u0441\u043e\u0431\u0438\u0440\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0435\\n\",\n200:     \"- 1 = \u0447\u0438\u0441\u043b\u0430 10-19\\n\",\n201:     \"- 2 = \u0434\u0435\u0441\u044f\u0442\u043a\u0438 20-90\\n