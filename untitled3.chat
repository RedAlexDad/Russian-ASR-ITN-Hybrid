            "raw_output": {
              "output": "\"\"\"\n\u0421\u043b\u043e\u0432\u0430\u0440\u044c ASR-\u043e\u0448\u0438\u0431\u043e\u043a: \u0438\u0441\u043a\u0430\u0436\u0451\u043d\u043d\u043e\u0435 \u0441\u043b\u043e\u0432\u043e -> \u043a\u0430\u043d\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0444\u043e\u0440\u043c\u0430.\n\n\u0417\u0430\u0447\u0435\u043c \u044d\u0442\u043e \u043d\u0443\u0436\u043d\u043e:\n  \u0421\u0438\u0441\u0442\u0435\u043c\u0430 \u0440\u0430\u0441\u043f\u043e\u0437\u043d\u0430\u0432\u0430\u043d\u0438\u044f \u0440\u0435\u0447\u0438 (ASR) \u0447\u0430\u0441\u0442\u043e \u043e\u0448\u0438\u0431\u0430\u0435\u0442\u0441\u044f \u0432 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445.\n  \u0422\u0438\u043f\u0438\u0447\u043d\u044b\u0435 \u043e\u0448\u0438\u0431\u043a\u0438:\n    - \u0417\u0430\u043c\u0435\u043d\u0430 \u0433\u043b\u0430\u0441\u043d\u044b\u0445: \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\" -> \"\u043f\u0435\u0442\u044c\u0441\u044f\u0442\", \"\u043f\u0438\u0441\u044f\u0442\"\n    - \u041f\u0440\u043e\u043f\u0443\u0441\u043a \u0431\u0443\u043a\u0432: \"\u0442\u044b\u0441\u044f\u0447\" -> \"\u0442\u044b\u0449\", \"\u0442\u044b\u0441\"\n    - \"\u0426\u043e\u043a\u0430\u043d\u044c\u0435\": \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\" -> \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0438\u0442\u044c\"\n    - \u0420\u0435\u0433\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0435 \u043f\u0440\u043e\u0438\u0437\u043d\u043e\u0448\u0435\u043d\u0438\u0435: \"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\" -> \"\u0434\u0438\u0432\u044f\u043d\u043e\u0441\u0442\u043e\"\n\n  \u042d\u0442\u043e\u0442 \u0441\u043b\u043e\u0432\u0430\u0440\u044c \u0441\u043e\u0431\u0438\u0440\u0430\u043b\u0441\u044f \u0430\u043d\u0430\u043b\u0438\u0437\u043e\u043c calibration.f \u2014 44 \u0432\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u044f \"\u0434\u0432\u0435\u0441\u0438\" \u0438 \u0442.\u0434.\n  \u0412\u0441\u0435\u0433\u043e ~40 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u0432, \u043f\u043e\u043a\u0440\u044b\u0432\u0430\u044e\u0449\u0438\u0445 >95% ASR-\u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u0439 \u0432 \u0434\u0430\u043d\u043d\u044b\u0445.\n\n\u0424\u043e\u0440\u043c\u0430\u0442: \u0438\u0441\u043a\u0430\u0436\u0451\u043d\u043d\u043e\u0435_\u0441\u043b\u043e\u0432\u043e -> \u043a\u0430\u043d\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0430\u044f_\u0444\u043e\u0440\u043c\u0430\n  \u041a\u0430\u043d\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0444\u043e\u0440\u043c\u0430 \u0434\u043e\u043b\u0436\u043d\u0430 \u043f\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432 NUMERAL_DICT (units/hundreds/thousands).\n\"\"\"\n\nASR_ERRORS = {\n    # \u0421\u0430\u043c\u0430\u044f \u0447\u0430\u0441\u0442\u0430\u044f \u043e\u0448\u0438\u0431\u043a\u0430 (44+ \u0432\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0439): \"\u0434\u0432\u0435\u0441\u0442\u0438\" -> \"\u0434\u0432\u0435\u0441\u0438\"\n    \"\u0434\u0432\u0435\u0441\u0438\": \"\u0434\u0432\u0435\u0441\u0442\u0438\",\n    \"\u0434\u0432\u0430\u0441\u0442\u0430\": \"\u0434\u0432\u0435\u0441\u0442\u0438\",\n    # \"\u0442\u044b\u0441\u044f\u0447\u0430\" \u0432 \u0440\u0430\u0437\u043d\u044b\u0445 \u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u044f\u0445\n    \"\u0442\u044b\u0449\": \"\u0442\u044b\u0441\u044f\u0447\",\n    \"\u0442\u044b\u0449\u0438\": \"\u0442\u044b\u0441\u044f\u0447\u0438\",\n    # \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\": \u0440\u0430\u0437\u043d\u044b\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u043f\u0440\u043e\u0438\u0437\u043d\u043e\u0448\u0435\u043d\u0438\u044f\n    \"\u043f\u0435\u0442\u044c\u0441\u044f\u0442\": \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\",\n    \"\u043f\u0435\u0442\u044c\u0434\u0435\u0441\u044f\u0442\": \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\",\n    \"\u043f\u0438\u0441\u044f\u0442\": \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\",\n    \"\u043f\u044f\u0434\u0441\u044f\u0442\": \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\",\n    \"\u043f\u044c\u0441\u044f\u0442\": \"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\",\n    # \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\": \u0446\u043e\u043a\u0430\u043d\u044c\u0435 \u0438 \u0440\u0435\u0434\u0443\u043a\u0446\u0438\u044f\n    \"\u043f\u044f\u0434\u0446\u0438\u0442\u044c\": \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0438\u0442\u044c\": \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u043f\u0438\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\": \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u043f\u0435\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\": \"\u043f\u044f\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    # \"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\"\n    \"\u0441\u0438\u043c\u043d\u0430\u0434\u0446\u0438\u0442\u044c\": \"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0438\u0442\u044c\": \"\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    # \"\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\"\n    \"\u0448\u0438\u0441\u043d\u0430\u0442\u0446\u0430\u0442\u044c\": \"\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u0448\u0435\u0441\u043d\u0430\u0442\u0446\u0430\u0442\u044c\": \"\u0448\u0435\u0441\u0442\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    # \"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\"\n    \"\u0432\u043e\u0441\u0438\u043c\u043d\u0430\u0434\u0446\u0438\u0442\u044c\": \"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0438\u0442\u044c\": \"\u0432\u043e\u0441\u0435\u043c\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    # \"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\"\n    \"\u0434\u0438\u0432\u044f\u043d\u043e\u0441\u0442\u043e\": \"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\",\n    \"\u0434\u0438\u0432\u044f\u043d\u043e\u0441\u0442\u0430\": \"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u0430\",\n    # \u041f\u0440\u043e\u0447\u0438\u0435 \u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u044f \"\u0442\u044b\u0441\u044f\u0447\"\n    \"\u0442\u044b\u0441\u0438\u0447\": \"\u0442\u044b\u0441\u044f\u0447\",\n    \"\u0442\u044b\u0441\u0435\u0447\": \"\u0442\u044b\u0441\u044f\u0447\",\n    \"\u0442\u0438\u0441\u044f\u0447\": \"\u0442\u044b\u0441\u044f\u0447\",\n    \"\u0442\u0438\u0449\": \"\u0442\u044b\u0441\u044f\u0447\",\n    # \"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\"\n    \"\u043c\u0438\u043b\u0438\u043e\u043d\": \"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\",\n    \"\u043c\u0438\u043b\u0438\u043e\u043d\u0430\": \"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\",\n    \"\u043c\u0438\u043b\u0438\u043e\u043d\u043e\u0432\": \"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432\",\n    # \u0421\u043e\u0442\u043d\u0438\n    \"\u0442\u0440\u0438\u0441\u0442\u0438\": \"\u0442\u0440\u0438\u0441\u0442\u0430\",\n    \"\u0441\u0435\u043c\u0441\u043e\u0442\": \"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\",\n    \"\u0432\u043e\u0441\u0438\u043c\u0441\u043e\u0442\": \"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\",\n    \"\u0434\u0435\u0432\u044f\u0442\u0441\u043e\u0442\": \"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\",\n    # \u0427\u0438\u0441\u043b\u0430 \u043d\u0430 -\u043d\u0430\u0434\u0446\u0430\u0442\u044c\n    \"\u0434\u0432\u0435\u043d\u0430\u0446\u0442\u0430\u0442\u044c\": \"\u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u0442\u0440\u0438\u043d\u0430\u0446\u0430\u0442\u044c\": \"\u0442\u0440\u0438\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    \"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0446\u0430\u0442\u044c\": \"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\",\n    # \"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\"\n    \"\u0432\u043e\u0441\u0435\u043c\u0441\u0430\u0442\": \"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\",\n    \"\u0432\u043e\u0441\u0438\u043c\u0434\u0435\u0441\u0430\u0442\": \"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\",\n    # \"\u0434\u0435\u0441\u044f\u0442\u044c\"\n    \"\u0434\u0438\u0441\u044f\u0442\u044c\": \"\u0434\u0435\u0441\u044f\u0442\u044c\",\n    \"\u0434\u0438\u0441\u044f\u0442\": \"\u0434\u0435\u0441\u044f\u0442\u044c\",\n    \"\u0434\u0435\u0441\u044f\u0442\": \"\u0434\u0435\u0441\u044f\u0442\u044c\",\n    # \u0415\u0449\u0451 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b\n    \"\u0432\u043e\u0441\u0438\u043c\u0438\u0441\u044f\u0442\": \"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\",\n    # \u041b\u0430\u0442\u0438\u043d\u0441\u043a\u0430\u044f 'c' \u0432\u043c\u0435\u0441\u0442\u043e \u043a\u0438\u0440\u0438\u043b\u043b\u0438\u0447\u0435\u0441\u043a\u043e\u0439 '\u0441'\n    \"\u0442\u044bc\": \"\u0442\u044b\u0441\u044f\u0447\",\n    # \u0410\u0431\u0431\u0440\u0435\u0432\u0438\u0430\u0442\u0443\u0440\u0430 \"\u0442\u044b\u0441\" (\u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044f \u0432 \u0442\u0435\u043a\u0441\u0442\u0435)\n    \"\u0442\u044b\u0441\": \"\u0442\u044b\u0441\u044f\u0447\",\n}\n",
