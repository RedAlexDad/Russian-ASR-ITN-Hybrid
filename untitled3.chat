                "preview": "    \"            for j in range(start, i):\\n\",\n    \"                tj = tokens[j]; lk2, io2 = lookup_word(tj), is_ordinal_word(tj)\\n\",\n    \"                if io2: gd.append((int(ordinal_value(tj)),0,False,True))\\n\",\n    \"                elif lk2:\\n\",\n    \"                    if tj in _FUSED_COMPOUNDS: gd.extend(_FUSED_COMPOUNDS[tj])\\n\",\n    \"                    else: gd.append((lk2[0],lk2[1],lk2[2],False))\\n\",\n    \"            result_tokens.extend(parse_number_group(gd))\\n\",\n    \"        else:\\n\",\n    \"            result_tokens.append(t); i += 1\\n\",\n    \"    return \\\" \\\".join(result_tokens)\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"2309a956\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def normalize_text_sequence(text):\\n\",",
