u043a\u0438\u0439\\\", \\\"\u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f\\\",\\n\",\n556:     \"    \\\"\u0432\u044b\u0441\u043e\u043a\u0438\u0439\\\", \\\"\u043d\u0438\u0437\u043a\u0438\u0439\\\", \\\"\u043d\u0443\u0436\u043d\u044b\u0439\\\", \\\"\u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439\\\", \\\"\u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0439\\\",\\n\",\n557:     \"    \\\"\u0440\u0430\u0437\u043d\u044b\u0439\\\", \\\"\u0446\u0435\u043b\u044b\u0439\\\", \\\"\u043f\u043e\u043b\u043d\u044b\u0439\\\", \\\"\u0432\u0430\u0436\u043d\u044b\u0439\\\", \\\"\u0442\u043e\u0447\u043d\u044b\u0439\\\", \\\"\u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439\\\", \\\"\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0439\\\",\\n\",\n558:     \"    \\\"\u043e\u0431\u044b\u0447\u043d\u044b\u0439\\\", \\\"\u043f\u043e\u0434\u043e\u0431\u043d\u044b\u0439\\\", \\\"\u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u0437\u043d\u0430\u0447\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\",\\n\",\n559:     \"    \\\"\u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439\\\", \\\"\u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043f\u0440\u0435\u0436\u043d\u0438\u0439\\\",\\n\",\n560:     \"    \\\"\u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u043f\u0440\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\",\\n\",\n561:     \"    \\\"\u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043f\u043e\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u0438\u0441\u0442\u043e\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\",\\n\",\n562:     \"    \\\"\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u044e\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043a\u0438\u0439\\\", \\\"\u043c\u0435\u0434\u0438\u0446\u0438\u043d\u0441\u043a\u0438\u0439\\\",\\n\",\n563:     \"    \\\"\u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439\\\", \\\"\u043a\u0443\u043b\u044c\u0442\u0443\u0440\u043d\u044b\u0439\\\", \\\"\u043d\u0430\u0443\u0447\u043d\u044b\u0439\\\",\\n\",\n564:     \"    \\\"\u043c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u044b\u0439\\\", \\\"\u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0439\\\", \\\"\u0432\u0442\u043e\u0440\u043e\u0439\\\"}\\n\",\n565:     \"_VAGUE_MARKERS = {\\\"\u0432\u044b\u0448\u0435\\\", \\\"\u043d\u0438\u0436\u0435\\\", \\\"\u043e\u043a\u043e\u043b\u043e\\\", \\\"\u043f\u043e\u0447\u0442\u0438\\\"}\\n\",\n566:     \"_MULTIPLIER_SET = set()\\n\",\n567:     \"for d in (THOUSANDS, MILLIONS, BILLIONS): _MULTIPLIER_SET.update(d.keys())\"\n568:    ]\n569:   },\n570:   {\n571:    \"cell_type\": \"code\",\n572:    \"execution_count\": null,\n573:    \"id\": \"3ea56ab9\",\n574:    \"metadata\": {},\n575:    \"outputs\": [],\n576:    \"source\": [\n577:     \"def _is_vague_context(prev_tokens):\\n\",\n578:     \"    if len(prev_tokens) < 1: return False\\n\",\n579:     \"    prev = prev_tokens[-1]\\n\",\n580:     \"    if prev in _VAGUE_MARKERS: return True\\n\",\n581:     \"    if len(prev_tokens) >= 3 and prev_tokens[-3:] == [\\\"\u0441\\\",\\\"\u0447\u0435\u043c\\\",\\\"\u0442\u043e\\\"]: return True\\n\",\n582:     \"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\"\u0433\u0434\u0435\\\",\\\"\u0442\u043e\\\"]: return True\\n\",\n583:     \"    if len(prev_tokens) >= 2 and prev_tokens[-2:] == [\\\"\u0441\\\",\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\"]: return True\\n\",\n584:     \"    return False\\n\",\n585:     \"\\n\",\n586:     \"def _match_root(word):\\n\",\n587:     \"    w = word.lower()\\n\",\n588:     \"    for root, val, mag, is_mult in _NUMERIC_ROOTS:\\n\",\n589:     \"        idx = w.find(root)\\n\",\n590:     \"        if idx == -1 or idx != 0: continue\\n\",\n591:     \"        suffix = w[len(root):]\\n\",\n592:     \"        if suffix in _INFLECTION_SUFFIXES:\\n\",\n593:     \"            return val, mag, is_mult, suffix\\n\",\n594:     \"    return None\\n\",\n595:     \"\\n\",\n596:     \"def _classify_ordinal(word, val, mag, suffix):\\n\",\n597:     \"    w = word.lower()\\n\",\n598:     \"    if w in _NON_ORDINALS or w in NUMERAL_DICT: return None\\n\",\n599:     \"    if suffix in _ORDINAL_SUFFIXES:\\n\",\n600:     \"        return TokenClass(val, mag, \\\"ordinal\\\", word)\\n\",\n601:     \"    return None\\n\",\n602:     \"\\n\",\n603:     \"def _find_fused_compound(word):\\n\",\n604:     \"    w = word.lower()\\n\",\n605:     \"    for i in range(2, len(w)):\\n\",\n606:     \"        p1, p2 = w[:i], w[i:]\\n\",\n607:     \"        r1, r2 = _match_root(p1), _match_root(p2)\\n\",\n608:     \"        if r1 and r2:\\n\",\n609:     \"            v1, m1, mult1, _ = r1\\n\",\n610:     \"            v2, m2, mult2, _ = r2\\n\",\n611:     \"            if mult2 and m1 <= 3 and m2 >= 4:\\n\",\n612:     \"                return [TokenClass(v1, m1, \\\"cardinal\\\", word), TokenClass(v2, m2, \\\"multiplier\\\", word)]\\n\",\n613:     \"    return None\"\n614:    ]\n615:   },\n616:   {\n617:    \"cell_type\": \"code\",\n618:    \"execution_count\": null,\n619:    \"id\": \"da5008ae\",\n620:    \"metadata\": {},\n621:    \"outputs\": [],\n622:    \"source\": [\n623:     \"def classify(word, prev_tokens=None):\\n\",\n624:     \"    if not word or len(word) < 2: return None\\n\",\n625:     \"    w = word.lower()\\n\",\n626:     \"    if w in (\\\"\u0442\u044b\u0449\\\",\\\"\u0442\u044b\u0449\u0430\\\") and prev_tokens and _is_vague_context(prev_tokens):\\n\",\n627:     \"        return [TokenClass(1000, 4, \\\"vague\\\", word)]\\n\",\n628:     \"    if w in NUMERAL_DICT:\\n\",\n629:     \"        val, mag = NUMERAL_DICT[w]\\n\",\n630:     \"        return [TokenClass(val, mag, \\\"multiplier\\\" if w in _MULTIPLIER_SET else \\\"cardinal\\\", word)]\\n\",\n631:     \"    if w in ORDINAL_SET:\\n\",\n632:     \"        return [TokenClass(int(ORDINALS[w]), 0, \\\"ordinal\\\", word)]\\n\",\n633:     \"    if w in ASR_ERRORS:\\n\",\n634:     \"        c = ASR_ERRORS[w]\\n\",\n635:     \"        if c in NUMERAL_DICT:\\n\",\n636:     \"            val, mag = NUMERAL_DICT[c]\\n\",\n637:     \"            return [TokenClass(val, mag, \\\"multiplier\\\" if c in _MULTIPLIER_SET else \\\"cardinal\\\", word)]\\n\",\n638:     \"        if c in ORDINAL_SET:\\n\",\n639:     \"            return [TokenClass(int(ORDINALS[c]), 0, \\\"ordinal\\\", word)]\\n\",\n640:     \"    match = _match_root(w)\\n\",\n641:     \"    if match:\\n\",\n642:     \"        val, mag, is_mult, suffix = match\\n\",\n643:     \"        ord = _classify_ordinal(word, val, mag, suffix)\\n\",\n644:     \"        if ord: return [ord]\\n\",\n645:     \"        return [TokenClass(val, mag, \\\"multiplier\\\" if is_mult else \\\"cardinal\\\", word)]\\n\",\n646:     \"    fused = _find_fused_compound(word)\\n\",\n647:     \"    if fused: return fused\\n\",\n648:     \"    return None\\n\",\n649:     \"\\n\",\n650:     \"print(\\\"=== classify() tests ===\\\")\\n\",\n651:     \"for w, exp in [(\\\"\u043f\u044f\u0442\u044c\\\",5),(\\\"\u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c\\\",14),(\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",80),\\n\",\n652:     \"               (\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\",300),(\\\"\u0442\u044b\u0441\u044f\u0447\u0430\\\",1000),(\\\"\u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\\\",None),\\n\",\n653:     \"               (\\\"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435\\\",20),(\\\"\u0434\u0432\u0435\u0441\u0438\\\",200)]:\\n\",\n654:     \"    tc = classify(w)\\n\",\n655:     \"    if exp is None: ok = tc is None\\n\",\n656:     \"    else: ok = tc and tc[0].value == exp\\n\",\n657:     \"    print(f\\\"  {chr(10003) if ok else chr(10007)} {w} -> {tc}\\\")\\n\",\n658:     \"print(f\\\"  {chr(10003) if classify('\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438') and len(classify('\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438'))==2 else chr(10007)} \u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 fused\\\")\\n\",\n659:     \"print(f\\\"  {chr(10003) if classify('\u0442\u044b\u0449',['\u0441','\u0447\u0435\u043c','\u0442\u043e']) and classify('\u0442\u044b\u0449',['\u0441','\u0447\u0435\u043c','\u0442\u043e'])[0].subtype=='vague' else chr(10007)} \u0442\u044b\u0449 vague\\\")\"\n660:    ]\n661:   },\n662:   {\n663:    \"cell_type\": \"markdown\",\n664:    \"id\": \"68fae262\",\n665:    \"metadata\": {},\n666:    \"source\": [\n667:     \"**\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0442\u0435\u0441\u0442\u043e\u0432 \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u0430:**\\n\",\n668:     \"\\n\",\n669:     \"| \u0421\u043b\u043e\u0432\u043e | \u0421\u0442\u0430\u0442\u0443\u0441 | \u041a\u043b\u0430\u0441\u0441 |\\n\",\n670:     \"|---|---|---|\\n\",\n671:     \"| \u043f\u044f\u0442\u044c | \u2713 | cardinal 5 |\\n\",\n672:     \"| \u0447\u0435\u0442\u044b\u0440\u043d\u0430\u0434\u0446\u0430\u0442\u044c | \u2713 | cardinal 14 |\\n\",\n673:     \"| \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 | \u2713 | cardinal 80 |\\n\",\n674:     \"| \u0442\u0440\u0438\u0441\u0442\u0430 | \u2713 | cardinal 300 |\\n\",\n675:     \"| \u0442\u044b\u0441\u044f\u0447\u0430 | \u2713 | multiplier 1000 |\\n\",\n676:     \"| \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u043e\u0435 | \u2713 | ordinal 20 |\\n\",\n677:     \"| \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440 | \u2713 | None |\\n\",\n678:     \"| \u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438 | \u2713 | fused 2+1000 |\\n\",\n679:     \"| \u0442\u044b\u0449 (\u0441 \u0447\u0435\u043c \u0442\u043e) | \u2713 | vague |\\n\",\n680:     \"| \u0434\u0432\u0435\u0441\u0438 | \u2713 | ASR -> 200 |\\n\",\n681:     \"\\n\",\n682:     \"\u0412\u0441\u0435 10 \u0442\u0435\u0441\u0442\u043e\u0432 \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0442. \u041a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u0435\u0442 \u0432\u0441\u0435 6 \u0442\u0438\u043f\u043e\u0432 \u0442\u043e\u043a\u0435\u043d\u043e\u0432.\"\n683:    ]\n684:   },\n685:   {\n686:    \"cell_type\": \"markdown\",\n687:    \"id\": \"e0ec4f48\",\n688:    \"metadata\": {},\n689:    \"source\": [\n690:     \"---\\n\",\n691:     \"## 4. Sequence Parser (\u043d\u043e\u0432\u044b\u0439 \u043f\u0443\u0442\u044c)\\n\",\n692:     \"\\n\",\n693:     \"State machine \u043d\u0430\u0434 `list[TokenClass]` \u0432\u043c\u0435\u0441\u0442\u043e `parse_number_group()`.\\n\",\n694:     \"\\n\",\n695:     \"**\u0421\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u044f:** START -> ACCUM -> MULTIPLY -> ACCUM / ENUM -> FLUSH -> START -> ORDINAL -> FLUSH\\n\",\n696:     \"\\n\",\n697:     \"**\u041f\u0440\u0430\u0432\u0438\u043b\u0430:**\\n\",\n698:     \"\\n\",\n699:     \"| Token[i] vs Token[i-1] | \u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435 |\\n\",\n700:     \"|---|---|\\n\",\n701:     \"| subtype=vague | \u041f\u0440\u043e\u043f\u0443\u0441\u0442\u0438\u0442\u044c (\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043a\u0430\u043a \u0442\u0435\u043a\u0441\u0442) |\\n\",\n702:     \"| subtype=multiplier | `compound += (current or 1) * val` |\\n\",\n703:     \"| subtype=ordinal | \u0424\u0438\u043d\u0430\u043b\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c current \u0441 ordinal \u0441\u0443\u0444\u0444\u0438\u043a\u0441\u043e\u043c |\\n\",\n704:     \"| mag < prev_mag | \u0421\u0443\u043c\u043c\u0430: `current += val` |\\n\",\n705:     \"| mag == prev_mag (\u043e\u0431\u0430 < 3) | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: flush, start new |\\n\",\n706:     \"| mag >= prev_mag (\u043e\u0431\u0430 == 3) | \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\\\" -> 200 300 |\\n\",\n707:     \"| same mult_mag | Enum: \\\"\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432...\u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\\\" -> 7e7 2e6 |\"\n708:    ]\n709:   },\n710:   {\n711:    \"cell_type\": \"code\",\n712:    \"execution_count\": null,\n713:    \"id\": \"62617952\",\n714:    \"metadata\": {},\n715:    \"outputs\": [],\n716:    \"source\": [\n717:     \"def _flush(compound, current, result, force=False):\\n\",\n718:     \"    total = compound + current\\n\",\n719:     \"    if total > 0 or force:\\n\",\n720:     \"        result.append(str(total))\\n\",\n721:     \"\\n\",\n722:     \"def parse_sequence(classes):\\n\",\n723:     \"    if not classes: return []\\n\",\n724:     \"    compound = current = 0\\n\",\n725:     \"    last_mag = last_mult_mag = -1\\n\",\n726:     \"    has_zero = False\\n\",\n727:     \"    result = []\\n\",\n728:     \"    for idx, tc in enumerate(classes):\\n\",\n729:     \"        if tc.subtype == \\\"vague\\\": continue\\n\",\n730:     \"        if tc.value == 0: has_zero = True\\n\",\n731:     \"        if tc.subtype == \\\"multiplier\\\":\\n\",\n732:     \"            if last_mult_mag == tc.mag:\\n\",\n733:     \"                _flush(compound, 0, result, force=has_zero)\\n\",\n734:     \"                compound = current * tc.value if current > 0 else tc.value\\n\",\n735:     \"                current = 0\\n\",\n736:     \"            else:\\n\",\n737:     \"                multiplied = current * tc.value if current > 0 else tc.value\\n\",\n738:     \"                compound += multiplied\\n\",\n739:     \"                current = 0\\n\",\n740:     \"            last_mult_mag, last_mag = tc.mag, -1\\n\",\n741:     \"            continue\\n\",\n742:     \"        if last_mag == -1:\\n\",\n743:     \"            current, last_mag = tc.value, tc.mag\\n\",\n744:     \"            continue\\n\",\n745:     \"        if tc.mag < last_mag:\\n\",\n746:     \"            if tc.mag <= 1 and idx < len(classes) - 1:\\n\",\n747:     \"                nxt = classes[idx + 1]\\n\",\n748:     \"                if nxt.subtype not in (\\\"multiplier\\\",\\\"vague\\\",\\\"ordinal\\\") and nxt.mag <= 1:\\n\",\n749:     \"                    _flush(compound, current, result, force=has_zero)\\n\",\n750:     \"                    compound, current = 0, tc.value\\n\",\n751:     \"                    last_mag, last_mult_mag = tc.mag, -1\\n\",\n752:     \"                    continue\\n\",\n753:     \"            current += tc.value\\n\",\n754:     \"            last_mag = tc.mag\\n\",\n755:     \"        else:\\n\",\n756:     \"            _flush(compound, current, result, force=has_zero)\\n\",\n757:     \"            compound, current = 0, tc.value\\n\",\n758:     \"            last_mag, last_mult_mag = tc.mag, -1\\n\",\n759:     \"    _flush(compound, current, result, force=has_zero)\\n\",\n760:     \"    if not result and has_zero: return [\\\"0\\\"]\\n\",\n761:     \"    return result\\n\"\n762:    ]\n763:   },\n764:   {\n765:    \"cell_type\": \"markdown\",\n766:    \"id\": \"919233b3\",\n767:    \"metadata\": {},\n768:    \"source\": [\n769:     \"**\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0442\u0435\u0441\u0442\u043e\u0432 sequence parser:**\\n\",\n770:     \"\\n\",\n771:     \"| \u0422\u0435\u0441\u0442 | \u0421\u0442\u0430\u0442\u0443\u0441 |\\n\",\n772:     \"|---|---|\\n\",\n773:     \"| 200+50=250 | \u2713 |\\n\",\n774:     \"| 200 300 (enum) | \u2713 |\\n\",\n775:     \"| 2843 (2x1000+800+40+3) | \u2713 |\\n\",\n776:     \"| 70M 2M (\u0434\u0432\u0430 \u0431\u043b\u043e\u043a\u0430) | \u2713 (\u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d) |\\n\",\n777:     \"| 285 (ordinal suffix) | \u2713 |\\n\",\n778:     \"\\n\",\n779:     \"\u0422\u0435\u0441\u0442 70M 2M \u0440\u0430\u043d\u0435\u0435 \u0432\u044b\u0434\u0430\u0432\u0430\u043b \u043e\u0448\u0438\u0431\u043a\u0443 70000002 \u0438\u0437-\u0437\u0430 \u043d\u0435\u0432\u0435\u0440\u043d\u043e\u0433\u043e compound+current \u043f\u0440\u0438 flush.\"\n780:    ]\n781:   },\n782:   {\n783:    \"cell_type\": \"markdown\",\n784:    \"id\": \"494af144\",\n785:    \"metadata\": {},\n786:    \"source\": [\n787:     \"---\\n\",\n788:     \"## 5. Legacy Parser (\u0441\u0442\u0430\u0440\u044b\u0439 \u043f\u0443\u0442\u044c)\\n\",\n789:     \"\\n\",\n790:     \"Mag-based parser: \u0440\u0430\u0437\u043b\u0438\u0447\u0430\u0435\u0442 \u0441\u0443\u043c\u043c\u0443 \u0438 \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 \u043f\u043e \u0440\u0430\u0437\u0440\u044f\u0434\u0430\u043c \u0441\u043e\u0441\u0435\u0434\u043d\u0438\u0445 \u0441\u043b\u043e\u0432.\\n\",\n791:     \"\\n\",\n792:     \"**\u041b\u043e\u0433\u0438\u043a\u0430:**\\n\",\n793:     \"- \u0420\u0430\u0437\u0440\u044f\u0434 \u043f\u043e\u043d\u0438\u0436\u0430\u0435\u0442\u0441\u044f (mag 3 -> 2) -> \u0441\u0443\u043c\u043c\u0430: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\" = 200+50 = 250\\n\",\n794:     \"- \u0420\u0430\u0437\u0440\u044f\u0434 \u043d\u0435 \u043c\u0435\u043d\u044f\u0435\u0442\u0441\u044f (mag 3 -> 3) -> \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435: \\\"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\\\" = 200 300\\n\",\n795:     \"- \u0423\u043c\u043d\u043e\u0436\u0438\u0442\u0435\u043b\u044c (\u0442\u044b\u0441\u044f\u0447\u0430/\u043c\u0438\u043b\u043b\u0438\u043e\u043d) -> \u0443\u043c\u043d\u043e\u0436\u0435\u043d\u0438\u0435: \\\"\u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447\\\" = 5*1000 = 5000\"\n796:    ]\n797:   },\n798:   {\n799:    \"cell_type\": \"code\",\n800:    \"execution_count\": null,\n801:    \"id\": \"881fca34\",\n802:    \"metadata\": {},\n803:    \"outputs\": [],\n804:    \"source\": [\n805:     \"def lookup_word(word):\\n\",\n806:     \"    w = word.lower()\\n\",\n807:     \"    if w in NUMERAL_DICT:\\n\",\n808:     \"        val, mag = NUMERAL_DICT[w]\\n\",\n809:     \"        return (val, mag, w in MULTIPLIERS)\\n\",\n810:     \"    if w in ASR_ERRORS:\\n\",\n811:     \"        c = ASR_ERRORS[w]\\n\",\n812:     \"        if c in NUMERAL_DICT:\\n\",\n813:     \"            val, mag = NUMERAL_DICT[c]\\n\",\n814:     \"            return (val, mag, c in MULTIPLIERS)\\n\",\n815:     \"    r = classify(word)\\n\",\n816:     \"    if r and not any(t.subtype == \\\"vague\\\" for t in r):\\n\",\n817:     \"        tc = r[0]\\n\",\n818:     \"        return (tc.value, tc.mag, tc.subtype == \\\"multiplier\\\")\\n\",\n819:     \"    return None\\n\",\n820:     \"\\n\",\n821:     \"def is_ordinal_word(word):\\n\",\n822:     \"    w = word.lower()\\n\",\n823:     \"    if w in ORDINAL_SET: return True\\n\",\n824:     \"    if w in NUMERAL_DICT or w in ASR_ERRORS: return False\\n\",\n825:     \"    r = classify(word)\\n\",\n826:     \"    return r and r[0].subtype == \\\"ordinal\\\" if r else False\\n\",\n827:     \"\\n\",\n828:     \"def ordinal_value(word):\\n\",\n829:     \"    w = word.lower()\\n\",\n830:     \"    if w in ORDINALS: return ORDINALS[w]\\n\",\n831:     \"    if w in NUMERAL_DICT or w in ASR_ERRORS: return None\\n\",\n832:     \"    r = classify(word)\\n\",\n833:     \"    return str(r[0].value) if r and r[0].subtype == \\\"ordinal\\\" else None\"\n834:    ]\n835:   },\n836:   {\n837:    \"cell_type\": \"code\",\n838:    \"execution_count\": null,\n839:    \"id\": \"a8c45d97\",\n840:    \"metadata\": {},\n841:    \"outputs\": [],\n842:    \"source\": [\n843:     \"def parse_number_group(tokens_data):\\n\",\n844:     \"    if not tokens_data: return []\\n\",\n845:     \"    single_mult = len(tokens_data) == 1 and tokens_data[0][2]\\n\",\n846:     \"    compound = current = 0\\n\",\n847:     \"    last_mag = last_mult_mag = -1\\n\",\n848:     \"    result = []\\n\",\n849:     \"    for j, (val, mag, is_mult, _) in enumerate(tokens_data):\\n\",\n850:     \"        if is_mult:\\n\",\n851:     \"            if last_mult_mag == mag:\\n\",\n852:     \"                result.append(str(int(compound)))\\n\",\n853:     \"                compound = current * val if current > 0 else val\\n\",\n854:     \"                current = 0\\n\",\n855:     \"            else:\\n\",\n856:     \"                multiplied = current * val if current > 0 else val\\n\",\n857:     \"                compound += multiplied; current = 0\\n\",\n858:     \"            last_mult_mag, last_mag = mag, -1\\n\",\n859:     \"        else:\\n\",\n860:     \"            if last_mag == -1:\\n\",\n861:     \"                current, last_mag = val, mag\\n\",\n862:     \"            elif mag < last_mag:\\n\",\n863:     \"                if mag <= 1 and j+1 < len(tokens_data) and tokens_data[j+1][1] == mag:\\n\",\n864:     \"                    result.append(str(int(compound+current)))\\n\",\n865:     \"                    compound, current = 0, val\\n\",\n866:     \"                    last_mag, last_mult_mag = mag, -1\\n\",\n867:     \"                else:\\n\",\n868:     \"                    current += val; last_mag = mag\\n\",\n869:     \"            else:\\n\",\n870:     \"                result.append(str(int(compound+current)))\\n\",\n871:     \"                compound, current = 0, val\\n\",\n872:     \"                last_mag, last_mult_mag = mag, -1\\n\",\n873:     \"    if single_mult:\\n\",\n874:     \"        v = tokens_data[0][0]\\n\",\n875:     \"        return [str(int(v))] if v in (1000,1000000,1000000000) else []\\n\",\n876:     \"    t = compound + current\\n\",\n877:     \"    if t > 0 or (len(tokens_data) >= 1 and any(td[0]==0 for td in tokens_data)):\\n\",\n878:     \"        result.append(str(int(t)))\\n\",\n879:     \"    return result\"\n880:    ]\n881:   },\n882:   {\n883:    \"cell_type\": \"markdown\",\n884:    \"id\": \"e811d965\",\n885:    \"metadata\": {},\n886:    \"source\": [\n887:     \"---\\n\",\n888:     \"## 6. ASR-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433 + \u041d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0442\u043e\u0440\\n\",\n889:     \"\\n\",\n890:     \"### ASR regex-\u043f\u0440\u0435\u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0438\u043d\u0433\\n\",\n891:     \"\\n\",\n892:     \"\u041a\u043e\u0440\u0440\u0435\u043a\u0442\u0438\u0440\u0443\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0435 ASR-\u043e\u0448\u0438\u0431\u043a\u0438 \u0434\u043e \u0442\u043e\u043a\u0435\u043d\u0438\u0437\u0430\u0446\u0438\u0438:\\n\",\n893:     \"\\n\",\n894:     \"1. **\\\"\u0434\u0432\u0435\u0441\u0438\\\" + hundred + (ten) + \u0442\u044b\u0441\u044f\u0447** \u2014 \u0441\u0434\u0432\u0438\u0433 \u0440\u0430\u0437\u0440\u044f\u0434\u043e\u0432:\\n\",\n895:     \"   `\u0434\u0432\u0435\u0441\u0438 \u0442\u0440\u0438\u0441\u0442\u0430 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442 \u0442\u044b\u0441\u044f\u0447` -> `\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c \u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447` -> 235000\\n\",\n896:     \"2. **\u041f\u0440\u043e\u043f\u0443\u0449\u0435\u043d\u043d\u044b\u0439 \u043c\u044f\u0433\u043a\u0438\u0439 \u0437\u043d\u0430\u043a**: \u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442 -> \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442, \u0448\u0435\u0441\u0442\u0434\u0435\u0441\u044f\u0442 -> \u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\n\",\n897:     \"3. **\u041f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u043e\u0448\u0438\u0431\u043a\u0438**: \u0442\u0440\u0438\u0441\u0442\u043e -> \u0442\u0440\u0438\u0441\u0442\u0430, \u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430 -> \u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\n\",\n898:     \"\\n\",\n899:     \"### \u0414\u0438\u0441\u0430\u043c\u0431\u0438\u0433\u0443\u0430\u0446\u0438\u044f (pymorphy2)\\n\",\n900:     \"\\n\",\n901:     \"\u041e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u0447\u0430\u0441\u0442\u0438 \u0440\u0435\u0447\u0438 \u0434\u043b\u044f \u043e\u043c\u043e\u043d\u0438\u043c\u043e\u0432: \\\"\u0441\u0442\u043e\\\" (100 vs \u0433\u043b\u0430\u0433\u043e\u043b), \\\"\u0442\u0440\u0438\\\" (3 vs \u0442\u0435\u0440\u0435\u0442\u044c).\\n\",\n902:     \"\u041f\u0430\u0442\u0442\u0435\u0440\u043d\u044b:\\n\",\n903:     \"- `\u0441\u0442\u043e \u0440\u0443\u0431\u043b\u0435\u0439` -> \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435\\n\",\n904:     \"- `\u044f \u0441\u0442\u043e` -> \u0433\u043b\u0430\u0433\u043e\u043b\\n\",\n905:     \"- \u0415\u0441\u043b\u0438 \u043d\u0435\u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0451\u043d\u043d\u043e -> pymorphy2 POS-\u0442\u0435\u0433\u0433\u0438\u043d\u0433\"\n906:    ]\n907:   },\n908:   {\n909:    \"cell_type\": \"code\",\n910:    \"execution_count\": null,\n911:    \"id\": \"3011f6ac\",\n912:    \"metadata\": {},\n913:    \"outputs\": [],\n914:    \"source\": [\n915:     \"_HUNDRED_TO_TEN = {\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\":\\\"\u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044c\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\":\\\"\u0441\u043e\u0440\u043e\u043a\\\",\\\"\u043f\u044f\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\n\",\n916:     \"    \\\"\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\":\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442\\\":\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\",\\\"\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442\\\":\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\"}\\n\",\n917:     \"_TEN_TO_UNIT = {\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u043f\u044f\u0442\u044c\\\",\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0448\u0435\u0441\u0442\u044c\\\",\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0441\u0435\u043c\u044c\\\",\\n\",\n918:     \"    \\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\":\\\"\u0432\u043e\u0441\u0435\u043c\u044c\\\",\\\"\u0434\u0435\u0432\u044f\u043d\u043e\u0441\u0442\u043e\\\":\\\"\u0434\u0435\u0432\u044f\u0442\u044c\\\"}\\n\",\n919:     \"\\n\",\n920:     \"def _asr_preprocess(text):\\n\",\n921:     \"    text = re.sub(\\n\",\n922:     \"        r\\\"\\\\b\u0434\u0432\u0435\u0441\u0438\\\\s+(\u0442\u0440\u0438\u0441\u0442\u0430|\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430|\u043f\u044f\u0442\u044c\u0441\u043e\u0442|\u0448\u0435\u0441\u0442\u044c\u0441\u043e\u0442|\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0441\u043e\u0442|\u0434\u0435\u0432\u044f\u0442\u044c\u0441\u043e\u0442)\\\"\\n\",\n923:     \"        r\\\"(?:\\\\s+(\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442|\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442|\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442))?\\\\s+\u0442\u044b\u0441\u044f\u0447[\u0430\u0438]?\\\\b\\\",\\n\",\n924:     \"        lambda m: \\\" \\\".join(\\n\",\n925:     \"            [\\\"\u0434\u0432\u0435\u0441\u0442\u0438\\\", _HUNDRED_TO_TEN.get(m.group(1),m.group(1))]\\n\",\n926:     \"            + ([_TEN_TO_UNIT.get(m.group(2))] if m.group(2) in _TEN_TO_UNIT else [])\\n\",\n927:     \"            + [\\\"\u0442\u044b\u0441\u044f\u0447\\\"]), text)\\n\",\n928:     \"    for p,r in [(r\\\"\\\\b\u043f\u044f\u0442\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\"),(r\\\"\\\\b\u0448\u0435\u0441\u0442\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0448\u0435\u0441\u0442\u044c\u0434\u0435\u0441\u044f\u0442\\\"),\\n\",\n929:     \"                 (r\\\"\\\\b\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\"),(r\\\"\\\\b\u0432\u043e\u0441\u0435\u043c\u0434\u0435\u0441\u044f\u0442\\\\b\\\",\\\"\u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442\\\"),\\n\",\n930:     \"                 (r\\\"\\\\b\u0442\u0440\u0438\u0441\u0442\u043e\\\\b\\\",\\\"\u0442\u0440\u0438\u0441\u0442\u0430\\\"),(r\\\"\\\\b\u0447\u0435\u0442\u044b\u0440\u0438\u0441\u0442\u0430\\\\b\\\",\\\"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\\\")]:\\n\",\n931:     \"        text = re.sub(p, r, text)\\n\",\n932:     \"    return text\"\n933:    ]\n934:   },\n935:   {\n936:    \"cell_type\": \"code\",\n937:    \"execution_count\": null,\n938:    \"id\": \"b684f41f\",\n939:    \"metadata\": {},\n940:    \"outputs\": [],\n941:    \"source\": [\n942:     \"def _is_vague_tyt_context(tokens, i):\\n\",\n943:     \"    if i < 1: return False\\n\",\n944:     \"    p = tokens[i-1]\\n\",\n945:     \"    if p in (\\\"\u0432\u044b\u0448\u0435\\\",\\\"\u043d\u0438\u0436\u0435\\\",\\\"\u043e\u043a\u043e\u043b\u043e\\\"): return True\\n\",\n946:     \"    if p==\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\" or (p==\\\"\u0441\\\" and i>=2 and tokens[i-2]==\\\"\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439\\\"): return True\\n\",\n947:     \"    if i>=3 and tokens[i-3]==\\\"\u0441\\\" and tokens[i-2]==\\\"\u0447\u0435\u043c\\\" and tokens[i-1]==\\\"\u0442\u043e\\\": return True\\n\",\n948:     \"    if i>=2 and tokens[i-2]==\\\"\u0433\u0434\u0435\\\" and tokens[i-1]==\\\"\u0442\u043e\\\": return True\\n\",\n949:     \"    return False\\n\",\n950:     \"\\n\",\n951:     \"_FUSED_COMPOUNDS = {\\\"\u0434\u0432\u0435\u0442\u044b\u0441\u044f\u0447\u0438\\\": [(2,0,False,False), (1000,4,True,False)]}\\n\",\n952:     \"_STO_PATTERNS = [\\n\",\n953:     \"    (r\\\"\\\\b\u0441\u0442\u043e\\\\s+(\u0440\u0443\u0431\u043b|\u0434\u043e\u043b\u043b\u0430\u0440|\u0435\u0432\u0440\u043e|\u0442\u044b\u0441\u044f\u0447|\u043c\u0438\u043b\u043b\u0438\u043e\u043d|\u043f\u0440\u043e\u0446\u0435\u043d\u0442|\u0440\u0430\u0437|\u0447\u0435\u043b\u043e\u0432\u0435\u043a|\u0448\u0442\u0443\u043a)\\\", True),\\n\",\n954:     \"    (r\\\"\\\\b(\u0434\u043e|\u043e\u043a\u043e\u043b\u043e|\u0431\u043e\u043b\u0435\u0435|\u043c\u0435\u043d\u0435\u0435|\u0441\u0432\u044b\u0448\u0435|\u043f\u043e\u0447\u0442\u0438)\\\\s+\u0441\u0442\u043e\\\\b\\\", True),\\n\",\n955:     \"    (r\\\"\\\\b\u044f\\\\s+\u0441\u0442\u043e\\\\b\\\", False), (r\\\"\\\\b\u0441\u0442\u043e\\\\s+(\u043d\u0430|\u0432|\u0443|\u0437\u0430|\u043f\u0435\u0440\u0435\u0434)\\\\b\\\", False),\\n\",\n956:     \"]\\n\",\n957:     \"def is_likely_numeric(text, word, pos):\\n\",\n958:     \"    if word.lower() == \\\"\u0441\u0442\u043e\\\":\\n\",\n959:     \"        for pat, is_num in _STO_PATTERNS:\\n\",\n960:     \"            if re.search(pat, text): return is_num\\n\",\n961:     \"    return True\"\n962:    ]\n963:   },\n964:   {\n965:    \"cell_type\": \"markdown\",\n966:    \"id\": \"20160bab\",\n967:    \"metadata\": {},\n968:    \"source\": [\n969:     \"### \u0414\u0432\u0430 \u043f\u0430\u0440\u0430\u043b\u043b\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0443\u0442\u0438 \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438\\n\",\n970:     \"\\n\",\n971:     \"**Path A (legacy, default):** `normalize_text()` -> `lookup_word()` -> `parse_number_group()`\\n\",\n972:     \"\\n\",\n973:     \"**Path B (sequence):** `normalize_text_sequence()` -> `classify()` -> `parse_sequence()`\"\n974:    ]\n975:   },\n976:   {\n977:    \"cell_type\": \"code\",\n978:    \"execution_count\": null,\n979:    \"id\": \"db2f5ed6\",\n980:    \"metadata\": {},\n981:    \"outputs\": [],\n982:    \"source\": [\n983:     \"def normalize_text(text):\\n\",\n984:     \"    if not isinstance(text, str) or not text.strip(): return text\\n\",\n985:     \"    text = _asr_preprocess(text)\\n\",\n986:     \"    tokens = text.split()\\n\",\n987:     \"    result_tokens, i = [], 0\\n\",\n988:     \"    while i < len(tokens):\\n\",\n989:     \"        t = tokens[i]\\n\",\n990:     \"        if t in (\\\"\u0442\u044b\u0449\\\",\\\"\u0442\u044b\u0449\u0430\\\") and _is_vague_tyt_context(tokens,i):\\n\",\n991:     \"            result_tokens.append(t); i += 1; continue\\n\",\n992:     \"        lk, io = lookup_word(t), is_ordinal_word(t)\\n\",\n993:     \"        if lk and not io and not is_likely_numeric(text,t,i):\\n\",\n994:     \"            result_tokens.append(t); i += 1; continue\\n\",\n995:     \"        if lk or io:\\n\",\n996:     \"            start = i\\n\",\n997:     \"            while i < len(tokens):\\n\",\n998:     \"                if lookup_word(tokens[i]) is not None or is_ordinal_word(tokens[i]): i += 1\\n\",\n999:     \"                else: break\\n\",\n1000:     \"            gd = []\\n\",\n\n(Output capped at 50 KB. Showing lines 1-1000. Use offset=1001 to continue.)\n</content>"
