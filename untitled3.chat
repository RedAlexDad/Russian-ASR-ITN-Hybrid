            "raw_output": {
              "output": "\"\"\"\n\u041c\u043e\u0434\u0443\u043b\u044c \u0441\u043b\u043e\u0432\u0430\u0440\u0435\u0439: \u0441\u043e\u0442\u043d\u0438 100-900.\n\n\u0417\u0430\u0447\u0435\u043c \u044d\u0442\u043e \u043d\u0443\u0436\u043d\u043e:\n  \u0421\u043e\u0442\u043d\u0438 \u2014 \u0442\u0440\u0435\u0442\u0438\u0439 \u0440\u0430\u0437\u0440\u044f\u0434 \u0447\u0438\u0441\u043b\u0430 (\u043f\u043e\u0441\u043b\u0435 \u0435\u0434\u0438\u043d\u0438\u0446 \u0438 \u0434\u0435\u0441\u044f\u0442\u043a\u043e\u0432).\n  \u0412 ASR-\u0442\u0440\u0430\u043d\u0441\u043a\u0440\u0438\u0431\u0430\u0446\u0438\u044f\u0445 \u0447\u0430\u0441\u0442\u043e \u0438\u0441\u043a\u0430\u0436\u0430\u044e\u0442\u0441\u044f: \"\u0434\u0432\u0435\u0441\u0438\" \u0432\u043c\u0435\u0441\u0442\u043e \"\u0434\u0432\u0435\u0441\u0442\u0438\", \"\u0434\u0432\u0430\u0441\u0442\u0430\" \u0432\u043c\u0435\u0441\u0442\u043e \"\u0434\u0432\u0435\u0441\u0442\u0438\".\n  \u041c\u044b \u0445\u0440\u0430\u043d\u0438\u043c \u0438 \u043a\u0430\u043d\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0444\u043e\u0440\u043c\u044b, \u0438 \u0442\u0438\u043f\u0438\u0447\u043d\u044b\u0435 ASR-\u043e\u0448\u0438\u0431\u043a\u0438 \u043f\u0440\u044f\u043c\u043e \u0437\u0434\u0435\u0441\u044c.\n\n\u0424\u043e\u0440\u043c\u0430\u0442: \u0441\u043b\u043e\u0432\u043e -> (\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435, mag=3)\n  mag=3 \u2014 \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0441\u043e\u0442\u0435\u043d, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043f\u0430\u0440\u0441\u0435\u0440\u043e\u043c \u0434\u043b\u044f \u0433\u0440\u0443\u043f\u043f\u0438\u0440\u043e\u0432\u043a\u0438.\n  \u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440: \"\u0434\u0432\u0435\u0441\u0442\u0438 \u043f\u044f\u0442\u044c\u0434\u0435\u0441\u044f\u0442\" (mag 3 > 2) -> \u0441\u0443\u043c\u043c\u0430 250\n            \"\u0434\u0432\u0435\u0441\u0442\u0438 \u0442\u0440\u0438\u0441\u0442\u0430\" (mag 3 == 3) -> \u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 200 300\n\"\"\"\n\nHUNDREDS = {\n    # \u041a\u0430\u043d\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0444\u043e\u0440\u043c\u044b\n    \"\u0441\u0442\u043e\": (100, 3),\n    \"\u0441\u0442\u0430\": (100, 3),\n    # \"\u0434\u0432\u0435\u0441\u0442\u0438\" \u0438 \u0432\u0441\u0435 \u043f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u044b\n    \"\u0434\u0432\u0435\u0441\u0442\u0438\": (200, 3),\n    \"\u0434\u0432\u0443\u0445\u0441\u043e\u0442\": (200, 3),\n    \"\u0434\u0432\u0443\u043c\u0441\u0442\u0430\u043c\": (200, 3),\n    \"\u0434\u0432\u0443\u043c\u044f\u0441\u0442\u0430\u043c\u0438\": (200, 3),\n    \"\u0434\u0432\u0443\u0445\u0441\u0442\u0430\u0445\": (200, 3),\n    # ASR-\u043e\u0448\u0438\u0431\u043a\u0438: \u043d\u0430\u0438\u0431\u043e\u043b\u0435\u0435 \u0447\u0430\u0441\u0442\u043e\u0435 \u0438\u0441\u043a\u0430\u0436\u0435\u043d\u0438\u0435 (44 \u0432\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u044f \u0432 calibration.f)\n    \"\u0434\u0432\u0435\u0441\u0438\": (200, 3),\n    \"\u0434\u0432\u0430\u0441\u0442\u0430\": (200, 3),\n    # \"\u0442\u0440\u0438\u0441\u0442\u0430\" \u0438 \u043f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u044b\n    \"\u0442\u0440\u0438\u0441\u0442\u0430\": (300, 3),\n    \"\u0442\u0440\u0451\u0445\u0441\u043e\u0442\": (300, 3),\n    \"\u0442\u0440\u0435\u0445\u0441\u043e\u0442\": (300, 3),\n    \"\u0442\u0440\u0435\u043c\u0441\u0442\u0430\u043c\": (300, 3),\n    \"\u0442\u0440\u0435\u043c\u044f\u0441\u0442\u0430\u043c\u0438\": (300, 3),\n    \"\u0442\u0440\u0451\u0445\u0441\u0442\u0430\u0445\": (300, 3),\n    # \"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\" \u0438 \u043f\u0430\u0434\u0435\u0436\u043d\u044b\u0435 \u0444\u043e\u0440\u043c\u044b\n    \"\u0447\u0435\u0442\u044b\u0440\u0435\u0441\u0442\u0430\": (400, 3),\n    \"\u0447\u0435\u0442\u044b\u0440\u0451\u0445\u0441\u043e