ource\\\": [\\n    \\\"---\\\\n\\\",\\n    \\\"## 17. ML \u043f\u043e\u0434\u0445\u043e\u0434 \u2014 ruT5-small + LoRA (deep dive)\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"### \u041f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u043f\u0435\u0440\u0435\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"\u041f\u043e\u043b\u043d\u043e\u0435 fine-tuning ruT5-small (65M \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043e\u0432) \u043d\u0430 <500 samples:\\\\n\\\",\\n    \\\"- eval_loss=0.2, accuracy=0%\\\\n\\\",\\n    \\\"- \u0413\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f \u043c\u0443\u0441\u043e\u0440\u043d\u044b\u0445 \u0442\u043e\u043a\u0435\u043d\u043e\u0432 `<0x57>`\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"**\u041f\u0440\u0438\u0447\u0438\u043d\u0430:** \u043c\u0435\u0442\u043a\u0438 \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043b\u0438 `<pad>` (id=0) \u0432\u043c\u0435\u0441\u0442\u043e `-100`.\\\\n\\\",\\n    \\\"\u041c\u043e\u0434\u0435\u043b\u044c \u0443\u0447\u0438\u043b\u0430\u0441\u044c \u043f\u0440\u0435\u0434\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u043f\u0430\u0434\u0434\u0438\u043d\u0433 \u043a\u0430\u043a \u0432\u0430\u043b\u0438\u0434\u043d\u044b\u0439 \u0442\u043e\u043a\u0435\u043d.\\\\n\\\",\\n    \\\"**\u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435:** `labels[labels == 0] = -100`\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"code\\\",\\n   \\\"metadata\\\": {},\\n   \\\"outputs\\\": [],\\n   \\\"source\\\": [\\n    \\\"# \u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f\\\\n\\\",\\n    \\\"print('=== LoRA \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f ===')\\\\n\\\",\\n    \\\"lora_config = {\\\\n\\\",\\n    \\\"    'r': 8,\\\\n\\\",\\n    \\\"    'lora_alpha': 16,\\\\n\\\",\\n    \\\"    'target_modules': ['q', 'v', 'k', 'o', 'wi', 'wo'],\\\\n\\\",\\n    \\\"    'lora_dropout': 0.1,\\\\n\\\",\\n    \\\"    'task_type': 'SEQ_2_SEQ_LM',\\\\n\\\",\\n    \\\"}\\\\n\\\",\\n    \\\"print(f'  LoRA rank r={lora_config[\\\\\\\"r\\\\\\\"]}')\\\\n\\\",\\n    \\\"print(f'  Alpha: {lora_config[\\\\\\\"lora_alpha\\\\\\\"]}')\\\\n\\\",\\n    \\\"print(f'  Target modules: {lora_config[\\\\\\\"target_modules\\\\\\\"]}')\\\\n\\\",\\n    \\\"print(f'  Dropout: {lora_config[\\\\\\\"lora_dropout\\\\\\\"]}')\\\\n\\\",\\n    \\\"print(f'  \u041e\u0431\u0443\u0447\u0430\u0435\u043c\u044b\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b: 0.9M \u0438\u0437 66M (1.36%)')\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"print('\\\\\\\\n=== \u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f ===')\\\\n\\\",\\n    \\\"train_config = {\\\\n\\\",\\n    \\\"    'model': 'cointegrated/ruT5-small',\\\\n\\\",\\n    \\\"    'batch_size': 16,\\\\n\\\",\\n    \\\"    'max_length': 128,\\\\n\\\",\\n    \\\"    'optimizer': 'AdamW',\\\\n\\\",\\n    \\\"    'lr': 5e-5,\\\\n\\\",\\n    \\\"    'eval_strategy': 'epoch',\\\\n\\\",\\n    \\\"    'early_stopping_patience': 5,\\\\n\\\",\\n    \\\"    'data': 'synthetic.f (clean only, 4890 samples)',\\\\n\\\",\\n    \\\"    'test_split': '10%',\\\\n\\\",\\n    \\\"}\\\\n\\\",\\n    \\\"for k, v in train_config.items():\\\\n\\\",\\n    \\\"    print(f'  {k}: {v}')\\\"\\n   ]\\n  },\\n  {\\n   \\\"cell_type\\\": \\\"markdown\\\",\\n   \\\"metadata\\\": {},\\n   \\\"source\\\": [\\n    \\\"### 17.1 \u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0432\u0441\u0435\u0445 \u0437\u0430\u043f\u0443\u0441\u043a\u043e\u0432\\\\n\\\",\\n    \\\"\\\\n\\\",\\n    \\\"| \u0417\u0430\u043f\u0443\u0441\u043a | \u042d\u043f\u043e\u0445\u0438 | \u0421\u044d\u043c\u043f\u043b\u044b | Data | Accuracy | Num_acc | CER | \u0412\u0440\u0435\u043c\u044f |\\\\n\\\",\\n    \\\"|---|---|---|---|---|---|---|---|\\\\n\\\",\\n    \\\"| ep3_s1000 | 3 | 1000 | clean | 0.00% | 0.00% | 0.819 