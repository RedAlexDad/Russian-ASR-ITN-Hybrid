              "output": "\"\"\"\n\u041c\u043e\u0434\u0443\u043b\u044c \u0441\u043b\u043e\u0432\u0430\u0440\u0435\u0439: \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435.\n\n\u0417\u0430\u0447\u0435\u043c \u044d\u0442\u043e \u043d\u0443\u0436\u043d\u043e:\n  \u0412 \u0437\u0430\u0434\u0430\u043d\u0438\u0438 \u044f\u0432\u043d\u043e \u0441\u043a\u0430\u0437\u0430\u043d\u043e: \u043d\u043e\u0440\u043c\u0430\u043b\u0438\u0437\u0443\u0435\u043c \u0438 \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435 \u0442\u043e\u0436\u0435.\n  \"\u043f\u0435\u0440\u0432\u043e\u0433\u043e \u0447\u0438\u0441\u043b\u0430\" -> \"1 \u0447\u0438\u0441\u043b\u0430\", \"\u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044c \u043f\u044f\u0442\u043e\u0433\u043e\" -> \"25\".\n  \u041f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0435 \u0438\u043c\u0435\u044e\u0442 \u0442\u0435 \u0436\u0435 mag, \u0447\u0442\u043e \u0438 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 (\u043f\u0435\u0440\u0432\u044b\u0439 -> 1, \u0432\u0442\u043e\u0440\u043e\u0439 -> 2),\n  \u043d\u043e \u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u044e\u0442\u0441\u044f \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e \u0447\u0435\u0440\u0435\u0437 is_ordinal_word().\n\n\u0424\u043e\u0440\u043c\u0430\u0442: \u0441\u043b\u043e\u0432\u043e -> \u0441\u0442\u0440\u043e\u043a\u043e\u0432\u043e\u0435_\u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0438\u0435_\u0446\u0438\u0444\u0440\u044b\n  \u0425\u0440\u0430\u043d\u0438\u043c \u043a\u0430\u043a \u0441\u0442\u0440\u043e\u043a\u0443, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e ordinal_value() \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442 str \u0434\u043b\u044f \u0432\u0441\u0442\u0430\u0432\u043a\u0438 \u0432 \u0442\u0435\u043a\u0441\u0442.\n\n\u041e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u0438:\n  - \u0423 \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u044b\u0445 \u043d\u0435\u0442 mag \u2014 \u043e\u043d\u0438 \u043d\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044e\u0442 \u0432 \u0433\u0440\u0443\u043f\u043f\u0438\u0440\u043e\u0432\u043a\u0435 \u0441\u0443\u043c\u043c\u044b/\u043f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e\n  - \u041d\u043e \u0435\u0441\u043b\u0438 \u043f\u043e\u0440\u044f\u0434\u043a\u043e\u0432\u043e\u0435 \u0441\u0442\u043e\u0438\u0442 \u043f\u043e\u0441\u043b\u0435 \u0447\u0438\u0441\u043b\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0441 \u0443\u0431\u044b\u0432\u0430\u044e\u0449\u0435\u0439 mag,\n    \u043f\u0430\u0440\u0441\u0435\u0440 \u043c\u043e\u0436\u0435\u0442 \u0432\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0435\u0433\u043e \u0432 \u0433\u0440\u0443\u043f\u043f\u0443: \"\u0434\u0432\u0435\u0441\u0442\u0438 \u0432\u043e\u0441\u0435\u043c\u044c\u0434\u0435\u0441\u044f\u0442 \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u044b\u0439\" -> 284\n\"\"\"\n\nORDINALS = {\n    # \"\u043f\u0435\u0440\u0432\u044b\u0439\" \u0438 \u0432\u0441\u0435 12 \u043f\u0430\u0434\u0435\u0436\u043d\u044b\u0445 \u0444\u043e\u0440\u043c (\u043c.\u0440., \u0436.\u0440., \u0441\u0440.\u0440., \u043c\u043d.\u0447.)\n    \"\u043f\u0435\u0440\u0432\u044b\u0439\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u043e\u0433\u043e\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u043e\u043c\u0443\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u044b\u043c\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u043e\u043c\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u0430\u044f\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u043e\u0439\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u0443\u044e\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u043e\u0435\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u044b\u0435\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u044b\u0445\": \"1\",\n    \"\u043f\u0435\u0440\u0432\u044b\u043c\u0438\": \"1\",\n    # \"\u0432\u0442\u043e\u0440\u043e\u0439\" \u2014 \u0432\u0441\u0435 \u0444\u043e\u0440\u043c\u044b\n    \"\u0432\u0442\u043e\u0440\u043e\u0439\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u043e\u0433\u043e\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u043e\u043c\u0443\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u044b\u043c\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u043e\u043c\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u0430\u044f\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u0443\u044e\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u043e\u0435\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u044b\u0435\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u044b\u0445\": \"2\",\n    \"\u0432\u0442\u043e\u0440\u044b\u043c\u0438\": \"2\",\n    # \"\u0442\u0440\u0435\u0442\u0438\u0439\" \u2014 \u0447\u0435\u0440\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u043e\u0441\u043d\u043e\u0432\u044b (\u0442\u0440\u0435\u0442\u044c-/\u0442\u0440\u0435\u0442\u044cj-)\n    \"\u0442\u0440\u0435\u0442\u0438\u0439\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0435\u0433\u043e\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0435\u043c\u0443\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0438\u043c\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0435\u043c\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u044f\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0435\u0439\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u044e\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0435\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0438\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0438\u0445\": \"3\",\n    \"\u0442\u0440\u0435\u0442\u044c\u0438\u043c\u0438\": \"3\",\n    # \"\u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044b\u0439\"\n    \"\u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044b\u0439\": \"4\",\n    \"\u0447\u0435\u0442\u0432\u0435\u0440\u0442\u043e\u0433\u043e\": \"4\",\n    \"\u0447\u0435\u0442\u0432\u0435\u0440\u0442\u043e\u043c\u0443\": \"4\",\n    \"\u0447\u0435\u0442\u0432\u04